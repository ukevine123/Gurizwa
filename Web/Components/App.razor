    <script>
        window.downloadFileFromStream = async (fileName, contentStreamReference, contentType) => {
    const arrayBuffer = await contentStreamReference.arrayBuffer();
    
    // 1. Determine the correct MIME type based on the provided content type or file extension
    let mimeType = contentType || 'application/pdf'; // Default
    if (!contentType) {
        const extension = fileName.toLowerCase().split('.').pop();
        if (extension === 'png') mimeType = 'image/png';
        else if (extension === 'jpg' || extension === 'jpeg') mimeType = 'image/jpeg';
        else if (extension === 'gif') mimeType = 'image/gif';
    }

    // 2. Create the Blob with the correct type
    const blob = new Blob([arrayBuffer], { type: mimeType });
    const url = URL.createObjectURL(blob);
    
    // 3. Open in a new tab
    const newWindow = window.open(url, '_blank');
    
    if (!newWindow) {
        alert("Please allow pop-ups for this website to view documents.");
    }

    // 4. Cleanup memory after 1 minute
    setTimeout(() => URL.revokeObjectURL(url), 60000);
}

        window.triggerFileDownload = async (fileName, contentStreamReference) => {
            const arrayBuffer = await contentStreamReference.arrayBuffer();
            const blob = new Blob([arrayBuffer]);
            const url = URL.createObjectURL(blob);
            const anchorElement = document.createElement('a');
            anchorElement.href = url;
            anchorElement.download = fileName ?? '';
            anchorElement.click();
            anchorElement.remove();
            URL.revokeObjectURL(url);
        };
    </script>

</body>

</html>
