@namespace Web.Components.Layout
@using System
@using Application.Interfaces

@inject IUserContext UserContext

<style>
    .mud-nav-link.active {
        color: white !important;
        background-color: transparent !important;
        font-weight: 700;
        border-right: 4px solid #4318FF;
    }
    .mud-nav-link.active .mud-nav-link-icon {
        color: #4318FF !important;
    }
</style>



@code {
    [Parameter] public bool IsMini { get; set; }

    private bool IsDeveloper =>
        string.Equals(UserContext.Email, "guriza291@gmail.com", StringComparison.OrdinalIgnoreCase);

    private bool CanViewUsersMenu => UserContext.IsAuthenticated && (UserContext.PrimaryRole == "Tenant" || IsDeveloper);

    private bool HasRole(string roleName)
    {
        if (UserContext.PrimaryRole == "Tenant" || IsDeveloper)
            return true;

        return UserContext.Roles.Any(r => 
            string.Equals(r, roleName, StringComparison.OrdinalIgnoreCase) || 
            r.EndsWith("_" + roleName, StringComparison.OrdinalIgnoreCase)
        );
    }
}

<MudNavMenu>
    <MudNavLink href="/Home" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Home">
        @(!IsMini ? "Home Hub" : "")
    </MudNavLink>

    <MudNavLink href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Dashboard">
        @(!IsMini ? "Dashboard" : "")
    </MudNavLink>

    @if (HasRole("Accountant"))
    {
        <MudNavLink href="/accounts" Icon="@Icons.Material.Outlined.ManageAccounts">
            @(!IsMini ? "Account" : "")
        </MudNavLink>
    }

    @if (HasRole("Loan Officer") || HasRole("LoanOfficer"))
    {
        <MudNavLink href="/loanProducts" Icon="@Icons.Material.Outlined.Paid">
            @(!IsMini ? "LoanProducts" : "")
        </MudNavLink>
    }

    @if (HasRole("Loan Officer") || HasRole("LoanOfficer") || HasRole("Staff"))
    {
        <MudNavLink href="/Borrower" Icon="@Icons.Material.Outlined.People">
            @(!IsMini ? "Borrowers" : "")
        </MudNavLink>

        <MudNavGroup Title="Application" Icon="@Icons.Material.Filled.Assignment" Expanded="false">
            <MudNavLink href="/LoanApplication" Icon="@Icons.Material.Outlined.Assignment">
                @(!IsMini ? "Application" : "")
            </MudNavLink>
            <MudNavLink href="/Guarantor" Icon="@Icons.Material.Outlined.GppGood">
                @(!IsMini ? "Guarantors" : "")
            </MudNavLink>
            <MudNavLink href="/collateral" Icon="@Icons.Material.Outlined.Money">
                @(!IsMini ? "Collateral" : "")
            </MudNavLink>
            <MudNavLink href="/ProvidedDocuments" Icon="@Icons.Material.Outlined.Description">
                @(!IsMini ? "Documents" : "")
            </MudNavLink>
        </MudNavGroup>
    }

    @if (HasRole("Accountant"))
    {
        <MudNavLink href="/ProcessFeeDeposits" Icon="@Icons.Material.Outlined.Money">
            @(!IsMini ? "Process Fee Deposits" : "")
        </MudNavLink>
    }

    @if (HasRole("Accountant") || HasRole("Loan Officer") || HasRole("LoanOfficer"))
    {
        <MudNavLink href="/Disbursements" Icon="@Icons.Material.Outlined.Money">
            @(!IsMini ? "Disbursement" : "")
        </MudNavLink>
    }

    @if (HasRole("Accountant") || HasRole("Staff"))
    {
        <MudNavLink href="/Payments" Icon="@Icons.Material.Outlined.Money">
            @(!IsMini ? "Payments" : "")
        </MudNavLink>
    }

    @if (HasRole("Accountant"))
    {
        <MudNavLink href="/Penality" Icon="@Icons.Material.Outlined.Money">
            @(!IsMini ? "Penality" : "")
        </MudNavLink>
    }

    @if (HasRole("Loan Officer") || HasRole("LoanOfficer"))
    {
        <MudNavLink href="/waivers" Icon="@Icons.Material.Outlined.GppGood">
            @(!IsMini ? "Waivers" : "")
        </MudNavLink>
    }

    @if (HasRole("Accountant"))
    {
        <MudNavLink Href="/Expenses" Icon="@Icons.Material.Outlined.Receipt">
            @(!IsMini ? "Expenses" : "")
        </MudNavLink>
    }

    @if (HasRole("Accountant") || HasRole("Loan Officer") || HasRole("LoanOfficer") || HasRole("Viewer") || HasRole("Staff"))
    {
        <MudNavLink Href="/Reports" Icon="@Icons.Material.Outlined.BarChart">
            @(!IsMini ? "Reports" : "")
        </MudNavLink>
    }

<MudNavGroup Title="Settings" Icon="@Icons.Material.Filled.Settings" Expanded="false">
    <MudNavLink Href="/Settings" Icon="@Icons.Material.Filled.Settings">
        @(!IsMini ? "Settings" : "")
    </MudNavLink>
    @if (CanViewUsersMenu)
    {
        <MudNavLink Href="/Users" Icon="@Icons.Material.Filled.People">
            @(!IsMini ? "Users" : "")
        </MudNavLink>
    }
    @if (IsDeveloper)
    {
        <MudNavLink Href="/tenants/pending" Icon="@Icons.Material.Filled.DomainVerification">
            @(!IsMini ? "Pending Tenants" : "")
        </MudNavLink>
    }
</MudNavGroup>
</MudNavMenu>
