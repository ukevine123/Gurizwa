<style>
    .mud-nav-link.active {
        color: white !important;
        background-color: transparent !important;
        font-weight: 700;
        border-right: 4px solid #4318FF;
    }
    .mud-nav-link.active .mud-nav-link-icon {
        color: #4318FF !important;
    }
</style>



@code {
    [Parameter] public bool IsMini { get; set; }
}

<MudNavMenu>
    <MudNavLink href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.Dashboard">
        @(!IsMini ? "Dashboard" : "")
    </MudNavLink>
    
    <MudNavLink href="/loans" Icon="@Icons.Material.Outlined.AccountBalanceWallet">
        @(!IsMini ? "My Loans" : "")
    </MudNavLink>

    <MudNavLink href="/employees" Icon="@Icons.Material.Outlined.Group">
        @(!IsMini ? "Employees" : "")
    </MudNavLink>
    <MudNavLink href="/Borrower" Icon="@Icons.Material.Outlined.People">
        @(!IsMini ? "Borrowers" : "")
    </MudNavLink>
    
    <MudNavLink href="/settings" Icon="@Icons.Material.Outlined.Settings">
        @(!IsMini ? "Settings" : "")
    </MudNavLink>
</MudNavMenu>