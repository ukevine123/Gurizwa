@page "/Users"
@using Application.DTO
@using Application.Services.Users
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using Application.Interfaces
@inject IUserContext UserContext
@inject IIdentityService IdentityService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<PageTitle>Users</PageTitle>

@if (UserContext.PrimaryRole != "Tenant" && !IsDeveloper)
{
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
            You do not have permission to access the Users Management page. Only the primary Tenant can view and manage staff.
        </MudAlert>
    </MudContainer>
}
else
{
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-6">
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => _showFilters = !_showFilters)"
                   StartIcon="@Icons.Material.Filled.FilterList" Class="rounded-lg mr-2">Filters</MudButton>
    </MudStack>

    @if (_showFilters)
    {
        <MudPaper Elevation="0" Class="pa-4 mb-6 rounded-xl border" Style="border-color: #e0e0e0;">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_filterName" Label="Name" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Clearable="true" Immediate="true"
                                  AdornmentIcon="@Icons.Material.Filled.Person" Adornment="Adornment.Start"/>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_filterEmail" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Clearable="true" Immediate="true"
                                  AdornmentIcon="@Icons.Material.Filled.Email" Adornment="Adornment.Start"/>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" @bind-Value="_selectedRole" Label="Role" 
                               Variant="Variant.Outlined" Margin="Margin.Dense" AnchorOrigin="Origin.BottomCenter" Clearable="false">
                        <MudSelectItem Value="@("All")">All</MudSelectItem>
                        @if (users != null)
                        {
                            @foreach (var role in users.Select(u => u.Role).Where(r => !string.IsNullOrEmpty(r)).Distinct())
                            {
                                <MudSelectItem Value="@role">@role</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudPaper>
    }

    <MudCard>
        <MudCardHeader>
            <div class="d-flex justify-space-between align-center w-100">
                <div>
                    <MudText Typo="Typo.h5">Users Management</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Primary">View and manage all users</MudText>
                </div>
                <div>
                    <MudButton OnClick="OpenRoleManagementDialog" 
                               Variant="Variant.Outlined" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.Settings"
                               Class="mr-3">
                        Manage Roles
                    </MudButton>
                    <MudButton OnClick="OpenCreateDialog" 
                               Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.Add">
                        Create User
                    </MudButton>
                </div>
            </div>
        </MudCardHeader>

        <MudCardContent>
            @if (isLoading)
            {
                <div class="d-flex flex-column align-center justify-center pa-8">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Typo="Typo.body1" Class="mt-4">Loading users...</MudText>
                </div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.Error">
                    @errorMessage
                </MudAlert>
            }
            else if (users == null || users.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info">
                    No users found. Click "Add New User" to create one.
                </MudAlert>
            }
            else
            {
                <MudTable Items="@users" 
                          Hover="true" 
                          Striped="true" 
                          Dense="true"
                          Breakpoint="Breakpoint.Sm"
                          Filter="new Func<UserDetailDTO, bool>(FilterFunc)">
                    <ToolBarContent>
                        <MudText Typo="Typo.h6">Users</MudText>
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Email</MudTh>
                        <MudTh>Phone</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Created At</MudTh>
                        <MudTh Style="text-align: right;">Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">
                            <div class="d-flex align-center">
                                <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                                    @((string.IsNullOrEmpty(context.FirstName) ? "?" : context.FirstName[0].ToString()) + (string.IsNullOrEmpty(context.LastName) ? "?" : context.LastName[0].ToString()))
                                </MudAvatar>
                                <div>
                                    <MudText Typo="Typo.body2"><strong>@context.FirstName @context.LastName</strong></MudText>
                                </div>
                            </div>
                        </MudTd>
                        <MudTd DataLabel="Email">
                            <MudText Typo="Typo.body2">@context.Email</MudText>
                        </MudTd>
                        <MudTd DataLabel="Phone">
                            <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(context.PhoneNumber) ? "-" : context.PhoneNumber)</MudText>
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Size="Size.Small" 
                                     Variant="Variant.Outlined"
                                     Color="@(context.IsApproved ? Color.Success : Color.Warning)"
                                     Icon="@(context.IsApproved ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Pending)">
                                @(context.IsApproved ? "Approved" : "Pending")
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Created At">
                            <MudText Typo="Typo.body2">@context.CreatedAt.ToString("yyyy-MM-dd")</MudText>
                        </MudTd>
                        <MudTd DataLabel="Actions" Style="text-align: right;">
                            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small">
                                @if (!context.IsApproved)
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.ThumbUp" 
                                                   Color="Color.Success" 
                                                   Size="Size.Small"
                                                   OnClick="@(() => ApproveUser(context.Id))"
                                                   Title="Approve User" />
                                }
                                <MudIconButton Icon="@Icons.Material.Filled.Visibility" 
                                               Color="Color.Info" 
                                               Size="Size.Small"
                                               Href="@($"/Users/{context.Id}")"
                                               Title="View Details" />
                                <AuthorizeView Roles="Tenant" Context="authState">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                                   Color="Color.Primary" 
                                                   Size="Size.Small"
                                                   OnClick="@(() => OpenEditDialog(context.Id))"
                                                   Title="Edit User" />
                                </AuthorizeView>
                            </MudButtonGroup>
                        </MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                </MudTable>

                <div class="mt-4">
                    <MudText Typo="Typo.caption" Color="Color.Primary">
                        Total Users: @users.Count
                    </MudText>
                </div>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>
}

@code {
    private List<UserDetailDTO>? users;
    private bool isLoading = true;
    private string? errorMessage;
    private bool _showFilters = false;
    private string _filterName = "";
    private string _filterEmail = "";
    private string _selectedRole = "All";

    private bool IsDeveloper => 
        string.Equals(UserContext.Email, "guriza291@gmail.com", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task OpenRoleManagementDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<RoleManagementDialog>("Manage Business Roles", options);
        await dialog.Result;
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateSubUserDialog>("Add New User", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadUsers();
        }
    }

    private async Task OpenEditDialog(int userId)
    {
        var parameters = new DialogParameters<EditUserDialog> { { x => x.Id, userId } };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<EditUserDialog>("Edit User", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadUsers();
        }
    }

    private async Task ApproveUser(int userId)
    {
        try
        {
            await IdentityService.ApproveUserAsync(userId);
            // Optionally show a success snackbar here
            await LoadUsers();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error approving user: {ex.Message}";
        }
    }

    private async Task LoadUsers()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            Console.WriteLine("[Users] Loading users list...");

            if (IsDeveloper)
            {
                users = await IdentityService.GetAllUsers();
            }
            else if (UserContext.PersonId.HasValue)
            {
                users = await IdentityService.GetSubUsers(UserContext.PersonId.Value);
            }
            else 
            {
                users = new List<UserDetailDTO>();
            }

            Console.WriteLine($"[Users] Loaded {users?.Count ?? 0} users");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading users: {ex.Message}";
            Console.WriteLine($"[Users] Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool FilterFunc(UserDetailDTO user)
    {
        if (!string.IsNullOrWhiteSpace(_filterName) && 
            !((user.FirstName?.Contains(_filterName, StringComparison.OrdinalIgnoreCase) ?? false) || 
              (user.LastName?.Contains(_filterName, StringComparison.OrdinalIgnoreCase) ?? false)))
            return false;

        if (!string.IsNullOrWhiteSpace(_filterEmail) && 
            !(user.Email?.Contains(_filterEmail, StringComparison.OrdinalIgnoreCase) ?? false))
            return false;
            
        if (_selectedRole != "All" && 
            user.Role != _selectedRole)
            return false;

        return true;
    }
}
