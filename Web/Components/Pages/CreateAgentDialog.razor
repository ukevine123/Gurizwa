@using Application.DTO
@using Application.Interfaces
@inject IIdentity IdentityService
@inject IUserContext UserContext
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-2" />
            Add New Agent
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Style="color: #A3AED0;">
            This agent will be created under your account and will only see their own data.
        </MudText>

        <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudTextField @bind-Value="_model.FirstName"
                                  Label="First Name"
                                  Variant="Variant.Outlined"
                                  For="@(() => _model.FirstName)"
                                  Required="true" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField @bind-Value="_model.LastName"
                                  Label="Last Name"
                                  Variant="Variant.Outlined"
                                  For="@(() => _model.LastName)"
                                  Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email Address"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  For="@(() => _model.Email)"
                                  Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.PhoneNumber"
                                  Label="Phone Number"
                                  Variant="Variant.Outlined"
                                  For="@(() => _model.PhoneNumber)"
                                  Required="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Password"
                                  Label="Password"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Password"
                                  For="@(() => _model.Password)"
                                  Required="true"
                                  HelperText="Minimum 8 characters" />
                </MudItem>
            </MudGrid>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mt-3" Dense="true">@_errorMessage</MudAlert>
            }
        </EditForm>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Color="Color.Default">Cancel</MudButton>
        <MudButton OnClick="HandleSubmit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="_isSaving"
                   StartIcon="@Icons.Material.Filled.PersonAdd">
            @(_isSaving ? "Creating..." : "Create Agent")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private CreateSubUserDTO _model = new();
    private bool _isSaving = false;
    private string _errorMessage = string.Empty;

    private async Task HandleSubmit()
    {
        if (UserContext.Id is null) return;

        _isSaving = true;
        _errorMessage = string.Empty;

        try
        {
            await IdentityService.CreateSubUserAsync(_model, UserContext.Id.Value);
            Snackbar.Add($"Agent '{_model.FirstName} {_model.LastName}' created successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
