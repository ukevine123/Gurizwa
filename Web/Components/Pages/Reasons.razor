@* </MudDataGrid> *@ 

@* @code {
    // --- ORIGINAL LOGIC PRESERVED ---
    private List<Reason> _reason = new();
    private HashSet<Reason> _selectedItems = new(); // Added to support selection UI
    private readonly DialogOptions _closeButton = new() { CloseButton = true };

    private async Task LoadReason()
    {
        _reason = await ReasonService.GetAllReasonsAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadReason();
    }

    private async Task GoToCreateReason()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateReason>("Add Reason", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100);
            await LoadReason();
        }
    }
} *@ 
