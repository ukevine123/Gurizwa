@* <div class="d-flex align-center justify-space-between mb-6 mt-4 px-4"> *@
    @* <MudText Typo="Typo.h5" Style="font-weight: 800; color: #1B2559;">Reason Management</MudText> *@
@* </div> *@

@* --- ACTION BAR: Clean spacing and alignment --- *@
