@using Domain.Entities
@using MudBlazor
@inject IJSRuntime JSRuntime
@inject Application.Interfaces.IQRCodeService QRCodeService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <div class="printable-document pa-4" style="color: #1B2559; background: #fff;">
            @* --- HEADER --- *@
            <div class="header-banner">
                <div class="d-flex align-center gap-3">
                    <img src="Images/guriza_icon.png" alt="Logo" style="height: 46px;" />
                    <div>
                        <h2 style="color: #1B2559; font-weight: 900; margin: 0; font-size: 1.6rem;">Guriza</h2>
                        <div style="font-size: 0.8rem; color: #64748b; font-weight: 600; letter-spacing: 0.5px;">OFFICIAL PAYMENT RECEIPT / STATEMENT</div>
                    </div>
                </div>
                <div style="text-align: right;">
                    <div style="font-weight: 700; color: #1B2559;">App Code: @AppCode</div>
                    <div style="font-size: 0.85rem; color: #64748b;">Receipt Date: @(Payment?.PaymentDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))</div>
                    <div style="font-size: 0.85rem; color: #64748b;">Transaction #: @(Payment?.Id.ToString("D6") ?? "000000")</div>
                </div>
            </div>

            @* --- SUMMARY BOX --- *@
            <div class="summary-box">
                <table style="width: 100%;">
                    <tr>
                        <td style="width: 50%;">
                            <div style="margin-bottom: 8px;">
                                <span style="font-weight: 700;">Borrower / Business:</span> @BorrowerName
                            </div>
                            <div style="margin-bottom: 8px;">
                                <span style="font-weight: 700;">Approved Principal:</span> @(Payment?.Disbursement?.PrincipalOffered.ToString("N2") ?? "0.00")
                            </div>
                            <div>
                                <span style="font-weight: 700;">Total Installments:</span> @(Payment?.Disbursement?.TotalInstallments ?? 0) Payment(s)
                            </div>
                        </td>
                        <td style="width: 50%; text-align: right;">
                            <div style="margin-bottom: 8px;">
                                <span style="font-weight: 700;">Payment Frequency:</span> @(Payment?.Disbursement?.PaymentModality?.Mode ?? "Monthly")
                            </div>
                            <div style="margin-bottom: 8px;">
                                <span style="font-weight: 700;">Interest Rate:</span> @(Payment?.Disbursement?.InterestRate ?? 0)%
                            </div>
                            <div>
                                <span style="font-weight: 700;">Total Repayable:</span> @(Payment?.Disbursement?.Amount.ToString("N2") ?? "0.00")
                            </div>
                        </td>
                    </tr>
                </table>
            </div>

            @* --- PAYMENT SUMMARY --- *@
            <div style="margin-top: 30px; margin-bottom: 30px; background: #e0f2fe; padding: 20px; border-radius: 8px; border: 1px solid #bae6fd; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <span style="font-size: 0.85rem; color: #0284c7; font-weight: 700; text-transform: uppercase;">Amount Paid This Transaction</span>
                    <div style="font-size: 1.8rem; font-weight: 800; color: #0369a1;">@((Payment?.Amount ?? 0).ToString("N2"))</div>
                </div>
                <div style="text-align: right;">
                    <span style="font-size: 0.85rem; color: #0284c7; font-weight: 700; text-transform: uppercase;">Overall Outstanding Balance</span>
                    <div style="font-size: 1.8rem; font-weight: 800; color: #dc2626;">@RemainingAmount.ToString("N2")</div>
                </div>
            </div>

            <hr style="border: 0; border-top: 2px dashed #e2e8f0; margin-bottom: 24px;" />

            @* --- AMORTIZATION TABLE (Remaining Only) --- *@
            <h4 style="margin-top: 10px; font-weight: 700; color: #1B2559;">Remaining Installments Schedule</h4>
            <table class="schedule-table">
                <thead>
                    <tr>
                        <th style="width: 5%;">No.</th>
                        <th style="width: 15%;">Due Date</th>
                        <th style="text-align: right; width: 15%;">Principal Part</th>
                        <th style="text-align: right; width: 15%;">Interest Part</th>
                        <th style="text-align: right; width: 15%;">Amount</th>
                        <th style="text-align: right; width: 15%;">Remaining Balance</th>
                        <th style="text-align: center; width: 20%;">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Rows.Where(r => r.Status != "PAID"))
                    {
                        <tr>
                            <td>#@row.No</td>
                            <td>@row.DueDate.ToString("yyyy-MM-dd")</td>
                            <td style="text-align: right;">@row.PrincipalPart.ToString("N2")</td>
                            <td style="text-align: right;">@row.InterestPart.ToString("N2")</td>
                            <td style="text-align: right; font-weight: 700;">@row.TotalAmount.ToString("N2")</td>
                            <td style="text-align: right; font-weight: 700; color: #dc2626;">@row.RemainingBalance.ToString("N2")</td>
                            <td style="text-align: center; font-weight: 700; color: @(row.Status == "PAID" ? "#16a34a" : (row.Status == "PARTIAL" ? "#ca8a04" : "#eab308"));">
                                @row.Status
                            </td>
                        </tr>
                    }
                    @if (!Rows.Any(r => r.Status != "PAID"))
                    {
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 20px; font-weight: 700; color: #16a34a;">
                                Loan is fully paid! No remaining installments.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* --- SIGNATURE ACKNOWLEDGMENT --- *@
            <div class="signature-section">
                <div class="signature-box">
                    Prepared By (Officer Signature)
                </div>
                <div class="signature-box">
                    Customer Acknowledgment Signature
                </div>
            </div>

            @* --- QR CODE VERIFICATION --- *@
            <div style="text-align: left; margin-top: 30px;">
                <p style="margin-bottom: 5px; font-size: 12px; color: #64748B;">Scan to Verify</p>
                @if (!string.IsNullOrEmpty(_qrCodeBase64))
                {
                    <img src="data:image/png;base64,@_qrCodeBase64" width="80" height="80" style="border-radius: 5px; border: 1px solid #e2e8f0; padding: 4px;" />
                }
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <div class="no-print pa-3 d-flex justify-end w-100">
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Print" 
                       OnClick="TriggerDownloadAndPrint"
                       Style="font-weight:700; border-radius:8px;">
                Download & Print Receipt
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public Payment? Payment { get; set; }
    [Parameter] public decimal TotalPaidPool { get; set; }

    public class SchedulePrintRow
    {
        public int No { get; set; }
        public DateTime DueDate { get; set; }
        public decimal PrincipalPart { get; set; }
        public decimal InterestPart { get; set; }
        public decimal TotalAmount { get; set; }
        public decimal RemainingBalance { get; set; }
        public string Status { get; set; } = "PENDING";
    }

    private List<SchedulePrintRow> Rows = new();

    private string BorrowerName => Payment?.Disbursement?.LoanApplication?.Borrower != null
        ? (!string.IsNullOrWhiteSpace(Payment.Disbursement.LoanApplication.Borrower.CompanyName)
            ? Payment.Disbursement.LoanApplication.Borrower.CompanyName
            : $"{Payment.Disbursement.LoanApplication.Borrower.FirstName} {Payment.Disbursement.LoanApplication.Borrower.LastName}".Trim())
        : (Payment?.Disbursement?.LoanApplication?.Person != null
            ? (!string.IsNullOrWhiteSpace(Payment.Disbursement.LoanApplication.Person.CompanyName)
                ? Payment.Disbursement.LoanApplication.Person.CompanyName
                : $"{Payment.Disbursement.LoanApplication.Person.FirstName} {Payment.Disbursement.LoanApplication.Person.LastName}".Trim())
            : "Valued Customer");

    private string AppCode => Payment?.Disbursement?.LoanApplication?.ApplicationCode ?? $"#APP-{Payment?.Disbursement?.LoanApplicationId}";

    private decimal RemainingAmount => (Payment?.Disbursement != null) ? (Payment.Disbursement.Amount - TotalPaidPool) : 0;

    private string _qrCodeBase64 = "";

    protected override void OnInitialized()
    {
        if (Payment?.Disbursement == null) return;

        if (Payment.Disbursement.LoanApplication != null)
        {
            _qrCodeBase64 = QRCodeService.GenerateQRCodeBase64($"https://app.guriza.com/verify?loan={Payment.Disbursement.LoanApplication.ApplicationCode}");
        }

        var disbursement = Payment.Disbursement;
        int n = disbursement.TotalInstallments > 0 ? disbursement.TotalInstallments : 1;
        decimal principalPart = disbursement.PrincipalOffered / n;
        decimal totalInterest = disbursement.Amount - disbursement.PrincipalOffered;
        decimal interestPart = totalInterest > 0 ? (totalInterest / n) : 0;
        decimal totalInstallmentAmount = disbursement.Amount / n;

        string mode = disbursement.PaymentModality?.Mode?.ToLower() ?? "monthly";
        DateTime baseDate = disbursement.StartDate;

        decimal currentPaidPool = TotalPaidPool;
        decimal remainingBal = disbursement.Amount;

        for (int i = 1; i <= n; i++)
        {
            DateTime dueDate = mode switch
            {
                "daily" => baseDate.AddDays(i),
                "weekly" => baseDate.AddDays(i * 7),
                "monthly" => baseDate.AddMonths(i),
                "yearly" => baseDate.AddYears(i),
                _ => baseDate.AddMonths(i)
            };

            decimal amountPaidForInstallment = 0;
            if (currentPaidPool >= totalInstallmentAmount)
            {
                amountPaidForInstallment = totalInstallmentAmount;
                currentPaidPool -= totalInstallmentAmount;
            }
            else if (currentPaidPool > 0)
            {
                amountPaidForInstallment = currentPaidPool;
                currentPaidPool = 0;
            }

            remainingBal -= amountPaidForInstallment;
            
            string status = amountPaidForInstallment >= totalInstallmentAmount ? "PAID" :
                           amountPaidForInstallment > 0 ? "PARTIAL" : "PENDING";

            Rows.Add(new SchedulePrintRow
            {
                No = i,
                DueDate = dueDate,
                PrincipalPart = principalPart,
                InterestPart = interestPart,
                TotalAmount = totalInstallmentAmount,
                RemainingBalance = remainingBal > 0 ? remainingBal : 0,
                Status = status
            });
        }
    }

    private async Task TriggerDownloadAndPrint()
    {
        await JSRuntime.InvokeVoidAsync("eval", @"
            (function() {
                var content = document.querySelector('.printable-document');
                if (!content) return;

                var htmlString = `
                    <!DOCTYPE html>
                    <html>
                    <head>
                        <meta charset='utf-8' />
                        <title>Payment Receipt</title>
                        <style>
                            * { box-sizing: border-box; margin: 0; padding: 0; }
                            body {
                                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                                color: #1B2559;
                                background: #fff;
                                padding: 24px;
                            }
                            .header-banner {
                                border-bottom: 2px solid #1B2559;
                                padding-bottom: 16px;
                                margin-bottom: 20px;
                                display: flex;
                                justify-content: space-between;
                                align-items: center;
                            }
                            .d-flex { display: flex; }
                            .align-center { align-items: center; }
                            .gap-3 { gap: 12px; }
                            .justify-space-between { justify-content: space-between; }
                            .summary-box {
                                background: #f8fafc;
                                border: 1px solid #e2e8f0;
                                border-radius: 8px;
                                padding: 16px;
                                margin-bottom: 20px;
                            }
                            .summary-box table { width: 100%; border-collapse: collapse; }
                            .summary-box td { padding: 4px 0; border: none; }
                            .schedule-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-top: 15px;
                            }
                            .schedule-table th, .schedule-table td {
                                border: 1px solid #cbd5e1;
                                padding: 8px 12px;
                                font-size: 0.85rem;
                            }
                            .schedule-table th {
                                background-color: #f1f5f9;
                                font-weight: 700;
                                text-align: left;
                            }
                            h4 { color: #1B2559; font-weight: 700; margin: 16px 0 8px 0; }
                            .signature-section {
                                margin-top: 40px;
                                display: flex;
                                justify-content: space-between;
                            }
                            .signature-box {
                                width: 45%;
                                border-top: 1px dashed #64748b;
                                padding-top: 8px;
                                text-align: center;
                                font-size: 0.85rem;
                            }
                            img { max-height: 46px; width: auto; object-fit: contain; }
                            @media print {
                                body { padding: 0; }
                            }
                        </style>
                    </head>
                    <body>` + content.innerHTML + `</body>
                    </html>
                `;

                var opt = {
                  margin:       10,
                  filename:     'Payment_Receipt_' + Date.now() + '.pdf',
                  image:        { type: 'jpeg', quality: 0.98 },
                  html2canvas:  { scale: 2, useCORS: true },
                  jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };
                
                if (typeof html2pdf !== 'undefined') {
                    html2pdf().set(opt).from(htmlString).save();
                }

                var printWindow = window.open('', '_blank', 'width=900,height=700');
                if (printWindow) {
                    printWindow.document.write(htmlString);
                    printWindow.document.close();
                    printWindow.focus();
                    printWindow.onload = function() {
                        printWindow.print();
                        printWindow.close();
                    };
                }
            })();
        ");
    }
}
