@using Application.Services.Borrowers
@using Application.Services.BorrowerTypes

@using Domain.Entities
@using Domain.ValueObjects
@using Application.DTO
@using Application.Interfaces
@using MudBlazor
@inject IBorrowerService BorrowerService
@inject IBorrowerTypeService BorrowerTypeService
@inject ISnackbar Snackbar

@rendermode InteractiveServer

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2"/> Edit Account Borrower
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_borrowerType == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <EditForm Model="@_editModel" OnValidSubmit="OnValidSubmit" FormName="EditAccountForm">
                <DataAnnotationsValidator />
                <MudStack Spacing="3">
                    
                    <MudSelect T="int"
                               Label="Borrower Type"
                               Value="_editModel.BorrowerTypeId"
                               ValueChanged="OnBorrowerTypeChanged"
                               Variant="Variant.Outlined"
                               For="@(() => _editModel.BorrowerTypeId)">
                        @if (_borrowerType != null)
                        {
                            foreach (var type in _borrowerType)
                            {
                                <MudSelectItem T="int" Value="@type.Id">@type.Type</MudSelectItem>
                            }
                        }
                    </MudSelect>

                    @if (!isOrganization)
                    {
                        <MudTextField Label="First Name" @bind-Value="_editModel.FirstName" 
                                      Variant="Variant.Outlined" For="@(() => _editModel.FirstName)" />

                        <MudTextField Label="Last Name" @bind-Value="_editModel.LastName" 
                                      Variant="Variant.Outlined" For="@(() => _editModel.LastName)" />

                        <MudSelect T="Sex?" Label="Sex" @bind-Value="_editModel.sex" 
                                   Variant="Variant.Outlined" For="@(() => _editModel.sex)">
                            <MudSelectItem T="Sex?" Disabled="true">-- Select Sex --</MudSelectItem>
                            @foreach (Sex item in Enum.GetValues(typeof(Sex)))
                            {
                                <MudSelectItem T="Sex?" Value="item">@item.ToString()</MudSelectItem>
                            }
                        </MudSelect>

                        <MudDatePicker Label="Date Of Birth" @bind-Value="_editModel.DateOfBirth" 
                                       Variant="Variant.Outlined" For="@(() => _editModel.DateOfBirth)" />

                        <MudSelect T="Maritalstatus?" Label="Marital Status" @bind-Value="_editModel.Maritalstatus" 
                                   Variant="Variant.Outlined" For="@(() => _editModel.Maritalstatus)">
                            <MudSelectItem T="Maritalstatus?" Disabled="true">-- Select Marital Status --</MudSelectItem>
                            @foreach (Maritalstatus item in Enum.GetValues(typeof(Maritalstatus)))
                            {
                                <MudSelectItem T="Maritalstatus?" Value="item">@item.ToString()</MudSelectItem>
                            }
                        </MudSelect>

                        @if (_editModel.Maritalstatus == Maritalstatus.Married)
                        {
                            <MudTextField Label="Spouse ID Number" @bind-Value="_editModel.SpouceIdNumber" 
                                          Variant="Variant.Outlined" For="@(() => _editModel.SpouceIdNumber)" />

                            <MudTextField Label="Spouse Name" @bind-Value="_editModel.SpouceName" 
                                          Variant="Variant.Outlined" For="@(() => _editModel.SpouceName)" />
                        }
                    }
                    else
                    {
                        <MudTextField Label="Company Name" @bind-Value="_editModel.CompanyName" 
                                      Variant="Variant.Outlined" For="@(() => _editModel.CompanyName)" />

                        <MudTextField Label="TIN" @bind-Value="_editModel.TIN" 
                                      Variant="Variant.Outlined" For="@(() => _editModel.TIN)" />

                        <MudTextField Label="Contact Person Name" @bind-Value="_editModel.ContactPersonName" 
                                      Variant="Variant.Outlined" For="@(() => _editModel.ContactPersonName)" />

                        <MudTextField Label="Contact Person Phone" @bind-Value="_editModel.ContactPersonPhone" 
                                      Variant="Variant.Outlined" For="@(() => _editModel.ContactPersonPhone)" />
                    }

                </MudStack>
            </EditForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="OnValidSubmit">Save Changes</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public int Id { get; set; } // The ID of the account to edit

    private UpdateBorrowerDTO _editModel = new();
    private List<BorrowerType> _borrowerType;
    private bool isOrganization = false;

    private void OnBorrowerTypeChanged(int typeId)
    {
        _editModel.BorrowerTypeId = typeId;
        var type = _borrowerType?.FirstOrDefault(t => t.Id == typeId);
        if (type != null && type.Type.Equals("Organization", StringComparison.OrdinalIgnoreCase))
        {
            isOrganization = true;
        }
        else
        {
            isOrganization = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // 1. Load Categories/Types for the dropdown
        _borrowerType = await BorrowerTypeService.GetAllBorrowerTypeAsync();

        // 2. Load the existing Account data
        var _borrower = await BorrowerService.GetBorrowerById(Id);
        if (_borrower != null)
        {
            // Map Entity to DTO
            _editModel = new UpdateBorrowerDTO
            {
                FirstName = _borrower.FirstName,
                LastName = _borrower.LastName,
                BorrowerTypeId = _borrower.BorrowerTypeId,
                sex = _borrower.sex ?? Sex.Male,
                DateOfBirth = _borrower.DateOfBirth ?? DateTime.Now,
                Maritalstatus = _borrower.Maritalstatus ?? Maritalstatus.Single,
                SpouceIdNumber = _borrower.SpouceIdNumber,
                SpouceName = _borrower.SpouceName,
                CompanyName = _borrower.CompanyName,
                TIN = _borrower.TIN,
                ContactPersonName = _borrower.ContactPersonName,
                ContactPersonPhone = _borrower.ContactPersonPhone
            };

            var type = _borrowerType?.FirstOrDefault(t => t.Id == _editModel.BorrowerTypeId);
            if (type != null && type.Type.Equals("Organization", StringComparison.OrdinalIgnoreCase))
            {
                isOrganization = true;
            }
        }
    }

    private async Task OnValidSubmit()
    {
        try
        {
            await BorrowerService.UpdateBorrower(Id, _editModel);
            Snackbar.Add("Borrower updated successfully!", Severity.Info);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Update failed: {ex.Message}", Severity.Error);
        }
    }
    private void Cancel() => MudDialog.Cancel();
}
