@using  Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces
@using Application.Services.LoanApplications
@using Application.Services.Borrowers
@using Application.Services.LoanProducts
@using Application.Services.PaymentModalities
@using Application.Services.ProvidedDocuments
@using Application.Services.Requirements
@using Domain.ValueObjects

@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization
@* @attribute [Authorize] *@
@inject NavigationManager Navigation
@inject ILoanApplicationService LoanApplicationService
@inject IProvidedDocumentService ProvidedDocumentService
@inject IBorrowerService BorrowerService
@inject IPaymentModalityService PaymentModalityService
@inject ILoanProductService LoanProductService
@inject IRequirementService RequirementService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudDialog Style="overflow:hidden;">

    <DialogContent>

        <!-- ══════════ HEADER BANNER ══════════ -->
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #4318FF );
                         padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                <MudIcon Icon="@Icons.Material.Filled.AccountBalance"
                         Style="color:white; font-size:1.6rem;" />

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700; line-height:1.2;">
                        Create Loan Application
                    </MudText>

                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new Application
                    </MudText>
                </MudStack>

            </MudStack>
        </MudPaper>


        <!-- ══════════ FORM ══════════ -->
        <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreateLoanApplicationForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

           

                <MudGrid Spacing="1" Class="align-items-center">

                    <MudItem xs="6">

                        <MudItem xs="12">
    <MudTextField T="string"
                  Label="Identification Number"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Immediate="true"
                  ValueChanged="@OnIdentificationChange"
                  Placeholder="Type ID Number to search..."
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  AdornmentColor="Color.Primary" />
</MudItem>

        @if (SelectedBorrower != null)
        {
            <MudItem xs="12">
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-n2">
                    <MudText Typo="Typo.body2"><b>Borrower:</b> @SelectedBorrower.FirstName @SelectedBorrower.LastName</MudText>
                    <MudText Typo="Typo.caption"><b>Contact:</b> @SelectedBorrower.PhoneNumber | @SelectedBorrower.Email</MudText>
                    <MudText Typo="Typo.caption" Class="d-block"><b>Location:</b> @SelectedBorrower.District, @SelectedBorrower.Sector</MudText>
                </MudAlert>
            </MudItem>
        }
        else if (!string.IsNullOrEmpty(SearchID))
        {
            <MudItem xs="12">
                <MudText Typo="Typo.caption" Color="Color.Error">No borrower found with this ID.</MudText>
            </MudItem>
        }
    </MudItem>

<MudSelect T="int"
           Label="Product"
           Value="Model.LoanProductId"
           ValueChanged="@(i => { Model.LoanProductId = i; StateHasChanged(); })"
           Variant="Variant.Outlined"
           Dense="true"
           Placeholder="--Select Product--">
    
    <MudSelectItem T="int" Value="0">-- Select Product --</MudSelectItem>

    @if (_loanProducts != null)
    {
        foreach (var product in _loanProducts)
        {
            @* Ensure Value matches the T type (int) *@
            <MudSelectItem T="int" Value="@product.Id">@product.ProductName</MudSelectItem>
        }
    }
</MudSelect>

     <MudItem xs="6">
                    <MudSelect T="int"
            Label="PaymentModality"
            Placeholder="--Select PaymentModality--"
            @bind-Value="Model.PaymentModalityId"
            Variant="Variant.Outlined"
            Dense="true"
            Margin="Margin.Dense"
            AdornmentIcon="@Icons.Material.Filled.Category"
            AdornmentColor="Color.Primary">

            <MudSelectItem T="int" Value="0">--Select PaymentModality--</MudSelectItem>

    
        @if (_paymentModalities != null)
        {
            @foreach (var item in _paymentModalities)
            {
                <MudSelectItem T="int" Value="@item.Id">@item.Mode</MudSelectItem>
            }
        }
    </MudSelect>
 </MudItem>


            <MudItem xs="6">
                <MudSelect T="int"
                Label="Document"
                Placeholder="--Select Document--"
                @bind-Value="Model.ProvidedDocumentId"
                Variant="Variant.Outlined"
                Dense="true"
                Margin="Margin.Dense"
                AdornmentIcon="@Icons.Material.Filled.Category"
                AdornmentColor="Color.Primary">

                <MudSelectItem T="int" Value="0">--Select Document--</MudSelectItem>

        
            @if (_documents != null)
            {
                @foreach (var item in _documents)
                {
                    <MudSelectItem T="int" Value="@item.Id">@item.DocumentName</MudSelectItem>
                }
            }
        </MudSelect>
     </MudItem>

                <MudItem  xs="6">
                <MudTextField Label="Amount Requested"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.AmountRequested"
                              For="@(() => Model.AmountRequested)"
                              InputType="InputType.Number" />
                </MudItem>
                 <MudItem  xs="6"> 
                      <MudDatePicker Label="Date of Application"
                       @bind-Value="Model.DateofApplication"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Adornment="Adornment.Start" 
                        AdornmentColor="Color.Primary" />
                </MudItem>
                 <MudItem  xs="6"> 
                      <MudDatePicker Label="Preferred Date"
                       @bind-Value="Model.PreferredDate"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Adornment="Adornment.Start" 
                        AdornmentColor="Color.Primary" />
                </MudItem>

                <MudItem xs="6">
    <MudSelect T="LoanStatus" 
               Label="Status" 
               Variant="Variant.Outlined" 
               Margin="Margin.Dense"
               @bind-Value="Model.Status"
               AnchorOrigin="Origin.BottomCenter">
        @foreach (LoanStatus item in Enum.GetValues(typeof(LoanStatus)))
        {
            <MudSelectItem Value="@item">@item.ToString()</MudSelectItem>
        }
    </MudSelect>
</MudItem>
                
                @* <MudItem  xs="6"> 
                <MudTextField Label="ApprovedBy"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.ApprovedBy"
                              For="@(() => Model.ApprovedBy)"
                               />
                </MudItem> *@
                <MudItem  xs="6">
                   
                </MudItem>
                <MudItem xs="12">
                <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Small"
                        FullWidth="true"
                        ButtonType="ButtonType.Submit"
                        Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px;">
                    Add Application
                </MudButton>
                </MudItem>

            </MudGrid>

        </EditForm>
    </DialogContent>
</MudDialog>

@code{
    [CascadingParameter]
    
    private IMudDialogInstance MudDialog { get; set; }
    private bool _fullWidth;
    private bool _fitContent;
    [SupplyParameterFromForm(Name = "CreateLoanApplicationForm")]
    private CreateApplicationDTO Model {get;set;} = new ();
    private string ErrorMessage{get;set;}

        private async Task onValidSubmit()
    {
        try
        {
            await LoanApplicationService.CreateLoanApplication(Model);
            Snackbar.Add("Loan Application successfully!", Severity.Info);
            MudDialog.Close(DialogResult.Ok(Model));
        }
        catch(Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        if (Model.LoanProductId <= 0)
        {
            Snackbar.Add("Please select a valid Loan Product", Severity.Warning);
            return;
        }
    }


    private List<PaymentModality> _paymentModalities = new List<PaymentModality>();
    private List<Borrower> _borrowers = new List<Borrower>();
    private List<LoanProduct> _loanProducts = new List<LoanProduct>();
    private List<ProvidedDocument> _documents = new List<ProvidedDocument>();

    protected override async Task OnInitializedAsync()
    {
        // 1. Load Borrowers
        try 
        {
            var borrowerData = await BorrowerService.GetAllBorrowersAsync();
            if (borrowerData != null)
            {
                _borrowers = borrowerData.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading Borrowers: {ex.Message}", Severity.Error);
        }
// load requirement


try 
    {
        // Use the injected service instance here
        var reqData = await RequirementService.GetAllRequirementsAsync();
        if (reqData != null)
        {
            _allRequirements = reqData.ToList();
        }
    }
    catch (Exception ex)
    {
        Snackbar.Add($"Error loading Requirements: {ex.Message}", Severity.Error);
    }

    StateHasChanged(); // Refresh UI once all data is loaded

        // 2. Load Payment Modalities
        try 
        {
            var paymentData = await PaymentModalityService.GetAllPaymentModalitysAsync();
            if (paymentData != null)
            {
                _paymentModalities = paymentData.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading Payment Modalities", Severity.Error);
        }

        // 3. Load Loan Document (Optional based on your variables)
        try 
        {

            var document = await ProvidedDocumentService.GetAllProvidedDocumentAsync();
            if (document != null)
            {
                _documents = document.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading Document Modalities", Severity.Error);
        }
        StateHasChanged();


        try 
        {
            var productData = await LoanProductService.GetAllLoanProductsAsync();
            if (productData != null)
            {
                _loanProducts = productData.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading Loan Products", Severity.Error);
        }
    }

    // ... existing variables ...
    private Borrower SelectedBorrower { get; set; }
    private string SearchID { get; set; }

    private void OnIdentificationChange(string value)
    {
        SearchID = value;

        if (string.IsNullOrWhiteSpace(value))
        {
            SelectedBorrower = null;
            Model.BorrowerId = 0;
            return;
        }

        // Search in the pre-loaded list (Case-insensitive)
      SelectedBorrower = _borrowers.FirstOrDefault(b => 
    b.IdentificationNumber != null && 
    b.IdentificationNumber.AsSpan().Trim().Equals(value.AsSpan().Trim(), StringComparison.OrdinalIgnoreCase));

        if (SelectedBorrower != null)
        {
            // Auto-bind the ID to your Model so the form submission still works
            Model.BorrowerId = SelectedBorrower.Id;
            Snackbar.Add($"Found: {SelectedBorrower.FirstName}", Severity.Info);
        }
        else
        {
            Model.BorrowerId = 0;
        }
    }

    //// apload document 



    ///@code {
    // List of all requirements fetched from your database
    private List<Requirement> _allRequirements = new(); 
    
    // Filtered list to show in the UI
    private List<Requirement> _filteredRequirements => _allRequirements
        .Where(r => r.LoanProductId == Model.LoanProductId)
        .ToList();

    private async Task UploadDocument(IBrowserFile file, Requirement req)
    {
        if (file == null) return;

        // Convert the file to byte array for ProvidedDocument
        using var memoryStream = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(memoryStream);

        var providedDoc = new ProvidedDocument
        {
            DocumentName = req.RequiredDocument?.DocumentName ?? "Unknown",
            DocumentFile = memoryStream.ToArray(),
            CreatedAt = DateTime.Now,
            CreatedBy = "CurrentUser" // Replace with actual user logic
        };

        // TODO: Call your service to save 'providedDoc' to the database
        Snackbar.Add($"{providedDoc.DocumentName} uploaded successfully!", Severity.Success);
    }
}

    
}