            @* <MudSelect T="Borrower" Label="Borrower" Dense="true" Margin="Margin.Dense" Outlined="true" Style="width: 150px; background: white;">
    <MudSelectItem T="Borrower" Value="null">All Borrowers</MudSelectItem>
