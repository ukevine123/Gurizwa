@page "/Borrower"
@page "/Borrowers"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.Borrowers
@using Domain.ValueObjects

@inject IBorrowerService BorrowerService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Borrowers</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="_searchString" Placeholder="Search borrowers..." IconSize="Size.Medium" Class="mt-0" Clearable="true"></MudTextField>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudSelect T="string" @bind-Value="_selectedBorrowerType" Label="Borrower Type" AnchorOrigin="Origin.BottomCenter" Clearable="false">
                <MudSelectItem Value="@("All")">All</MudSelectItem>
                @if (_borrowerTypeCounts != null)
                {
                    @foreach (var bt in _borrowerTypeCounts.Where(c => c.BorrowerType != null).Select(c => c.BorrowerType).Distinct())
                    {
                        <MudSelectItem Value="@bt">@bt</MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-center justify-end gap-4">
            @if (_selectedItems.Any())
            {
                <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" OnClick="@(() => OpenDetailDialog(_selectedItems.First().Id))" />
                <AuthorizeView Roles="Tenant">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"  OnClick="@(() => OpenEditDialog(_selectedItems.First().Id))" />
                </AuthorizeView>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@ConfirmDeleteBorrower" />
                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
            }
        </MudItem>
    </MudGrid>

    @* 3. BORROWER TYPE SUMMARY CARDS *@
    <MudGrid Class="mb-4" Spacing="2">
        @if (_borrowerTypeCounts != null && _borrowerTypeCounts.Any())
        {
            @foreach (var typeCount in _borrowerTypeCounts)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Class="pa-4">
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@typeCount.BorrowerType</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">@typeCount.Count</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Info">Borrowers</MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        }
    </MudGrid>

    @* 4. THE DATAGRID *@
    <MudDataGrid T="Borrower" Items="@FilteredBorrowers" MultiSelection="true" @bind-SelectedItems="_selectedItems"
                 Hover="true" Elevation="0" Class="rounded-xl border-none" Filterable="true">

                  <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Borrower</MudText>
            <MudSpacer />

            <MudMenu Label="Add Borrowe"
                     Variant="Variant.Filled"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Color="Color.Primary">

                <MudMenuItem Icon="@Icons.Material.Filled.Add"
                             OnClick="OpenDialog">
                    Add
                </MudMenuItem>

                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">
                    Print
                </MudMenuItem>

            </MudMenu>
        </ToolBarContent>

          <ToolBarContent>
            @* <MudText Typo="Typo.h5" Color="Color.Primary">Borrower</MudText> *@
            <MudSpacer />
            <MudMenu Label="Add Borrower" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Add</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Print</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="Borrower" />
            @if (IsOrganizationSelected)
            {
                <PropertyColumn Property="x => x.CompanyName" Title="Company Name" />
                <PropertyColumn Property="x => x.TIN" Title="TIN" />
                <PropertyColumn Property="x => x.ContactPersonName" Title="Contact Person" />
                <PropertyColumn Property="x => x.ContactPersonPhone" Title="Contact Phone" />
                <PropertyColumn Property="x => x.BorrowerType.Type" Title="Borrower type" />
                <TemplateColumn Title="Total Debt" SortBy="x => x.TotalDebt">
                    <CellTemplate>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="@(() => OpenDebtDialog(context.Item.Id))" Style="font-weight: 700;">
                            @context.Item.TotalDebt.ToString("N2")
                        </MudButton>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Email" Title="Email" />
                <PropertyColumn Property="x => x.Province" Title="Province" />
                <PropertyColumn Property="x => x.District" Title="District" />
            }
            else
            {
                <TemplateColumn Title="Name">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.CompanyName))
                        {
                            <MudText Typo="Typo.body2">@context.Item.CompanyName</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@($"{context.Item.FirstName} {context.Item.LastName}")</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.BorrowerType.Type" Title="Borrower type" />
                <PropertyColumn Property="x => x.sex" Title="Sex" />
                <PropertyColumn Property="x => x.IdentificationNumber" Title="ID number" />
                <TemplateColumn Title="Total Debt" SortBy="x => x.TotalDebt">
                    <CellTemplate>
                        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" OnClick="@(() => OpenDebtDialog(context.Item.Id))" Style="font-weight: 700;">
                            @context.Item.TotalDebt.ToString("N2")
                        </MudButton>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Email" Title="Email" />
                <PropertyColumn Property="x => x.PhoneNumber" Title="Phone number" />
                <PropertyColumn Property="x => x.Province" Title="Province" />
                <PropertyColumn Property="x => x.District" Title="District" />
            }
        </Columns>
        
        <PagerContent>
            <MudDataGridPager T="Borrower" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
     private string _searchString = "";
     private string _selectedBorrowerType = "All";

     private bool IsOrganizationSelected => _selectedBorrowerType?.Equals("Organization", StringComparison.OrdinalIgnoreCase) == true || _selectedBorrowerType?.Equals("Business", StringComparison.OrdinalIgnoreCase) == true;

       List<Borrower> _borrowers = new();
    private HashSet<Borrower> _selectedItems = new();

    private IEnumerable<Borrower> FilteredBorrowers => _borrowers
        .Where(x => string.IsNullOrWhiteSpace(_searchString) || 
                    (x.FirstName != null && x.FirstName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.LastName != null && x.LastName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.CompanyName != null && x.CompanyName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.TIN != null && x.TIN.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.IdentificationNumber != null && x.IdentificationNumber.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.Email != null && x.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase)))
        .Where(x => _selectedBorrowerType == "All" || (x.BorrowerType != null && x.BorrowerType.Type == _selectedBorrowerType));

    private List<BorrowerTypeCount> _borrowerTypeCounts = new();

    private class BorrowerTypeCount
    {
        public string? BorrowerType { get; set; }
        public int Count { get; set; }
    }

      protected override async Task OnInitializedAsync()
    {
         await LoadBorrower();
         
    }
    
    private async Task OpenDialog()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };

        var dialog = await DialogService.ShowAsync<BorrowerCreateDialog>("Add Borrower", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
             await LoadBorrower();
        }
    }
     private async Task LoadBorrower()
    {
        _borrowers = await BorrowerService.GetAllBorrowersAsync();
        
        // Calculate borrower type counts
        _borrowerTypeCounts = _borrowers
            .Where(b => b.BorrowerType != null)
            .GroupBy(b => b.BorrowerType.Type)
            .Select(g => new BorrowerTypeCount
            {
                BorrowerType = g.Key,
                Count = g.Count()
            })
            .ToList();
        
        StateHasChanged();
    }
        private Color GetStatusColor(LoanStatus status)
        {
        return status.ToString() switch
        {
            "Dormant" => Color. Warning,
            "Active" => Color.Success,
            "Closed" => Color.Error,
            _ => Color.Default
        };
       }

    private async Task OpenDetailDialog(int id)
    {
        var parameters = new DialogParameters<BorrowerDetailDialog> { { x => x.Id, id } };
        await DialogService.ShowAsync<BorrowerDetailDialog>("View Details", parameters);
    }

    private async Task OpenDebtDialog(int id)
    {
        var parameters = new DialogParameters<BorrowerDebtDialog> { { x => x.BorrowerId, id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<BorrowerDebtDialog>("Debt Breakdown", parameters, options);
    }

     private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters<EditBorrowerDialog> { { x => x.Id, id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<EditBorrowerDialog>("Edit Borrower", parameters, options);
        var result = await dialog.Result;
    }

    private async Task ConfirmDeleteBorrower()
    {
        var selected = _selectedItems.FirstOrDefault();
        if (selected == null) return;

        var name = string.IsNullOrEmpty(selected.CompanyName) ? $"{selected.FirstName} {selected.LastName}" : selected.CompanyName;

        var result = await DialogService.ShowMessageBox(
            "Delete Borrower",
            $"Are you sure you want to delete borrower {name}?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await BorrowerService.DeleteBorrowerAsync(selected.Id);
                Snackbar.Add("Borrower deleted successfully.", Severity.Success);
                _selectedItems.Clear();
                await LoadBorrower();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
