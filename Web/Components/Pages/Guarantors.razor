@page "/Guarantor"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.Guarantors
@using Domain.ValueObjects
@inject IGuarantorService GuarantorService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Guarantors</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    @* 1. TOP TITLE AND SEARCH BAR *@
    <!-- <div class="d-flex align-center justify-space-between mb-6">
        <MudText Typo="Typo.h5" Style="font-weight: 800; color: #1B2559;">Guarantor</MudText>
    </div> -->

    @* 2. SEARCH AND FILTER ROW *@
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="_searchString" Placeholder="Search guarantor..." IconSize="Size.Medium" Class="mt-0" Clearable="true"></MudTextField>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudSelect T="string" @bind-Value="_selectedGuarantorType" Label="Guarantor Type" AnchorOrigin="Origin.BottomCenter" Clearable="false">
                <MudSelectItem Value="@("All")">All</MudSelectItem>
                @if (_guarantorTypeCounts != null)
                {
                    @foreach (var bt in _guarantorTypeCounts.Where(c => c.GuarantorType != null).Select(c => c.GuarantorType).Distinct())
                    {
                        <MudSelectItem Value="@bt">@bt</MudSelectItem>
                    }
                }
            </MudSelect>
        </MudItem>

        <MudItem xs="12"  Class="d-flex align-center justify-end gap-4">
            @if (_selectedItems.Any())
            {
                <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" OnClick="@(() => OpenDetailDialog(_selectedItems.First().Id))" />
                @* <MudIconButton Icon="@Icons.Material.Filled.Details" Size="Size.Small" /> *@
                <AuthorizeView Roles="Tenant">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"  OnClick="@(() => OpenEditDialog(_selectedItems.First().Id))" />
                </AuthorizeView>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@ConfirmDeleteGuarantor" />
                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
            }
            @* <MudButton StartIcon="@Icons.Material.Filled.FilterList" Variant="Variant.Text">Filter</MudButton> *@
            @* <MudButton StartIcon="@Icons.Material.Filled.Sort" Variant="Variant.Text">Sort by</MudButton> *@
     
        </MudItem>
    </MudGrid>

    @* 3. GUARANTOR TYPE SUMMARY CARDS *@
    <MudGrid Class="mb-4" Spacing="2">
        @if (_guarantorTypeCounts != null && _guarantorTypeCounts.Any())
        {
            @foreach (var typeCount in _guarantorTypeCounts)
            {
                <MudItem xs="12" sm="6" md="4" lg="3">
                    <MudCard Elevation="2" Class="pa-4">
                        <MudCardContent>
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@typeCount.GuarantorType</MudText>
                                <MudText Typo="Typo.h6" Style="font-weight: 600;">@typeCount.Count</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Info">Guarantors</MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        }
    </MudGrid>

    @* 4. THE DATAGRID *@
    <MudDataGrid T="Guarantor" Items="@FilteredGuarantors" MultiSelection="true" @bind-SelectedItems="_selectedItems"
                 Hover="true" Elevation="0" Class="rounded-xl border-none" Filterable="true">

                  <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Guarantor</MudText>
            <MudSpacer />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenDialog">Add Guarantor</MudButton>
        </ToolBarContent>

          <ToolBarContent>
            @* <MudText Typo="Typo.h5" Color="Color.Primary">Guarantor</MudText> *@
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Add Guarantor</MudButton>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="Guarantor" />
            @if (IsOrganizationSelected)
            {
                <PropertyColumn Property="x => x.CompanyName" Title="Company Name" />
                <PropertyColumn Property="x => x.TIN" Title="TIN" />
                <PropertyColumn Property="x => x.ContactPersonName" Title="Contact Person" />
                <PropertyColumn Property="x => x.ContactPersonPhone" Title="Contact Phone" />
                <PropertyColumn Property="x => x.GuarantorType.Name" Title="Guarantor type" />
                <PropertyColumn Property="x => x.LoanApplication.ApplicationCode" Title="Loan Application" />
                <PropertyColumn Property="x => x.Email" Title="Email" />
                <PropertyColumn Property="x => x.Province" Title="Province" />
                <PropertyColumn Property="x => x.District" Title="District" />
            }
            else
            {
                <TemplateColumn Title="Name">
                    <CellTemplate>
                        @if (!string.IsNullOrEmpty(context.Item.CompanyName))
                        {
                            <MudText Typo="Typo.body2">@context.Item.CompanyName</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">@($"{context.Item.FirstName} {context.Item.LastName}")</MudText>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.GuarantorType.Name" Title="Guarantor type" />
                <PropertyColumn Property="x => x.Identification" Title="ID number" />
                <PropertyColumn Property="x => x.LoanApplication.ApplicationCode" Title="Loan Application" />
                <PropertyColumn Property="x => x.Email" Title="Email" />
                <PropertyColumn Property="x => x.PhoneNumber" Title="Phone number" />
                <PropertyColumn Property="x => x.Province" Title="Province" />
                <PropertyColumn Property="x => x.District" Title="District" />
            }
        </Columns>
        
        <PagerContent>
            <MudDataGridPager T="Guarantor" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
     private string _searchString = "";
    private string _selectedGuarantorType = "All";

     private bool IsOrganizationSelected => _selectedGuarantorType?.Equals("Organization", StringComparison.OrdinalIgnoreCase) == true || _selectedGuarantorType?.Equals("Business", StringComparison.OrdinalIgnoreCase) == true;

    private IEnumerable<Guarantor> FilteredGuarantors => _guarantor
        .Where(x => string.IsNullOrWhiteSpace(_searchString) || 
                    (x.FirstName != null && x.FirstName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.LastName != null && x.LastName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.CompanyName != null && x.CompanyName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.TIN != null && x.TIN.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.Identification != null && x.Identification.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.Email != null && x.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase)))
        .Where(x => _selectedGuarantorType == "All" || (x.GuarantorType != null && x.GuarantorType.Name == _selectedGuarantorType));
     //s
       List<Guarantor> _guarantor = new();
    private HashSet<Guarantor> _selectedItems = new();

    private List<GuarantorTypeCount> _guarantorTypeCounts = new();

    private class GuarantorTypeCount
    {
        public string? GuarantorType { get; set; }
        public int Count { get; set; }
    }


      protected override async Task OnInitializedAsync()
    {
         await LoadGuarantor();
         
    }
    
    private async Task OpenDialog()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };

        var dialog = await DialogService.ShowAsync<CreateGuarantorDialog>("Add Guarantor", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
             await LoadGuarantor();
        }
    }
     private async Task LoadGuarantor()
    {
        _guarantor = await GuarantorService.GetAllGuarantorsAsync();
        
        // Calculate guarantor type counts
        _guarantorTypeCounts = _guarantor
            .Where(b => b.GuarantorType != null)
            .GroupBy(b => b.GuarantorType.Name)
            .Select(g => new GuarantorTypeCount
            {
                GuarantorType = g.Key,
                Count = g.Count()
            })
            .ToList();
            
        StateHasChanged();
    }
        private Color GetStatusColor(LoanStatus status)
        {
        return status.ToString() switch
        {
            "Dormant" => Color. Warning,
            "Active" => Color.Success,
            "Closed" => Color.Error,
            _ => Color.Default
        };
       }

    private async Task OpenDetailDialog(int id)
    {
        var parameters = new DialogParameters<BorrowerDetailDialog> { { x => x.Id, id } };
        await DialogService.ShowAsync<BorrowerDetailDialog>("View Details", parameters);
    }

     private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters<EditBorrowerDialog> { { x => x.Id, id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<EditBorrowerDialog>("Edit Guarantor", parameters, options);
        var result = await dialog.Result;
    }

    private async Task ConfirmDeleteGuarantor()
    {
        var selected = _selectedItems.FirstOrDefault();
        if (selected == null) return;

        var result = await DialogService.ShowMessageBox(
            "Delete Guarantor",
            $"Are you sure you want to delete guarantor {selected.FirstName} {selected.LastName}?",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            try
            {
                await GuarantorService.DeleteGuarantor(selected.Id);
                Snackbar.Add("Guarantor deleted successfully.", Severity.Success);
                _selectedItems.Clear();
                await LoadGuarantor();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
