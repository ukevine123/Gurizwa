@using  Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces
@using Application.Services.AccountTypes
@using Application.Services.Accounts
@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization
@* @attribute [Authorize] *@
@inject NavigationManager Navigation
@inject IAccountService AccountService
@inject IAccountTypeService AccountTypeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudDialog Style="overflow:hidden;" >

    <DialogContent>

        <!-- ══════════ HEADER BANNER ══════════ -->
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #4318FF );
                         padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                <MudIcon Icon="@Icons.Material.Filled.AccountBalance"
                         Style="color:white; font-size:1.6rem;" />

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700; line-height:1.2;">
                        Create Account
                    </MudText>

                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new Account
                    </MudText>
                </MudStack>

            </MudStack>
        </MudPaper>


        <!-- ══════════ FORM ══════════ -->
        <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreateAccountForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @* <MudStack Spacing="2"> *@

                <!-- Section -->
                @* <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600; letter-spacing:.08em;
                                text-transform:uppercase;">
                    Account Type
                </MudText> *@
                <MudGrid Spacing="1" Class="align-items-center">
                    
                <MudItem  xs="6">
                <MudTextField Label="Name"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Name"
                              For="@(() => Model.Name)" />
                </MudItem>
                <MudItem  xs="6">
                <MudTextField Label="Provider"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Provider"
                              For="@(() => Model.Provider)" />
                </MudItem>
                <MudItem  xs="6">
                <MudSelect T="int" 
                             Label="AccountType"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Placeholder="--Select Account Type"
                              AdornmentIcon="@Icons.Material.Filled.Category"
                                AdornmentColor="Color.Primary"
                              @bind-Value="Model.AccountTypeId">

                              <MudSelectItem Value="0">--Select Account Type--</MudSelectItem>
                              @if (_accountTypes != null)
                              {
                                foreach(var types in _accountTypes)
                                {
                                    <MudSelectItem T="int" Value="@types.Id">@types.AccountTypeName</MudSelectItem>
                                }
                              }
                </MudSelect>     
                </MudItem>
                <MudItem  xs="6">
                <MudTextField Label="AccountNumber"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.AccountNumber"
                              For="@(() => Model.AccountNumber)" />
                </MudItem>
                <MudItem  xs="6">
                <MudTextField Label="Balance"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Balance"
                              For="@(() => Model.Balance)" />
                </MudItem>
                <MudItem  xs="6">
                <MudSelect T="string"
                           Label="Currency"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           AnchorOrigin="Origin.BottomCenter"
                           AdornmentColor="Color.Primary"
                           @bind-Value="Model.Currency"
                           For="@(() => Model.Currency)">
                    <MudSelectItem T="string" Value="@string.Empty">--Select Currency--</MudSelectItem>
                    @foreach (var currency in Currencies)
                    {
                        <MudSelectItem T="string" Value="@currency.Code">@currency.Label</MudSelectItem>
                    }
                </MudSelect>
                </MudItem>



                 
                <MudItem xs="12">
                <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Small"
                        FullWidth="true"
                        ButtonType="ButtonType.Submit"
                        Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px;">
                    Add Account
                </MudButton>
                </MudItem>



            </MudGrid>

        </EditForm>
    </DialogContent>
</MudDialog>

@code{
    [CascadingParameter]
    
    private IMudDialogInstance MudDialog { get; set; }
    private bool _fullWidth;
    private bool _fitContent;
    [SupplyParameterFromForm(Name = "CreateAccountForm")]
    private AccountCreateDTO Model {get;set;} = new ();
    private string ErrorMessage{get;set;}
    private List<AccountType> _accountTypes = new ();

    private readonly List<(string Code, string Label)> Currencies = new()
    {
        ("RWF", "🇷🇼 RWF — Rwandan Franc"),
        ("USD", "🇺🇸 USD — US Dollar"),
        ("EUR", "🇪🇺 EUR — Euro"),
        ("GBP", "🇬🇧 GBP — British Pound"),
        ("CAD", "🇨🇦 CAD — Canadian Dollar"),
        ("AUD", "🇦🇺 AUD — Australian Dollar"),
    };

      protected override async Task OnInitializedAsync()
      {
          try
          {
               var types = await AccountTypeService.GetAllAccountTypesAsync();
               if (types != null)
               {
                _accountTypes=types;
                StateHasChanged();
               }
          }
    catch (Exception ex)
    {
        Snackbar.Add("Error Loading Account Types",Severity.Error);
    }
      }
    private async Task onValidSubmit()
    {
        try
        {
            await AccountService.CreateAccountAsync(Model);
            Snackbar.Add("Account created successfully!", Severity.Info);
            MudDialog.Close(DialogResult.Ok(Model));
        }
        catch(Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
   
    

}
