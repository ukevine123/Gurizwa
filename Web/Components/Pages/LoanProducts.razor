@page "/loanProducts"
@using Application.Interfaces
@using Application.Services.Requirements
@using MudBlazor
@using Domain.Entities
@using Application.Services.LoanProductSettings
@inject ILoanProductSettingService LoanProductSettingService
@inject IRequirementService RequirementService
@inject ILoanProductService LoanProductService
@inject NavigationManager Navigation
@inject IDialogService DialogService

<PageTitle>Loan Products</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 p-3">
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        
        @* --- TAB 1: LOAN PRODUCTS --- *@
        <MudTabPanel Text="Loan Products" Icon="@Icons.Material.Filled.Category">
            <MudDataGrid T="LoanProduct" Items="@_loanProducts" MultiSelection="true" @bind-SelectedItems="_selectedItems"
                         Hover="true" Elevation="0" Class="rounded-xl border-none shadow-sm mt-4">
                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: bold;">Loan Products List</MudText>
                    <MudSpacer />
                    <div class="d-flex align-center gap-4 mr-4">
                        @if (_selectedItems.Any())
                        {
                            <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" Disabled="@(!_selectedItems.Any())" OnClick="@(() => OpenDetailDialog(_selectedItems.First()))" />
                            <AuthorizeView Roles="Tenant">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => OpenEditDialog(_selectedItems.First().Id))" />
                            </AuthorizeView>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
                        }
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Add Loan Product</MudButton>
                </ToolBarContent>
                <Columns>
                    <SelectColumn T="LoanProduct" />
                    <HierarchyColumn T="LoanProduct" />
                    <PropertyColumn Property="x => x.ProductName" Title="Product Name" />
                    <PropertyColumn Property="x => x.Description" Title="Description" />
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="LoanProduct" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>

        @* --- TAB 2: LOAN PRODUCT SETTINGS --- *@
        <MudTabPanel Text="Loan Product Settings" Icon="@Icons.Material.Filled.Settings">
            <MudDataGrid T="LoanProductSetting"
                         Items="@LoanProductSettings"
                         MultiSelection="true"
                         @bind-SelectedItems="_selectedSettingItems"
                         Hover="true"
                         Elevation="0"
                         Class="rounded-xl border-none shadow-sm mx-4 mt-4">
                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: bold;">Loan Product Settings</MudText>
                    <MudSpacer />
                    <div class="d-flex align-center gap-4 mr-4">
                        @if (_selectedSettingItems.Any())
                        {
                            <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedSettingItems.Count Selected</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
                        }
                    </div>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@GoToCreateLoanProductSetting">Add Loan product Setting</MudButton>
                </ToolBarContent>
                <Columns>
                    <SelectColumn T="LoanProductSetting" />
                    <PropertyColumn Property="x => x.LoanProduct.ProductName" Title="Loan Product" Sortable="true" />
                    <PropertyColumn Property="x => x.InterestRate" Title="Interest Rate (%)" Sortable="true" />
                    <PropertyColumn Property="x => x.GracePeriodDays" Title="Grace Period (Days)" Sortable="true" Format="0" />
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="LoanProductSetting" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private string _searchString = "";
    private List<LoanProduct> _loanProducts = new();
    private HashSet<LoanProduct> _selectedItems = new();
    
    private List<LoanProductSetting> LoanProductSettings = new();
    private HashSet<LoanProductSetting> _selectedSettingItems = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLoanProduct();
        await LoadLoanProductSetting();
    }

    private async Task LoadLoanProduct()
    {
        _loanProducts = (await LoanProductService.GetAllLoanProductsAsync()).OrderByDescending(x => x.Id).ToList();
        StateHasChanged();
    }

    private async Task LoadLoanProductSetting()
    {
        var result = await LoanProductSettingService.GetAllLoanProductSettingsAsync();
        LoanProductSettings = result?.ToList() ?? new List<LoanProductSetting>();
        StateHasChanged();
    }

    private async Task OpenDialog()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<LoanProductDialog>("Add LoanProduct", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadLoanProduct();
        }
    }

    private async Task GoToCreateLoanProductSetting()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };
        var dialog = await DialogService.ShowAsync<LoanProductSettingDialog>("Add LoanProduct Setting", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100);
            await LoadLoanProductSetting();
        }
    }

    private async Task OpenDetailDialog(LoanProduct product)
    {
        var allRequirements = await RequirementService.GetAllRequirementsAsync();
        var productRequirements = allRequirements
            .Where(r => r.LoanProductId == product.Id)
            .ToList();

        var parameters = new DialogParameters<LoanProductDetailDialog> 
        { 
            { x => x.Product, product }, 
            { x => x.Requirements, productRequirements },
            { x => x.Id, product.Id }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<LoanProductDetailDialog>("Loan Product Details", parameters, options);
    }

    private async Task OpenEditDialog(int id)
    {
        Navigation.NavigateTo($"/loanproducts/edit/{id}");
    }
}
