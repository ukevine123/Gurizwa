@using Application.DTO

<MudTabs Elevation="0" Rounded="true" Centered="true" Class="mt-4" Color="Color.Transparent" ActiveTabClass="mud-theme-primary" ActivePanelIndex="ActiveUpcomingDuesTab" ActivePanelIndexChanged="OnActiveUpcomingDuesTabChanged">
    <MudTabPanel Text="Due in 5 Days">
        <MudDataGrid T="RepaymentScheduleReportDTO" Items="@RepaymentSchedules.Where(s => s.DueDate.Date >= DateTime.Now.Date && s.DueDate.Date <= DateTime.Now.Date.AddDays(5)).OrderBy(s => s.DueDate)" Hover="true" Striped="true" Class="mt-4">
            <ToolBarContent>
                <MudSpacer />
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.ApplicationCode" Title="Code" />
                <PropertyColumn Property="x => x.BorrowerName" Title="Borrower" />
                <PropertyColumn Property="x => x.DueDate" Title="Due Date" Format="yyyy-MM-dd" />
                <PropertyColumn Property="x => x.InstallmentAmount" Title="Installment Amount" Format="N2" />
                <TemplateColumn Title="Action">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.ReadMore" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small" OnClick="@(() => OnViewDetails.InvokeAsync(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="RepaymentScheduleReportDTO" />
            </PagerContent>
        </MudDataGrid>
    </MudTabPanel>
    <MudTabPanel Text="Due in 7 Days">
        <MudDataGrid T="RepaymentScheduleReportDTO" Items="@RepaymentSchedules.Where(s => s.DueDate.Date >= DateTime.Now.Date && s.DueDate.Date <= DateTime.Now.Date.AddDays(7)).OrderBy(s => s.DueDate)" Hover="true" Striped="true" Class="mt-4">
            <ToolBarContent>
                <MudSpacer />
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.ApplicationCode" Title="Code" />
                <PropertyColumn Property="x => x.BorrowerName" Title="Borrower" />
                <PropertyColumn Property="x => x.DueDate" Title="Due Date" Format="yyyy-MM-dd" />
                <PropertyColumn Property="x => x.InstallmentAmount" Title="Installment Amount" Format="N2" />
                <TemplateColumn Title="Action">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.ReadMore" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Small" OnClick="@(() => OnViewDetails.InvokeAsync(context.Item))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="RepaymentScheduleReportDTO" />
            </PagerContent>
        </MudDataGrid>
    </MudTabPanel>
</MudTabs>

@code {
    [Parameter] public List<RepaymentScheduleReportDTO> RepaymentSchedules { get; set; } = new();
    [Parameter] public int ActiveUpcomingDuesTab { get; set; }
    [Parameter] public EventCallback<int> ActiveUpcomingDuesTabChanged { get; set; }
    [Parameter] public EventCallback<RepaymentScheduleReportDTO> OnViewDetails { get; set; }

    private async Task OnActiveUpcomingDuesTabChanged(int value)
    {
        ActiveUpcomingDuesTab = value;
        await ActiveUpcomingDuesTabChanged.InvokeAsync(value);
    }
}
