@using Application.DTO

<MudPaper Class="pa-4 mb-4" Elevation="0">
    <MudGrid>
        <MudItem xs="12" sm="4">
            <MudDateRangePicker Label="Transaction Period" DateRange="AccountHistoryRange" DateRangeChanged="OnAccountHistoryRangeChanged" />
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="OnGenerateReport" StartIcon="@Icons.Material.Filled.Refresh">Generate Report</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudDataGrid Items="@AccountHistories" Hover="true" Striped="true" Class="mt-4">
    <ToolBarContent>
    </ToolBarContent>
    <Columns>
        <HierarchyColumn T="AccountHistoryReportDTO" />
        <PropertyColumn Property="x => x.AccountName" Title="Account Name" />
        <PropertyColumn Property="x => x.Provider" Title="Provider" />
        <PropertyColumn Property="x => x.AccountNumber" Title="Account Number" />
        <PropertyColumn Property="x => x.CurrentBalance" Title="Current Balance" Format="N2" />
        <PropertyColumn Property="x => x.Transactions.Count" Title="Transactions Count" />
    </Columns>
    <ChildRowContent>
        <MudCard Elevation="0" Class="pa-4 ml-6" Style="background-color: var(--mud-palette-background-grey);">
            <MudText Typo="Typo.subtitle1" Class="mb-2">Transactions for @context.Item.AccountName</MudText>
            @if (context.Item.Transactions.Any())
            {
                <MudTable Items="@context.Item.Transactions" Dense="true" Hover="true" Elevation="1">
                    <HeaderContent>
                        <MudTh>Date</MudTh>
                        <MudTh>Type</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Amount</MudTh>
                    </HeaderContent>
                    <RowTemplate Context="txnCtx">
                        <MudTd DataLabel="Date">@txnCtx.TransactionDate.ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd DataLabel="Type">
                            <MudChip T="string" Color="@(txnCtx.Amount > 0 ? MudBlazor.Color.Success : MudBlazor.Color.Error)" Size="MudBlazor.Size.Small">@txnCtx.TransactionType</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Description">@txnCtx.Description</MudTd>
                        <MudTd DataLabel="Amount">@Math.Abs(txnCtx.Amount).ToString("N2")</MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudText Typo="Typo.body2">No transactions found for the selected period.</MudText>
            }
        </MudCard>
    </ChildRowContent>
    <PagerContent>
        <MudDataGridPager T="AccountHistoryReportDTO" />
    </PagerContent>
</MudDataGrid>

@code {
    [Parameter] public List<AccountHistoryReportDTO> AccountHistories { get; set; } = new();
    [Parameter] public DateRange AccountHistoryRange { get; set; }
    [Parameter] public EventCallback<DateRange> AccountHistoryRangeChanged { get; set; }
    [Parameter] public EventCallback OnGenerateReport { get; set; }

    private async Task OnAccountHistoryRangeChanged(DateRange range)
    {
        AccountHistoryRange = range;
        await AccountHistoryRangeChanged.InvokeAsync(range);
    }
}
