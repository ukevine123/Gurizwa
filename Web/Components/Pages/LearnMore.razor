                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bottom CTA -->
    <section class="learn-cta">
        <div class="cta-content">
            <h2>Ready to experience the digital transition?</h2>
            <p>Onboard your lending institution or log in with your credit administrator account to begin creating products and managing portfolios.</p>
            <a href="/account/login" class="btn btn-primary btn-lg">Access Portal Now</a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
        <p>&copy; 2026 Guriza. All rights reserved.</p>
    </footer>
</div>

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #4318FF 0%, #070bdc 100%);
        --primary-color: #4318FF;
        --secondary-color: #070bdc;
        --text-dark: #1B2559;
        --text-light: #A3AED0;
        --background-light: #F7F9FC;
    }

    .learn-container {
        height: 100vh;
        overflow-y: auto;
        background-color: #FAFCFF;
        color: var(--text-dark);
        font-family: 'Inter', sans-serif;
    }

    /* Navbar */
    .learn-navbar {
        position: sticky;
        top: 0;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        z-index: 100;
        padding: 16px 40px;
    }

    .navbar-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .brand-logo {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .logo-img {
        width: 48px;
        height: 39px;
        object-fit: cover;
        object-position: top;
        border-radius: 8px;
    }

    .logo-text {
        font-size: 1.4rem;
        font-weight: 900;
        letter-spacing: 0.5px;
        color: var(--text-dark);
    }

    .back-btn {
        gap: 8px;
        background: #F4F7FE;
        color: var(--primary-color) !important;
        border-radius: 12px;
        padding: 10px 18px;
        font-size: 0.85rem;
    }

    .back-btn:hover {
        background: #EAEFFD;
    }

    /* Hero */
    .learn-hero {
        text-align: center;
        padding: 60px 40px 40px;
        max-width: 800px;
        margin: 0 auto;
    }

    .learn-title {
        font-size: 3rem;
        font-weight: 900;
        margin-bottom: 16px;
        letter-spacing: -1px;
    }

    .gradient-text {
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .learn-subtitle {
        font-size: 1.1rem;
        color: var(--text-light);
        line-height: 1.6;
    }

    /* Showroom */
    .showroom-section {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px 80px;
    }

    .showroom-wrapper {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 40px;
        align-items: flex-start;
    }

    /* Showroom Sidebar */
    .showroom-sidebar {
        display: flex;
        flex-direction: column;
        gap: 12px;
        background: white;
        padding: 16px;
        border-radius: 24px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.03);
    }

    .showroom-tab-btn {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px;
        border-radius: 16px;
        border: none;
        background: transparent;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s ease;
        color: var(--text-dark);
    }

    .showroom-tab-btn i {
        font-size: 1.25rem;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #F4F7FE;
        color: var(--primary-color);
        transition: all 0.2s ease;
    }

    .tab-btn-text h4 {
        font-size: 0.95rem;
        font-weight: 700;
        margin: 0 0 2px;
    }

    .tab-btn-text p {
        font-size: 0.75rem;
        color: var(--text-light);
        margin: 0;
    }

    .showroom-tab-btn:hover {
        background: #F8FAFC;
    }

    .showroom-tab-btn.active {
        background: var(--primary-gradient);
        color: white;
    }

    .showroom-tab-btn.active i {
        background: rgba(255, 255, 255, 0.2);
        color: white;
    }

    .showroom-tab-btn.active .tab-btn-text p {
        color: rgba(255, 255, 255, 0.8);
    }

    /* Showroom Display */
    .showroom-display {
        display: grid;
        grid-template-columns: 1.1fr 1.3fr;
        gap: 32px;
        background: white;
        border-radius: 32px;
        border: 1px solid rgba(0, 0, 0, 0.03);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.04);
        overflow: hidden;
        padding: 40px;
        min-height: 520px;
    }

    .display-details {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: flex-start;
    }

    .category-badge {
        font-size: 0.75rem;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 16px;
    }

    .category-badge.blue { background: #EBF3FF; color: var(--primary-color); }
    .category-badge.green { background: #E6F9F3; color: #05CD99; }
    .category-badge.info { background: #EAF7FF; color: #39B8FF; }
    .category-badge.warning { background: #FFF5E6; color: #FFB547; }
    .category-badge.purple { background: #F4EBFF; color: #8A3FFC; }

    .display-details h3 {
        font-size: 1.8rem;
        font-weight: 900;
        margin: 0 0 16px;
        letter-spacing: -0.5px;
    }

    .desc-text {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--text-light);
        margin-bottom: 24px;
    }

    .key-takeaways {
        margin-bottom: 30px;
        width: 100%;
