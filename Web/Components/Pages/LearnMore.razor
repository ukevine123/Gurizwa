@page "/learn-more"
@attribute [AllowAnonymous]
@layout Web.Components.Layout.AuthLayout
@inject NavigationManager Navigation

<PageTitle>Guriza - Feature Showroom</PageTitle>

<div class="learn-container">
    <!-- Header/Nav -->
    <header class="learn-navbar">
        <div class="navbar-content">
            <div class="brand-logo" @onclick='() => Navigation.NavigateTo("/")' style="cursor: pointer;">
                <img src="/Images/guriza_logo.png" alt="Guriza Logo" class="logo-img" />
                <span class="logo-text">GURIZA</span>
            </div>
            <button class="btn btn-secondary back-btn" @onclick='() => Navigation.NavigateTo("/")'>
                <i class="oi oi-arrow-left"></i> Back to Landing Page
            </button>
        </div>
    </header>

    <!-- Hero Header -->
    <section class="learn-hero">
        <h1 class="learn-title">Inside the <span class="gradient-text">Guriza Platform</span></h1>
        <p class="learn-subtitle">Explore the exact interface, layouts, and tools designed to optimize digital lending workflows, assess risk, and track payment pipelines.</p>
    </section>

    <!-- Showroom Section -->
    <section class="showroom-section">
        <div class="showroom-wrapper">
            <!-- Sidebar Navigation Tabs -->
            <div class="showroom-sidebar">
                <button class="showroom-tab-btn @(ActiveTab == "dashboard" ? "active" : "")" @onclick='() => SetActiveTab("dashboard")'>
                    <i class="oi oi-dashboard"></i>
                    <div class="tab-btn-text">
                        <h4>Executive Dashboard</h4>
                        <p>Aggregated metrics & trends</p>
                    </div>
                </button>
                <button class="showroom-tab-btn @(ActiveTab == "borrowers" ? "active" : "")" @onclick='() => SetActiveTab("borrowers")'>
                    <i class="oi oi-people"></i>
                    <div class="tab-btn-text">
                        <h4>Borrowers Directory</h4>
                        <p>Onboarding & client records</p>
                    </div>
                </button>
                <button class="showroom-tab-btn @(ActiveTab == "applications" ? "active" : "")" @onclick='() => SetActiveTab("applications")'>
                    <i class="oi oi-file"></i>
                    <div class="tab-btn-text">
                        <h4>Loan Applications</h4>
                        <p>Submission & verification</p>
                    </div>
                </button>
                <button class="showroom-tab-btn @(ActiveTab == "payments" ? "active" : "")" @onclick='() => SetActiveTab("payments")'>
                    <i class="oi oi-dollar"></i>
                    <div class="tab-btn-text">
                        <h4>Payments & Schedules</h4>
                        <p>Amortization & collection logs</p>
                    </div>
                </button>
                <button class="showroom-tab-btn @(ActiveTab == "reports" ? "active" : "")" @onclick='() => SetActiveTab("reports")'>
                    <i class="oi oi-graph"></i>
                    <div class="tab-btn-text">
                        <h4>System Reports</h4>
                        <p>Ledger audit & waiver approvals</p>
                    </div>
                </button>
            </div>

            <!-- Showroom Display Area -->
            <div class="showroom-display">
                <!-- Tab Content details -->
                <div class="display-details">
                    @if (ActiveTab == "dashboard")
                    {
                        <span class="category-badge blue">Operational Hub</span>
                        <h3>Dashboard Overview</h3>
                        <p class="desc-text">The operational brain of Guriza. Provides managers and credit risk officers with instant insights into the health of the lending portfolio.</p>
                        
                        <div class="key-takeaways">
                            <h4>Key Capabilities:</h4>
                            <ul>
                                <li><i class="oi oi-check text-success"></i> <strong>Aggregate Metrics:</strong> Track total loan files (applied, approved, rejected, disbursed) dynamically.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Performance Analytics:</strong> Observe monthly application trend charts over selected timeframes.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Account Balances:</strong> Direct view of capital, disbursements, and penalty deposits in real-time.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Activity Heatmap:</strong> Visual log of credit staff activity across the calendar year.</li>
                            </ul>
                        </div>
                    }
                    else if (ActiveTab == "borrowers")
                    {
                        <span class="category-badge green">KYC & Onboarding</span>
                        <h3>Borrowers Directory</h3>
                        <p class="desc-text">Onboard borrowers and manage client profiles with rich demographic inputs, identity documents, and debt ceilings.</p>
                        
                        <div class="key-takeaways">
                            <h4>Key Capabilities:</h4>
                            <ul>
                                <li><i class="oi oi-check text-success"></i> <strong>Full KYC Records:</strong> Save personal data, emails, telephone numbers, and addresses.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Risk Profile:</strong> Categorize clients as Individual or Enterprise and manage credit locks.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Integrated Audits:</strong> View borrower history, outstanding debts, and payment performance.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Action Shortcuts:</strong> Edit profiles, check guarantor files, and attach documents.</li>
                            </ul>
                        </div>
                    }
                    else if (ActiveTab == "applications")
                    {
                        <span class="category-badge info">Credit Review Pipeline</span>
                        <h3>Loan Application Flow</h3>
                        <p class="desc-text">Manage the complete lifecycle of a loan, from configuration of requirements to final credit committee authorization.</p>
                        
                        <div class="key-takeaways">
                            <h4>Key Capabilities:</h4>
                            <ul>
                                <li><i class="oi oi-check text-success"></i> <strong>Requirement Checklist:</strong> Mandate document checklists per loan product.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Collateral Appraisal:</strong> Record assets, values, and verification details.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Guarantor Management:</strong> Connect multiple guarantors with customizable coverage shares.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Multi-Stage Flow:</strong> Automated status tags (Pending, Approved, Disbursed, Rejected).</li>
                            </ul>
                        </div>
                    }
                    else if (ActiveTab == "payments")
                    {
                        <span class="category-badge warning">Financial Ledger</span>
                        <h3>Payment Schedules</h3>
                        <p class="desc-text">Generate amortization schedules, process user repayments, calculate dynamic late penalties, and execute waivers.</p>
                        
                        <div class="key-takeaways">
                            <h4>Key Capabilities:</h4>
                            <ul>
                                <li><i class="oi oi-check text-success"></i> <strong>Amortization Tables:</strong> Automated division of principal and interest per schedule date.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Grace Period & Penalties:</strong> Automatic calculations of penalties on past-due invoices.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Collection Auditing:</strong> Log exact payment modes (Mobile Money, Bank Transfer, cash).</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Flexible Waivers:</strong> Submit penalty waiver requests for manager approvals.</li>
                            </ul>
                        </div>
                    }
                    else if (ActiveTab == "reports")
                    {
                        <span class="category-badge purple">System Integrity</span>
                        <h3>Ledger Audit & Reports</h3>
                        <p class="desc-text">Export accounting reports, audit transactions, track system expenses, and balance financial positions across multiple accounts.</p>
                        
                        <div class="key-takeaways">
                            <h4>Key Capabilities:</h4>
                            <ul>
                                <li><i class="oi oi-check text-success"></i> <strong>Expense Tracking:</strong> Log operational costs by custom classifications.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Comprehensive Ledgers:</strong> Check branch transaction logs and cashflows.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Printable Formats:</strong> Export clean PDF/Excel sheets of performance metrics.</li>
                                <li><i class="oi oi-check text-success"></i> <strong>Business Isolation:</strong> Ensure strict tenant separation in multi-tenant environments.</li>
                            </ul>
                        </div>
                    }

                    <div class="learn-actions">
                        <a href="/account/login" class="btn btn-primary">Try Live System</a>
                    </div>
                </div>

                <!-- Tab Preview Render (High Fidelity HTML/CSS Mockup representing the "Same picture/UI of the page") -->
                <div class="display-visual-window">
                    <div class="mock-header-bar">
                        <div class="mock-dots">
                            <span class="dot red"></span>
                            <span class="dot yellow"></span>
                            <span class="dot green"></span>
                        </div>
                        <div class="mock-url">guriza.org/@(ActiveTab)</div>
                    </div>
                    
                    <div class="mock-page-content">
                        @if (ActiveTab == "dashboard")
                        {
                            <!-- Dashboard UI Mock -->
                            <div class="mock-dash">
                                <div class="mock-sec-header">
                                    <h4>Dashboard Overview</h4>
                                    <span class="mock-date">Today, 2026</span>
                                </div>
                                <div class="mock-stats-row">
                                    <div class="m-stat" style="border-left-color: #4318FF;">
                                        <span class="m-label">Applied</span>
                                        <span class="m-val">152</span>
                                    </div>
                                    <div class="m-stat" style="border-left-color: #05CD99;">
                                        <span class="m-label">Approved</span>
                                        <span class="m-val">98</span>
                                    </div>
                                    <div class="m-stat" style="border-left-color: #EE5D50;">
                                        <span class="m-label">Rejected</span>
                                        <span class="m-val">12</span>
                                    </div>
                                    <div class="m-stat" style="border-left-color: #7047EB;">
                                        <span class="m-label">Disbursed</span>
                                        <span class="m-val">84</span>
                                    </div>
                                </div>
                                <div class="mock-chart-card">
                                    <h5>Application Monthly Performance</h5>
                                    <div class="mock-bar-chart">
                                        <div class="bar-bar" style="height: 40%"><span>Jan</span></div>
                                        <div class="bar-bar" style="height: 60%"><span>Feb</span></div>
                                        <div class="bar-bar" style="height: 85%"><span>Mar</span></div>
                                        <div class="bar-bar" style="height: 70%"><span>Apr</span></div>
                                        <div class="bar-bar" style="height: 95%"><span>May</span></div>
                                        <div class="bar-bar" style="height: 100%"><span>Jun</span></div>
                                    </div>
                                </div>
                                <div class="mock-heatmap-card">
                                    <h5>Daily Activity Ledger (Heatmap)</h5>
                                    <div class="mock-heatmap">
                                        @for (int i = 0; i < 35; i++)
                                        {
                                            var density = (i % 7 == 0) ? "none" : (i % 5 == 0) ? "high" : (i % 3 == 0) ? "med" : "low";
                                            <span class="heat-node @density"></span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else if (ActiveTab == "borrowers")
                        {
                            <!-- Borrowers UI Mock -->
                            <div class="mock-borrowers">
                                <div class="mock-sec-header">
                                    <h4>Borrower Directory</h4>
                                    <span class="m-btn-mini">+ Register Borrower</span>
                                </div>
                                <div class="mock-search-bar">
                                    <input type="text" placeholder="Search by name, phone..." disabled />
                                </div>
                                <table class="mock-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Email</th>
                                            <th>Phone</th>
                                            <th>Debt (Rwf)</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><strong>Isabella Mugisha</strong></td>
                                            <td>isabella@gmail.com</td>
                                            <td>+250 788 123 456</td>
                                            <td>4,500,000</td>
                                            <td><span class="m-chip success">Active</span></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Jean Claude Nshimiye</strong></td>
                                            <td>jc.nshimiye@gmail.com</td>
                                            <td>+250 785 987 654</td>
                                            <td>0</td>
                                            <td><span class="m-chip warning">Pending</span></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Aisha Uwase</strong></td>
                                            <td>aisha.uwase@yahoo.com</td>
                                            <td>+250 783 555 111</td>
                                            <td>1,200,000</td>
                                            <td><span class="m-chip success">Active</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        }
                        else if (ActiveTab == "applications")
                        {
                            <!-- Applications UI Mock -->
                            <div class="mock-applications">
                                <div class="mock-sec-header">
                                    <h4>Active Applications</h4>
                                    <span class="m-btn-mini">+ New Application</span>
                                </div>
                                <div class="mock-card-list">
                                    <div class="m-app-card">
                                        <div class="m-app-header">
                                            <h5>Student Loan - Rwf 800,000</h5>
                                            <span class="m-chip warning">Under Review</span>
                                        </div>
                                        <p class="m-app-meta">Borrower: Isabella Mugisha | Date: 2026-07-15</p>
                                        <div class="m-app-requirements">
                                            <span class="m-req verified"><i class="oi oi-circle-check"></i> KYC Info</span>
                                            <span class="m-req verified"><i class="oi oi-circle-check"></i> Transcript</span>
                                            <span class="m-req missing"><i class="oi oi-warning"></i> Guarantor Letter</span>
                                        </div>
                                    </div>
                                    <div class="m-app-card">
                                        <div class="m-app-header">
                                            <h5>GIRA IWAWE - Rwf 15,000,000</h5>
                                            <span class="m-chip success">Approved</span>
                                        </div>
                                        <p class="m-app-meta">Borrower: Jean Claude Nshimiye | Date: 2026-07-12</p>
                                        <div class="m-app-requirements">
                                            <span class="m-req verified"><i class="oi oi-circle-check"></i> Title Deed</span>
                                            <span class="m-req verified"><i class="oi oi-circle-check"></i> Collateral Valuation</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else if (ActiveTab == "payments")
                        {
                            <!-- Payments UI Mock -->
                            <div class="mock-payments">
                                <div class="mock-sec-header">
                                    <h4>Amortization Schedule</h4>
                                    <span class="m-chip success">Gira Iwawe #104</span>
                                </div>
                                <table class="mock-table font-dense">
                                    <thead>
                                        <tr>
                                            <th>Installment</th>
                                            <th>Due Date</th>
                                            <th>Principal</th>
                                            <th>Interest</th>
                                            <th>Paid</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>#1</td>
                                            <td>2026-08-01</td>
                                            <td>250,000</td>
                                            <td>12,500</td>
                                            <td>262,500</td>
                                            <td><span class="m-chip success">Paid</span></td>
                                        </tr>
                                        <tr>
                                            <td>#2</td>
                                            <td>2026-09-01</td>
                                            <td>250,000</td>
                                            <td>12,500</td>
                                            <td>0</td>
                                            <td><span class="m-chip danger">Past Due</span></td>
                                        </tr>
                                        <tr>
                                            <td>#3</td>
                                            <td>2026-10-01</td>
                                            <td>250,000</td>
                                            <td>12,500</td>
                                            <td>0</td>
                                            <td><span class="m-chip disabled">Unpaid</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="mock-waive-box">
                                    <h6>Request Late Fee Waiver</h6>
                                    <p>Late fee penalty outstanding: <strong>Rwf 5,000</strong></p>
                                    <button class="m-btn-small" disabled>Request Waiver Approval</button>
                                </div>
                            </div>
                        }
                        else if (ActiveTab == "reports")
                        {
                            <!-- Reports UI Mock -->
                            <div class="mock-reports">
                                <div class="mock-sec-header">
                                    <h4>Financial Reports</h4>
                                    <span class="m-btn-mini">Export PDF</span>
                                </div>
                                <div class="mock-grid-2">
                                    <div class="mock-ledger-card">
                                        <h5>Income vs Expenses</h5>
                                        <div class="m-ledger-item">
                                            <span>Interest Collections</span>
                                            <span class="text-success">+ Rwf 4,820,000</span>
                                        </div>
                                        <div class="m-ledger-item">
                                            <span>Processing Fees</span>
                                            <span class="text-success">+ Rwf 350,000</span>
                                        </div>
                                        <div class="m-ledger-item">
                                            <span>Operating Costs</span>
                                            <span class="text-danger">- Rwf 900,000</span>
                                        </div>
                                        <hr/>
                                        <div class="m-ledger-item font-bold">
                                            <span>Net Position</span>
                                            <span class="text-success">Rwf 4,270,000</span>
                                        </div>
                                    </div>
                                    <div class="mock-tenant-card">
                                        <h5>Branch Contribution</h5>
                                        <div class="m-branch">
                                            <span>Kigali Central</span>
                                            <div class="bar-progress"><span style="width: 70%;"></span></div>
                                        </div>
                                        <div class="m-branch">
                                            <span>Musanze Branch</span>
                                            <div class="bar-progress"><span style="width: 45%;"></span></div>
                                        </div>
                                        <div class="m-branch">
                                            <span>Huye Branch</span>
                                            <div class="bar-progress"><span style="width: 25%;"></span></div>
                                        </div>
