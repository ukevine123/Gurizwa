@using Application.DTO
@using Application.Services.Users
@using Application.Interfaces
@inject IIdentityService IdentityService
@inject IUserContext UserContext
@inject ISnackbar Snackbar

<MudDialog Style="overflow:hidden; max-width: 500px; width: 100%;">
    <DialogContent>
        <!-- ══════════ HEADER BANNER ══════════ -->
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #4318FF, #8F70FF);
                         padding:14px 18px; margin-bottom:16px; border-radius: 8px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.PersonAdd"
                         Style="color:white; font-size:1.6rem;" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700; line-height:1.2;">
                        Add New User
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new sub-user
                    </MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <!-- ══════════ FORM ══════════ -->
        <EditForm Model="@model" OnValidSubmit="OnValidSubmit">
            <DataAnnotationsValidator />
            
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudTextField @bind-Value="model.FirstName" 
                                  Label="First Name" 
                                  Required="true" 
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  For="@(() => model.FirstName)" />
                </MudItem>
                              
                <MudItem xs="6">
                    <MudTextField @bind-Value="model.LastName" 
                                  Label="Last Name" 
                                  Required="true" 
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  For="@(() => model.LastName)" />
                </MudItem>
                              
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.Email" 
                                  Label="Email" 
                                  Required="true" 
                                  InputType="InputType.Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  For="@(() => model.Email)" />
                </MudItem>
                              
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.PhoneNumber" 
                                  Label="Phone Number" 
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  For="@(() => model.PhoneNumber)" />
                </MudItem>
                              
                <MudItem xs="12">
                    <MudSelect T="string" 
                               Label="Roles" 
                               MultiSelection="true" 
                               @bind-SelectedValues="selectedRoles" 
                               Required="true" 
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense">
                        @if (availableRoles != null)
                        {
                            @foreach (var role in availableRoles)
                            {
                                <MudSelectItem T="string" Value="@role">@role</MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>
                              
                <MudItem xs="12">
                    <MudTextField @bind-Value="model.Password" 
                                  Label="Temporary Password" 
                                  Required="true" 
                                  InputType="@PasswordInput"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                 
                                  Adornment="Adornment.End" AdornmentIcon="@PasswordInputIcon"
                                  OnAdornmentClick="TogglePasswordVisibility"
                                  For="@(() => model.Password)" 
                                  Class="mb-2" />
                </MudItem>
            </MudGrid>

            <div class="d-flex justify-end mt-6">
                <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary" 
                           Class="ml-2" 
                           Disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <MudText Class="ms-2">Saving...</MudText>
                    }
                    else
                    {
                        <MudText>Create User</MudText>
                    }
                </MudButton>
            </div>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }

    private RegisterUserDTO model = new RegisterUserDTO 
    {
        DateOfBirth = DateTime.UtcNow,
        Role = "Staff"
    };
    private bool isSubmitting = false;
    private List<string> availableRoles;
    private IEnumerable<string> selectedRoles { get; set; } = new HashSet<string> { "Staff" };

    protected override async Task OnInitializedAsync()
    {
        if (UserContext.PersonId.HasValue)
        {
            availableRoles = await IdentityService.GetRolesAsync(UserContext.PersonId.Value);
        }
    }

    // Password visibility toggle
    private bool isShowPassword;
    private InputType PasswordInput = InputType.Password;
    private string PasswordInputIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        if (isShowPassword)
        {
            isShowPassword = false;
            PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            PasswordInput = InputType.Password;
        }
        else
        {
            isShowPassword = true;
            PasswordInputIcon = Icons.Material.Filled.Visibility;
            PasswordInput = InputType.Text;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task OnValidSubmit()
    {
        if (UserContext.PersonId == null)
        {
            Snackbar.Add("Error: Could not determine parent account.", Severity.Error);
            return;
        }

        try
        {
            isSubmitting = true;
            model.Role = string.Join(",", selectedRoles);
            await IdentityService.RegisterSubUser(model, UserContext.PersonId.Value);
            Snackbar.Add("User created successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
