@page "/ProvidedDocuments"
@using System.IO
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.ProvidedDocuments
@using Domain.ValueObjects
@using Application.Interfaces

@inject IProvidedDocumentService ProvidedDocumentService
@inject IProvidedDocument DocumentRepo
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Provided Document</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    @* 1. TOP TITLE AND SEARCH BAR *@
    <!-- <div class="d-flex align-center justify-space-between mb-6">
        <MudText Typo="Typo.h5" Style="font-weight: 800; color: #1B2559;">Provided Document</MudText>
    </div> -->

    @* 2. SEARCH AND FILTER ROW *@
    <MudGrid Class="mb-4" Spacing="2">

        <MudItem xs="12" Class="d-flex align-center justify-end gap-4">
            @if (_selectedItems.Any())
            {
                <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small"  />
                @* <MudIconButton Icon="@Icons.Material.Filled.Details" Size="Size.Small" /> *@
                <AuthorizeView Roles="Tenant">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"  />
                </AuthorizeView>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
            }
            <MudButton StartIcon="@Icons.Material.Filled.FilterList" Variant="Variant.Text">Filter</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Sort" Variant="Variant.Text">Sort by</MudButton>
     
        </MudItem>
    </MudGrid>

    @* 3. THE DATAGRID *@
    <MudDataGrid T="ProvidedDocument" Items="@_providedDocument" MultiSelection="true" @bind-SelectedItems="_selectedItems"
                 Hover="true" Elevation="0" Class="rounded-xl border-none">

                  <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">Provided Document</MudText>
            <MudSpacer />

            <MudMenu Label="Add Document"
                     Variant="Variant.Filled"
                     EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                     Color="Color.Primary">

                <MudMenuItem Icon="@Icons.Material.Filled.Add"
                             OnClick="OpenDialog">
                    Add
                </MudMenuItem>

                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">
                    Print
                </MudMenuItem>

            </MudMenu>
        </ToolBarContent>

          <ToolBarContent>
            @* <MudText Typo="Typo.h5" Color="Color.Primary">LoanApplication</MudText> *@
            <MudSpacer />
            <MudMenu Label="Upload" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.Upload" Color="Color.Primary">
                <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Add</MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Print</MudMenuItem>
            </MudMenu>
        </ToolBarContent>

  <Columns>
    <SelectColumn T="ProvidedDocument" />
    <HierarchyColumn T="ProvidedDocument" />
    
  
    <PropertyColumn Property="x => x.DocumentName" Title="Document Name" />

   

   
            <TemplateColumn Title="Action">
    <CellTemplate>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Class="mr-2" OnClick="@(() => ViewDocument(context.Item))">
            <MudIcon Icon="@Icons.Material.Filled.RemoveRedEye" Size="Size.Small" Class="mr-1" />
            View @context.Item.DocumentName
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" OnClick="@(() => ReplaceDocument(context.Item))">
            <MudIcon Icon="@Icons.Material.Filled.Autorenew" Size="Size.Small" Class="mr-1" />
            Replace
        </MudButton>
    </CellTemplate>
</TemplateColumn>


</Columns>
        
        <PagerContent>
            <MudDataGridPager T="ProvidedDocument" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
     private string _searchString = "";

    private IEnumerable<ProvidedDocument> FilteredBorrowers => _providedDocument
        .Where(x => string.IsNullOrWhiteSpace(_searchString) || 
                    
            x.DocumentName.Contains(_searchString, StringComparison.OrdinalIgnoreCase));
     //s
       List<ProvidedDocument> _providedDocument = new();
    private HashSet<ProvidedDocument> _selectedItems = new();

      protected override async Task OnInitializedAsync()
    {
         await LoadDocument();
         
    }
    private async Task OpenDialog()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };

        var dialog = await DialogService.ShowAsync<DocumentCreateDialog>("Add Application", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
             await LoadDocument();
        }
    }
     private async Task LoadDocument()
    {
        _providedDocument = await ProvidedDocumentService.GetAllProvidedDocumentAsync();
        StateHasChanged();
    }

    private async Task ViewDocument(ProvidedDocument doc)
    {
        var fullDoc = await ProvidedDocumentService.GetProvidedDocumentById(doc.Id);
        if (fullDoc?.DocumentFile == null || fullDoc.DocumentFile.Length == 0)
        {
            Snackbar.Add("File is empty.", Severity.Error);
            return;
        }

        byte[] fileData = fullDoc.DocumentFile;
        try 
        {
            string possibleString = System.Text.Encoding.UTF8.GetString(fileData);
            if (possibleString.Contains("base64,"))
            {
                var base64Data = possibleString.Split(',')[1];
                fileData = Convert.FromBase64String(base64Data);
            }
            else 
            {
                Span<byte> buffer = new Span<byte>(new byte[possibleString.Length]);
                if (Convert.TryFromBase64String(possibleString.Trim(), buffer, out int bytesParsed))
                {
                    fileData = buffer.Slice(0, bytesParsed).ToArray();
                }
            }
        } 
        catch { }

        string mimeType = GetMimeType(fileData);
        string base64 = Convert.ToBase64String(fileData);
        string url = $"data:{mimeType};base64,{base64}";

        var parameters = new DialogParameters 
        { 
            ["Url"] = url, 
            ["MimeType"] = mimeType,
            ["FileName"] = doc.DocumentName 
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        DialogService.Show<DocumentViewerDialog>(doc.DocumentName ?? "View Document", parameters, options);
    }


private string GetMimeType(byte[] fileData)
{
    if (fileData == null || fileData.Length < 4)
        return "application/octet-stream";

    // PDF
    if (fileData[0] == 0x25 && fileData[1] == 0x50 && fileData[2] == 0x44 && fileData[3] == 0x46)
        return "application/pdf";
    
    // PNG
    if (fileData[0] == 0x89 && fileData[1] == 0x50 && fileData[2] == 0x4E && fileData[3] == 0x47)
        return "image/png";
    
    // JPEG
    if (fileData[0] == 0xFF && fileData[1] == 0xD8 && fileData[2] == 0xFF)
        return "image/jpeg";
    
    // GIF
    if (fileData[0] == 0x47 && fileData[1] == 0x49 && fileData[2] == 0x46 && fileData[3] == 0x38)
        return "image/gif";

    return "application/octet-stream";
}
    private async Task ReplaceDocument(ProvidedDocument doc)
    {
        try
        {
            await DocumentRepo.DeleteProvidedDocumentAsync(doc.Id);
            Snackbar.Add("Document deleted. Please upload a replacement.", Severity.Info);
            await LoadDocument();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error replacing document: {ex.Message}", Severity.Error);
        }
    }

    private string GetIcon(string fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName)) return Icons.Custom.FileFormats.FileDocument;
        
        var ext = Path.GetExtension(fileName).ToLower();
        return ext switch
        {
            ".pdf" => Icons.Custom.FileFormats.FilePdf,
            ".xlsx" or ".xls" => Icons.Custom.FileFormats.FileExcel,
            ".docx" or ".doc" => Icons.Custom.FileFormats.FileWord,
            ".png" or ".jpg" or ".jpeg" => Icons.Custom.FileFormats.FileImage,
            _ => Icons.Material.Filled.AttachFile
        };
    }
        
     }  

   

     


