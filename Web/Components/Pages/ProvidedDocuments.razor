@page "/ProvidedDocuments"
@using System.IO
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.ProvidedDocuments
@using Domain.ValueObjects
@using Application.Interfaces

@inject IProvidedDocumentService ProvidedDocumentService
@inject IProvidedDocument DocumentRepo
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Provided Documents</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    @* SEARCH & HEADER ROW *@
    <MudGrid Class="mb-4" Spacing="2">

        <MudItem xs="12" Class="d-flex align-center justify-end gap-4">
            @if (_selectedItems.Any())
            {
                <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small"  />
                @* <MudIconButton Icon="@Icons.Material.Filled.Details" Size="Size.Small" /> *@
                <AuthorizeView Roles="Tenant">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"  />
                </AuthorizeView>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
            }
            <MudButton StartIcon="@Icons.Material.Filled.FilterList" Variant="Variant.Text">Filter</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Sort" Variant="Variant.Text">Sort by</MudButton>
     
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Search by application code or borrower name..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium"
                          Immediate="true"
                          Class="mt-0"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="6" Class="d-flex align-center justify-end gap-2">
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenDialog">
                Upload Document
            </MudButton>
        </MudItem>
    </MudGrid>

    @* THE DATAGRID - GROUPED BY LOAN APPLICATION *@
    <MudDataGrid T="LoanAppGroup" Items="@FilteredGroups"
                 Hover="true" Elevation="0" Class="rounded-xl border-none">

        <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 800;">Loan Application Documents</MudText>
            <MudSpacer />
        </ToolBarContent>

        <Columns>
            @* Application Code Column *@
            <TemplateColumn Title="Application Code" SortBy="x => x.ApplicationCode">
                <CellTemplate>
                    <MudChip T="string" Color="Color.Info" Style="font-weight: 700;">
                        @context.Item.ApplicationCode
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            @* Business Name / Applicant Column *@
            <TemplateColumn Title="Business / Applicant Name" SortBy="x => x.BusinessName">
                <CellTemplate>
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2" Style="font-weight: 700; color: #1B2559;">@context.Item.BusinessName</MudText>
                        @if (!string.IsNullOrEmpty(context.Item.ContactPerson) && context.Item.ContactPerson != context.Item.BusinessName)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Contact: @context.Item.ContactPerson</MudText>
                        }
                    </div>
                </CellTemplate>
            </TemplateColumn>

            @* Total Documents Count Column *@
            <TemplateColumn Title="Documents Count" SortBy="x => x.DocumentCount">
                <CellTemplate>
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">
                        @context.Item.DocumentCount Document(s)
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            @* Document Names Summary Column *@
            <!-- <TemplateColumn Title="Attached Documents">
                <CellTemplate>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var doc in context.Item.Documents.Take(3))
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                                @doc.DocumentName
                            </MudChip>
                        }
                        @if (context.Item.Documents.Count > 3)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Secondary">
                                +@(context.Item.Documents.Count - 3) more
                            </MudChip>
                        }
                    </div>
                </CellTemplate>
            </TemplateColumn> -->

            @* Action Column *@
            <TemplateColumn Title="Action" Style="text-align: right;">
                <CellTemplate>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.FolderOpen" OnClick="@(() => OpenAllAppDocuments(context.Item.LoanApplicationId, context.Item.ApplicationCode, context.Item.BusinessName))">
                        View All Documents
                    </MudButton>
                </CellTemplate>
            </TemplateColumn>

        </Columns>
        
        <PagerContent>
            <MudDataGridPager T="LoanAppGroup" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private string _searchString = "";
    private List<LoanAppGroup> _appGroups = new();

    public class LoanAppGroup
    {
        public int LoanApplicationId { get; set; }
        public string ApplicationCode { get; set; } = "";
        public string BusinessName { get; set; } = "";
        public string ContactPerson { get; set; } = "";
        public int DocumentCount { get; set; }
        public List<ProvidedDocument> Documents { get; set; } = new();
    }

    private IEnumerable<LoanAppGroup> FilteredGroups => _appGroups
        .Where(x => string.IsNullOrWhiteSpace(_searchString) || 
                    (x.ApplicationCode != null && x.ApplicationCode.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.BusinessName != null && x.BusinessName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    (x.ContactPerson != null && x.ContactPerson.Contains(_searchString, StringComparison.OrdinalIgnoreCase)) ||
                    x.Documents.Any(d => d.DocumentName != null && d.DocumentName.Contains(_searchString, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await LoadDocument();
    }

    private async Task OpenDialog()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };
        var dialog = await DialogService.ShowAsync<DocumentCreateDialog>("Add Document", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadDocument();
        }
    }

    private async Task LoadDocument()
    {
        var rawDocs = await ProvidedDocumentService.GetAllProvidedDocumentAsync();
        
        _appGroups = rawDocs
            .GroupBy(d => d.LoanApplicationId)
            .Select(g => {
                var first = g.First();
                var appCode = first.LoanApplication?.ApplicationCode;
                if (string.IsNullOrWhiteSpace(appCode))
                {
                    appCode = g.Key > 0 ? $"#APP-{g.Key}" : "General Documents";
                }
                
                string bName = "";
                string contact = "";

                // 1. Try LoanApplication -> Borrower
                if (first.LoanApplication?.Borrower != null)
                {
                    var b = first.LoanApplication.Borrower;
                    bName = !string.IsNullOrWhiteSpace(b.CompanyName) ? b.CompanyName : $"{b.FirstName} {b.LastName}".Trim();
                    contact = !string.IsNullOrWhiteSpace(b.ContactPersonName) ? b.ContactPersonName : $"{b.FirstName} {b.LastName}".Trim();
                }
                
                // 2. Try LoanApplication -> Person
                if (string.IsNullOrWhiteSpace(bName) && first.LoanApplication?.Person != null)
                {
                    var p = first.LoanApplication.Person;
                    bName = !string.IsNullOrWhiteSpace(p.CompanyName) ? p.CompanyName : $"{p.FirstName} {p.LastName}".Trim();
                    contact = !string.IsNullOrWhiteSpace(p.ContactPerson) ? p.ContactPerson : $"{p.FirstName} {p.LastName}".Trim();
                }

                // 3. Try ProvidedDocument -> Person
                if (string.IsNullOrWhiteSpace(bName) && first.Person != null)
                {
                    var p = first.Person;
                    bName = !string.IsNullOrWhiteSpace(p.CompanyName) ? p.CompanyName : $"{p.FirstName} {p.LastName}".Trim();
                    contact = !string.IsNullOrWhiteSpace(p.ContactPerson) ? p.ContactPerson : $"{p.FirstName} {p.LastName}".Trim();
                }

                if (string.IsNullOrWhiteSpace(bName)) bName = "N/A";

                return new LoanAppGroup
                {
                    LoanApplicationId = g.Key,
                    ApplicationCode = appCode,
                    BusinessName = bName,
                    ContactPerson = contact,
                    DocumentCount = g.Count(),
                    Documents = g.ToList()
                };
            })
            .ToList();

        StateHasChanged();
    }

    private async Task OpenAllAppDocuments(int loanApplicationId, string applicationCode, string businessName)
    {
        var parameters = new DialogParameters
        {
            ["LoanApplicationId"] = loanApplicationId,
            ["ApplicationCode"] = applicationCode,
            ["BusinessName"] = businessName
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        var dialog = DialogService.Show<ApplicationDocumentsDialog>("Application Documents", parameters, options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadDocument();
        }
    }
}
