@using Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces

@using Application.Services.ProcessFeeDeposits
@using Application.Services.LoanApplications
@using Application.Services.Accounts
@using Domain.ValueObjects
@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization

@inject NavigationManager Navigation
@inject IProcessFeeDepositService ProcessFeeDepositService
@inject ILoanApplicationService LoanApplicationService
@inject IAccountService AccountService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog Style="overflow:hidden;">
    <DialogContent>
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #5a55e6 0%, #f7f9f8 100%); padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Style="color:white; font-size:1.6rem;" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Style="color:white; font-weight:700; line-height:1.2;">
                        Create Guarantor
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new Guarantor
                    </MudText> 
                </MudStack>
            </MudStack>
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreateGuarantorForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudGrid Spacing="1" Class="align-items-center">
                <MudItem xs="6"> 
                    <MudSelect T="int"
                               Label="LoanApplication"
                               Placeholder="--Select Loan Type--"
                               @bind-Value="Model.LoanApplicationId"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                               AdornmentIcon="@Icons.Material.Filled.Category"
                               AdornmentColor="Color.Primary">
                        <MudSelectItem Value="0">--Select Loan --</MudSelectItem>
                       @if (loanApplications != null)
                        {
                            foreach (var app in loanApplications)
                            {
                               <MudSelectItem T="int" Value="@app.Id"> @app.ApplicationCode </MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6">
                    <MudTextField Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="Model.Amount" For="@(() => Model.Amount)" />
                </MudItem>
                          
                <MudItem xs="12">
                    <MudSelect T="int"
                               Label="Account "
                               Placeholder="--Select Account --"
                               @bind-Value="Model.AccountId"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                               AdornmentIcon="@Icons.Material.Filled.Category"
                               AdornmentColor="Color.Primary">
                        <MudSelectItem Value="0">--Select Account --</MudSelectItem>
                        @if (accountN != null)
                        {
                            foreach (var account in accountN)
                            {
                                <MudSelectItem T="int" Value="@account.Id">@account.Name</MudSelectItem>
                            }
                        }
                    </MudSelect> 
                </MudItem>           

                <MudItem xs="6"> 
                    <MudDatePicker Label="Deposited Date" @bind-Value="Model.DepositDate" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentColor="Color.Primary" />
                </MudItem>
                 <MudItem xs="6">
                    <MudTextField Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="Model.Status" For="@(() => Model.Status)" />
                </MudItem>

                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" FullWidth="true" ButtonType="ButtonType.Submit" Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px;">
                        save
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

    [SupplyParameterFromForm(Name = "CreateProcessFeeDepositForm")]
    private CreateProcessFeeDepositDTO Model { get; set; } = new();
    private string ErrorMessage { get; set; }

    [Parameter] public bool IsReadOnly { get; set; } = false;

    public Sex sex { get; set; }
    private List<Account> accountN = new();
    private List<LoanApplication> loanApplications = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Load Loan Application
            var loans = await LoanApplicationService.GetAllLoanApplicationsAsync();
            if (loans != null)
            {
                loanApplications = loans;
            }

            // 2. Load Guarantor Types
            var accounts = await AccountService.GetAllAccountsAsync();
            if (accounts != null)
            {
                accountN = accounts;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading initial data", Severity.Error);
            ErrorMessage = ex.Message;
        }
    }


    private async Task onValidSubmit()
    {
        try
        {
            await ProcessFeeDepositService.CreateProcessFeeDepositAsync(Model);
            Snackbar.Add("Process fee deposit created successfully!", Severity.Info);
            MudDialog.Close(DialogResult.Ok(Model));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
}