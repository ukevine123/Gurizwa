@using Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces

@using Application.Services.ProcessFeeDeposits
@using Application.Services.Disbursements
@using Application.Services.LoanApplications
@using Application.Services.Accounts
@using Domain.ValueObjects
@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization

@inject NavigationManager Navigation
@inject IProcessFeeDepositService ProcessFeeDepositService
@inject ILoanApplicationService LoanApplicationService
@inject IAccountService AccountService
@inject IDisbursementService DisbursementService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog Style="overflow:hidden;">
    <DialogContent>
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #4318FF); padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Style="color:white; font-size:1.6rem;" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Style="color:white; font-weight:700; line-height:1.2;">
                        Create Process Fee Deposit  
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new Process Fee Deposit
                    </MudText> 
                </MudStack>
            </MudStack>
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreateGuarantorForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudGrid Spacing="1" Class="align-items-center">
                <MudItem xs="12"> 
                    <MudSelect T="int"
                               Label="Loan Application"
                               Placeholder="--Select Loan --"
                               Value="Model.LoanApplicationId"
                               ValueChanged="OnLoanApplicationChanged"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                              
                              >
                        <MudSelectItem Value="0">--Select Loan --</MudSelectItem>
                       @if (loanApplications != null)
                        {
                            foreach (var app in loanApplications)
                            {
                               <MudSelectItem T="int" Value="@app.Id"> @app.ApplicationCode </MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6">
                    <MudNumericField T="decimal" Label="Percentage Rate (%)" Variant="Variant.Outlined" Margin="Margin.Dense" Value="Percentage" ValueChanged="OnPercentageChanged" />
                </MudItem>

                <MudItem xs="6">
                    <MudNumericField T="decimal" Label="Amount" Variant="Variant.Outlined" Margin="Margin.Dense" @bind-Value="Model.Amount" For="@(() => Model.Amount)" />
                </MudItem>
                          
                <MudItem xs="12">
                    <MudSelect T="int"
                               Label="Account "
                               Placeholder="--Select Account --"
                               @bind-Value="Model.AccountId"
                               Variant="Variant.Outlined"
                               Dense="true"
                               Margin="Margin.Dense"
                              
                              >
                        <MudSelectItem Value="0">--Select Account --</MudSelectItem>
                        @if (accountN != null)
                        {
                            foreach (var account in accountN)
                            {
                                <MudSelectItem T="int" Value="@account.Id">@account.Name</MudSelectItem>
                            }
                        }
                    </MudSelect> 
                </MudItem>           

                <MudItem xs="12"> 
                    <MudDatePicker ShowToolbar="false" Label="Deposited Date" DateFormat="yyyy-MM-dd" @bind-Value="Model.DepositDate" Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" FullWidth="true" ButtonType="ButtonType.Submit" Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px;">
                        save
                    </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; }

    [SupplyParameterFromForm(Name = "CreateProcessFeeDepositForm")]
    private CreateProcessFeeDepositDTO Model { get; set; } = new();
    private string ErrorMessage { get; set; }

    [Parameter] public bool IsReadOnly { get; set; } = false;

    public Sex sex { get; set; }
    private List<Account> accountN = new();
    private List<LoanApplication> loanApplications = new();
    private List<Disbursement> disbursements = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. Load Loan Application
            var loans = await LoanApplicationService.GetAllLoanApplicationsAsync();
            if (loans != null)
            {
                loanApplications = loans.Where(l => l.Status == LoanStatus.Approved).ToList();
            }

            // 2. Load Guarantor Types (Accounts)
            var accounts = await AccountService.GetAllAccountsAsync();
            if (accounts != null)
            {
                accountN = accounts;
            }
            
            // 3. Load Disbursements
            var disbs = await DisbursementService.GetAllDisbursementsAsync();
            if (disbs != null)
            {
                disbursements = disbs;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error loading initial data", Severity.Error);
            ErrorMessage = ex.Message;
        }
    }


    private async Task onValidSubmit()
    {
        try
        {
            await ProcessFeeDepositService.CreateProcessFeeDepositAsync(Model);
            Snackbar.Add("Process fee deposit created successfully!", Severity.Info);
            MudDialog.Close(DialogResult.Ok(Model));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }

    private decimal Percentage { get; set; } = 0;

    private void OnLoanApplicationChanged(int loanId)
    {
        Model.LoanApplicationId = loanId;
        var selectedLoan = loanApplications.FirstOrDefault(l => l.Id == loanId);
        if (selectedLoan != null && selectedLoan.LoanProductSetting != null)
        {
            // Default to 0, let the user set it manually
            Percentage = 0;
            CalculateAmount();
        }
        else
        {
            Model.Amount = 0;
        }
    }

    private void OnPercentageChanged(decimal newPercentage)
    {
        Percentage = newPercentage;
        CalculateAmount();
    }

    private void CalculateAmount()
    {
        if (Model.LoanApplicationId > 0)
        {
            var selectedLoan = loanApplications.FirstOrDefault(l => l.Id == Model.LoanApplicationId);
            if (selectedLoan != null)
            {
                Model.Amount = selectedLoan.AmountRequested * (Percentage / 100m);
            }
            else
            {
                Model.Amount = 0;
            }
        }
    }
}

