
@using Application.Interfaces
@using Domain.Entities

@using Domain.ValueObjects
@using Application.Services.Accounts
@using System.Globalization

@inject NavigationManager NavigationManager

 <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="BackToAccounts" StartIcon="@Icons.Material.Filled.ArrowBack">
                    Back to List
                </MudButton>
<MudDialog>
    
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2"/> Account Details
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_accounts == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Account ID</MudText>
                    <MudText Typo="Typo.body1">@_accounts.Id</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Name</MudText>
                    <MudText Typo="Typo.body1">@_accounts.Name</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Provider</MudText>
                    <MudText Typo="Typo.body1">@_accounts.Provider</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">AccountNumber</MudText>
                    <MudText Typo="Typo.body1">@_accounts.AccountNumber</MudText>
                </MudItem>
               
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Balance</MudText>
                    <MudText Typo="Typo.body1">@_accounts.Balance</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Currency</MudText>
                    <MudText Typo="Typo.body1">@_accounts.Currency</MudText>
                </MudItem>
              
                    @* <MudItem xs="6">
                        <MudTextField Label="Account Type" Value="@_accounts.AccountType" ReadOnly Variant="Variant.Outlined" />
                </MudItem>  *@
              
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public int Id { get; set; } 
    
    [Inject] IAccountService AccountService { get; set; }

    private Account _accounts;

    protected override async Task OnInitializedAsync()
    {
        _accounts = await AccountService.GetAccountByIdAsync(Id);
    }
    private void Close() => MudDialog.Close();
     private void BackToAccounts()
    {
        NavigationManager.NavigateTo("/Accounts");
    }
}
