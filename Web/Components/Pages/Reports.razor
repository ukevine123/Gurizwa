@page "/Reports"
@using Application.DTO
@using Application.Interfaces
@using MudBlazor

@inject IReportService ReportService
@inject ISnackbar Snackbar
@inject IUserContext UserContext
@inject IIdentity IdentityService
@inject IExportService ExportService
@inject IJSRuntime JSRuntime

<PageTitle>Portfolio Reports</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h4" Color="MudBlazor.Color.Primary" Class="mb-6">Portfolio Reports</MudText>

    @* Overview Dashboard Cards - Acting as shortcuts *@
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("ActiveLoans")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-purple">
                        <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Active Loans</div>
                <div class="rc-desc">Overview of @_activeLoans.Count active loans and their balances</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("ActiveLoans", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("ActiveLoans", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("ActiveLoans", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("Disbursements")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-blue">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Disbursements</div>
                <div class="rc-desc">Detailed breakdown of @_disbursements.Count loan disbursements</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("Disbursements", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("Disbursements", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("Disbursements", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("MaturityTracker")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-green">
                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Maturity Tracker</div>
                <div class="rc-desc">Track @_maturities.Count loans reaching maturity dates</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("MaturityTracker", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("MaturityTracker", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("MaturityTracker", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("UserActivities")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-yellow">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">User Activities</div>
                <div class="rc-desc">Performance insights for @(_activities.Select(a => a.UserName).Distinct().Count()) active users</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("UserActivities", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("UserActivities", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("UserActivities", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
    </MudGrid>
    
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("RepaymentSchedules")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-pink">
                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Repayment Schedules</div>
                <div class="rc-desc">Health scores and @_repaymentSchedules.Count repayment schedules</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("RepaymentSchedules", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("RepaymentSchedules", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("RepaymentSchedules", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("OverdueLoans")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-red">
                        <MudIcon Icon="@Icons.Material.Filled.Warning" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Overdue Loans</div>
                <div class="rc-desc">High level KPI summary for @_overdues.Count overdue loans</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("OverdueLoans", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("OverdueLoans", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("OverdueLoans", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("CustomerPortfolios")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-cyan">
                        <MudIcon Icon="@Icons.Material.Filled.ContactPage" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Customer Portfolios</div>
                <div class="rc-desc">Detailed overview of @_customerPortfolios.Count customer portfolios</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("CustomerPortfolios", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("CustomerPortfolios", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("CustomerPortfolios", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("ApplicationStatuses")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-lightgreen">
                        <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Application Statuses</div>
                <div class="rc-desc">Analyze pipeline metrics for @_applicationStatuses.Count applications</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("ApplicationStatuses", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("ApplicationStatuses", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("ApplicationStatuses", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("UpcomingDues")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-purple">
                        <MudIcon Icon="@Icons.Material.Filled.NotificationImportant" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Upcoming Dues</div>
                <div class="rc-desc">Filter upcoming dues by 5 or 7 days</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("UpcomingDues", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("UpcomingDues", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("UpcomingDues", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <div class="report-card cursor-pointer" @onclick='() => SetActiveReport("IncomeStatement")'>
                <div class="rc-header">
                    <div class="rc-icon-box bg-green">
                        <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Size="MudBlazor.Size.Small" Style="color: white;" />
                    </div>
                    <MudIcon Icon="@Icons.Material.Outlined.StarBorder" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
                <div class="rc-title">Income Statement</div>
                <div class="rc-desc">Portfolio P&L summary and operating expenses</div>
                <div class="rc-meta">Live updates</div>
                <div class="rc-footer">
                    <div class="rc-exports">
                        <span class="export-btn text-pdf" @onclick:stopPropagation="true" @onclick='() => Export("IncomeStatement", "pdf")'><MudIcon Icon="@Icons.Material.Filled.PictureAsPdf" Size="MudBlazor.Size.Small" Class="mr-1" /> PDF</span>
                        <span class="export-btn text-xlsx" @onclick:stopPropagation="true" @onclick='() => Export("IncomeStatement", "xlsx")'><MudIcon Icon="@Icons.Material.Filled.TableChart" Size="MudBlazor.Size.Small" Class="mr-1" /> XLSX</span>
                        <span class="export-btn text-word" style="color:#2B579A" @onclick:stopPropagation="true" @onclick='() => Export("IncomeStatement", "doc")'><MudIcon Icon="@Icons.Material.Filled.Article" Size="MudBlazor.Size.Small" Class="mr-1" /> WORD</span>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.MoreHoriz" Size="MudBlazor.Size.Small" Style="color: #6B7280;" />
                </div>
            </div>
        </MudItem>
    </MudGrid>

    <style>
        .cursor-pointer:hover {
            cursor: pointer;
        }
        .report-card {
            background-color: var(--mud-palette-surface);
            border: 1px solid var(--mud-palette-lines-default);
            border-radius: 12px;
            padding: 20px;
            color: var(--mud-palette-text-primary);
            transition: transform 0.2s, box-shadow 0.2s;
            display: flex;
            flex-direction: column;
            height: 100%;
        }
        .report-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.1);
            border-color: var(--mud-palette-primary);
        }
        .rc-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 16px;
        }
        .rc-icon-box {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .rc-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--mud-palette-text-primary);
        }
        .rc-desc {
            font-size: 13px;
            color: var(--mud-palette-text-secondary);
            margin-bottom: 16px;
            line-height: 1.4;
            flex-grow: 1;
        }
        .rc-meta {
            font-size: 12px;
            color: var(--mud-palette-text-secondary);
            margin-bottom: 16px;
        }
        .rc-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .rc-exports {
            display: flex;
            gap: 12px;
        }
        .export-btn {
            display: flex;
            align-items: center;
            font-size: 12px;
            font-weight: 600;
        }
        .text-pdf { color: #F87171; }
        .text-xlsx { color: #34D399; }
        .bg-purple { background-color: #8B5CF6; }
        .bg-blue { background-color: #3B82F6; }
        .bg-green { background-color: #10B981; }
        .bg-yellow { background-color: #F59E0B; }
        .bg-pink { background-color: #EC4899; }
        .bg-red { background-color: #EF4444; }
        .bg-cyan { background-color: #06B6D4; }
        .bg-lightgreen { background-color: #84CC16; }
    </style>

    @if (_activeReport == "ActiveLoans")
    {
        <MudDataGrid T="ActiveLoanSummaryDTO" Items="@_activeLoans" Hover="true" Bordered="false" Striped="true" QuickFilter="@_activeLoanFilter">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Active Loans Summary</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_activeLoanSearch" Placeholder="Search Borrower or Code..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.ApplicationCode" Title="Code" />
                <PropertyColumn Property="x => x.BorrowerName" Title="Borrower" />
                <PropertyColumn Property="x => x.PrincipalBalance" Title="Balance" Format="N2" />
                <PropertyColumn Property="x => x.InterestRate" Title="Rate (%)" />
                <PropertyColumn Property="x => x.TenureMonths" Title="Tenure (Months)" />
                <PropertyColumn Property="x => x.StartDate" Title="Start Date" Format="yyyy-MM-dd" />
                <PropertyColumn Property="x => x.EndDate" Title="Maturity Date" Format="yyyy-MM-dd" />
            </Columns>
            <PagerContent>
                <MudDataGridPager T="ActiveLoanSummaryDTO" />
            </PagerContent>
        </MudDataGrid>
    }
    else if (_activeReport == "Disbursements")
    {
        <MudPaper Class="pa-4 mb-4" Elevation="0">
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudDateRangePicker Label="Disbursement Period" @bind-DateRange="_disbursementRange" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_loanTypeFilter" Label="Loan Type" Placeholder="e.g. Personal" />
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="LoadDisbursementReport" StartIcon="@Icons.Material.Filled.Refresh">Generate Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudDataGrid T="LoanDisbursementReportDTO" Items="@_disbursements" Hover="true" Striped="true" QuickFilter="@_disbursementFilter">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Loan Disbursement Report</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_disbursementSearch" Placeholder="Search type, branch, officer..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.ApplicationCode" Title="Code" />
                <PropertyColumn Property="x => x.BorrowerName" Title="Borrower" />
                <PropertyColumn Property="x => x.AmountDisbursed" Title="Amount" Format="N2" />
                <PropertyColumn Property="x => x.LoanType" Title="Type" />
                <PropertyColumn Property="x => x.Branch" Title="Branch" />
                <PropertyColumn Property="x => x.Officer" Title="Officer" />
                <PropertyColumn Property="x => x.DisbursementDate" Title="Date" Format="yyyy-MM-dd" />
            </Columns>
            <PagerContent>
                <MudDataGridPager T="LoanDisbursementReportDTO" />
            </PagerContent>
        </MudDataGrid>
    }
    else if (_activeReport == "MaturityTracker")
    {
        <MudPaper Class="pa-4 mb-4" Elevation="0">
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudDateRangePicker Label="Maturity Period" @bind-DateRange="_maturityRange" />
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="LoadMaturityReport" StartIcon="@Icons.Material.Filled.Refresh">Generate Report</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudDataGrid T="LoanMaturityReportDTO" Items="@_maturities" Hover="true" Striped="true">
            <ToolBarContent>
                <MudText Typo="Typo.h6">Loan Maturity Report</MudText>
            </ToolBarContent>
            <Columns>
