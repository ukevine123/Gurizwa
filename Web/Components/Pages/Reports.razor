@page "/Reports"
@using Application.DTO
@using ApexCharts
@using Application.Interfaces
@using MudBlazor

@inject IReportService ReportService
@inject ISnackbar Snackbar

<PageTitle>Portfolio Reports</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h4" Color="MudBlazor.Color.Primary" Class="mb-6">Portfolio Reports</MudText>

    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" Position="Position.Left">
        
        @* 1. LOAN PORTFOLIO *@
        <MudTabPanel Text="1. Loan Portfolio" Icon="@Icons.Material.Filled.FolderShared">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        
        @* 1. ACTIVE LOANS SUMMARY *@
        <MudTabPanel Text="Active Loans" Icon="@Icons.Material.Filled.Assignment">
            <MudDataGrid T="ActiveLoanSummaryDTO" Items="@_activeLoans" Hover="true" Bordered="false" Striped="true" QuickFilter="@_activeLoanFilter">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Active Loans Summary</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_activeLoanSearch" Placeholder="Search Borrower or Code..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.ApplicationCode" Title="Code" />
                    <PropertyColumn Property="x => x.BorrowerName" Title="Borrower" />
                    <PropertyColumn Property="x => x.PrincipalBalance" Title="Balance" Format="N2" />
                    <PropertyColumn Property="x => x.InterestRate" Title="Rate (%)" />
                    <PropertyColumn Property="x => x.TenureMonths" Title="Tenure (Months)" />
                    <PropertyColumn Property="x => x.StartDate" Title="Start Date" Format="yyyy-MM-dd" />
                    <PropertyColumn Property="x => x.EndDate" Title="Maturity Date" Format="yyyy-MM-dd" />
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="ActiveLoanSummaryDTO" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>

        @* 2. LOAN DISBURSEMENT REPORT *@
        <MudTabPanel Text="Disbursements" Icon="@Icons.Material.Filled.Payments">
            <MudPaper Class="pa-4 mb-4" Elevation="0">
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudDateRangePicker Label="Disbursement Period" @bind-DateRange="_disbursementRange" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_loanTypeFilter" Label="Loan Type" Placeholder="e.g. Personal" />
                    </MudItem>
                    <MudItem xs="12" sm="4" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="LoadDisbursementReport" StartIcon="@Icons.Material.Filled.Refresh">Generate Report</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudDataGrid T="LoanDisbursementReportDTO" Items="@_disbursements" Hover="true" Striped="true" QuickFilter="@_disbursementFilter">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Loan Disbursement Report</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_disbursementSearch" Placeholder="Search type, branch, officer..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.ApplicationCode" Title="Code" />
                    <PropertyColumn Property="x => x.BorrowerName" Title="Borrower" />
                    <PropertyColumn Property="x => x.AmountDisbursed" Title="Amount" Format="N2" />
                    <PropertyColumn Property="x => x.LoanType" Title="Type" />
                    <PropertyColumn Property="x => x.Branch" Title="Branch" />
                    <PropertyColumn Property="x => x.Officer" Title="Officer" />
                    <PropertyColumn Property="x => x.DisbursementDate" Title="Date" Format="yyyy-MM-dd" />
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="LoanDisbursementReportDTO" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>

        @* 3. LOAN MATURITY REPORT *@
        <MudTabPanel Text="Maturity" Icon="@Icons.Material.Filled.Event">
             <MudPaper Class="pa-4 mb-4" Elevation="0">
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudDateRangePicker Label="Maturity Period" @bind-DateRange="_maturityRange" />
                    </MudItem>
                    <MudItem xs="12" sm="4" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="LoadMaturityReport" StartIcon="@Icons.Material.Filled.Refresh">Generate Report</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudDataGrid T="LoanMaturityReportDTO" Items="@_maturities" Hover="true" Striped="true">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Loan Maturity Report</MudText>
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.ApplicationCode" Title="Code" />
                    <PropertyColumn Property="x => x.BorrowerName" Title="Borrower" />
                    <PropertyColumn Property="x => x.MaturityDate" Title="Maturity Date" Format="yyyy-MM-dd" />
                    <PropertyColumn Property="x => x.RemainingBalance" Title="Remaining Balance" Format="N2" />
                    <TemplateColumn Title="Status">
                        <CellTemplate>
                            <MudChip T="string" Color="@(context.Item.Status == "Matured" ? MudBlazor.Color.Error : MudBlazor.Color.Info)" Size="MudBlazor.Size.Small">@context.Item.Status</MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="LoanMaturityReportDTO" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>

        @* 4. USER ACTIVITY REPORT *@
        <MudTabPanel Text="User Activity" Icon="@Icons.Material.Filled.History">
            <MudPaper Class="pa-6 mb-6 rounded-xl" Elevation="0" Style="background: rgba(255, 255, 255, 0.4); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.2);">
                <MudGrid>
                    <MudItem xs="12" sm="4">
                        <MudDateRangePicker Label="Activity Period" @bind-DateRange="_activityRange" Class="rounded-lg" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField @bind-Value="_activityUserSearch"
                                      Label="User Name"
                                      Placeholder="Search by user name"
                                      Immediate="true"
                                      Adornment="Adornment.Start"
                                      AdornmentIcon="@Icons.Material.Filled.PersonSearch" />
                    </MudItem>
                    <MudItem xs="12" sm="4" Class="d-flex align-end">
                        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="LoadActivityReport" StartIcon="@Icons.Material.Filled.Refresh" Class="rounded-lg px-6 py-3" Style="text-transform: none; font-weight: 600;">Generate Report</MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @* Quick Metrics *@
            <MudGrid Class="mb-6" Spacing="3">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center gap-4" Elevation="1">
                        <div class="pa-3 rounded-lg" style="background: var(--mud-palette-primary-hover); color: var(--mud-palette-primary);">
                            <MudIcon Icon="@Icons.Material.Filled.Leaderboard" Size="MudBlazor.Size.Medium" />
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">Total Logs</MudText>
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@_activities.Count</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center gap-4" Elevation="1">
                        <div class="pa-3 rounded-lg" style="background: rgba(46, 204, 113, 0.15); color: #2ecc71;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="MudBlazor.Size.Medium" />
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">Approvals</MudText>
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@_activities.Count(a => a.Action.Contains("Approval", StringComparison.OrdinalIgnoreCase) || a.Action.Contains("Disbursed", StringComparison.OrdinalIgnoreCase))</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center gap-4" Elevation="1">
                        <div class="pa-3 rounded-lg" style="background: rgba(241, 196, 15, 0.15); color: #f1c40f;">
                            <MudIcon Icon="@Icons.Material.Filled.Edit" Size="MudBlazor.Size.Medium" />
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">Edits & Updates</MudText>
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@_activities.Count(a => a.Action.Contains("Edited", StringComparison.OrdinalIgnoreCase) || a.Action.Contains("Rescheduled", StringComparison.OrdinalIgnoreCase) || a.Action.Contains("Updated", StringComparison.OrdinalIgnoreCase))</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 rounded-xl d-flex align-center gap-4" Elevation="1">
                        <div class="pa-3 rounded-lg" style="background: rgba(231, 76, 60, 0.15); color: #e74c3c;">
                            <MudIcon Icon="@Icons.Material.Filled.DeleteForever" Size="MudBlazor.Size.Medium" />
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">Deletions</MudText>
                            <MudText Typo="Typo.h6" Style="font-weight: 700;">@_activities.Count(a => a.Action.Contains("Deleted", StringComparison.OrdinalIgnoreCase) || a.Action.Contains("Removed", StringComparison.OrdinalIgnoreCase))</MudText>
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudDataGrid T="UserActivityReportDTO" Items="@_activities" Hover="true" Elevation="0" Class="rounded-xl border-none" QuickFilter="@_activityFilter">
                <ToolBarContent>
                    <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B2559;">User Activity Log</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_activitySearch" Placeholder="Search action or details..." Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0" Style="max-width: 300px;"></MudTextField>
                </ToolBarContent>
                <Columns>
                    <PropertyColumn Property="x => x.Timestamp" Title="Created At" Format="yyyy-MM-dd HH:mm" />
                    <TemplateColumn Title="Created By">
                        <CellTemplate>
                            <div class="d-flex align-center gap-2">
                                <MudAvatar Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Primary" Variant="Variant.Filled">
                                    @(context.Item.UserName?.Substring(0, Math.Min(2, context.Item.UserName.Length)).ToUpper() ?? "U")
                                </MudAvatar>
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Item.UserName</MudText>
                            </div>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Action">
                        <CellTemplate>
                            @{
                                var action = context.Item.Action;
                                var color = MudBlazor.Color.Default;
                                var variant = Variant.Text;
                                
                                if (action.Contains("Approval", StringComparison.OrdinalIgnoreCase) || 
                                    action.Contains("Disbursed", StringComparison.OrdinalIgnoreCase) || 
                                    action.Contains("Paid", StringComparison.OrdinalIgnoreCase))
                                {
                                    color = MudBlazor.Color.Success;
                                    variant = Variant.Filled;
                                }
                                else if (action.Contains("Deleted", StringComparison.OrdinalIgnoreCase) || 
                                         action.Contains("Removed", StringComparison.OrdinalIgnoreCase) || 
                                         action.Contains("Rejection", StringComparison.OrdinalIgnoreCase))
                                {
                                    color = MudBlazor.Color.Error;
                                    variant = Variant.Filled;
                                }
                                else if (action.Contains("Edited", StringComparison.OrdinalIgnoreCase) || 
                                         action.Contains("Rescheduled", StringComparison.OrdinalIgnoreCase) || 
                                         action.Contains("Updated", StringComparison.OrdinalIgnoreCase))
                                {
                                    color = MudBlazor.Color.Warning;
                                    variant = Variant.Filled;
                                }
                                else if (action.Contains("Created", StringComparison.OrdinalIgnoreCase) || 
                                         action.Contains("Added", StringComparison.OrdinalIgnoreCase) || 
                                         action.Contains("Deposit", StringComparison.OrdinalIgnoreCase))
                                {
                                    color = MudBlazor.Color.Info;
                                    variant = Variant.Filled;
                                }
                            }
                            <MudChip T="string" Color="@color" Size="MudBlazor.Size.Small" Variant="@variant" Style="font-weight: 600; font-size: 0.75rem;">
                                @action
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn Title="Entity">
                        <CellTemplate>
                            <MudChip T="string" Size="MudBlazor.Size.Small" Variant="Variant.Outlined" Color="MudBlazor.Color.Primary" Style="font-weight: 500;">
                                @context.Item.EntityName
                            </MudChip>
                        </CellTemplate>
                    </TemplateColumn>
                    <PropertyColumn Property="x => x.Description" Title="Details" />
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="UserActivityReportDTO" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>
            </MudTabs>
        </MudTabPanel>

        @* 2. REPAYMENT & COLLECTION *@
        <MudTabPanel Text="2. Repayment & Collection" Icon="@Icons.Material.Filled.AccountBalance">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="Repayment Schedule" Icon="@Icons.Material.Filled.Schedule">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Repayment Schedule Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
                <MudTabPanel Text="Overdue / Delinquency" Icon="@Icons.Material.Filled.Warning">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Overdue/Delinquency Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
                <MudTabPanel Text="Collection Efficiency" Icon="@Icons.Material.Filled.TrendingUp">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Collection Efficiency Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
            </MudTabs>
        </MudTabPanel>

        @* 3. FINANCIAL PERFORMANCE *@
        <MudTabPanel Text="3. Financial Performance" Icon="@Icons.Material.Filled.AttachMoney">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="Interest Income" Icon="@Icons.Material.Filled.Savings">
                    <MudGrid Class="mt-4">
                        <MudItem xs="12" sm="4">
                            <MudPaper Class="pa-6 rounded-xl" Style="background: linear-gradient(135deg, #1B2559 0%, #2A3673 100%); color: white; box-shadow: 0 10px 30px rgba(27, 37, 89, 0.2);">
                                <MudText Typo="Typo.subtitle2" Style="color: #A3AED0; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Total Interest Expected</MudText>
                                <MudText Typo="Typo.h4" Style="font-weight: 700; margin-top: 8px;">$124,500.00</MudText>
                                <MudText Typo="Typo.body2" Class="mt-2" Style="color: #05CD99; font-weight: 600;">
                                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="MudBlazor.Size.Small" Class="mr-1" Style="vertical-align: text-bottom;" />
                                    +12.5% from last year
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudPaper Class="pa-6 rounded-xl" Style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border: 1px solid #E2E8F0; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);">
                                <MudText Typo="Typo.subtitle2" Style="color: #A3AED0; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Interest Collected</MudText>
                                <MudText Typo="Typo.h4" Style="font-weight: 700; margin-top: 8px; color: #1B2559;">$89,200.00</MudText>
                                <MudText Typo="Typo.body2" Class="mt-2" Style="color: #05CD99; font-weight: 600;">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="MudBlazor.Size.Small" Class="mr-1" Style="vertical-align: text-bottom;" />
                                    71.6% collection rate
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudPaper Class="pa-6 rounded-xl" Style="background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(10px); border: 1px solid #E2E8F0; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);">
                                <MudText Typo="Typo.subtitle2" Style="color: #A3AED0; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">Outstanding Interest</MudText>
                                <MudText Typo="Typo.h4" Style="font-weight: 700; margin-top: 8px; color: #E31A1A;">$35,300.00</MudText>
                                <MudText Typo="Typo.body2" Class="mt-2" Style="color: #E31A1A; font-weight: 600;">
                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="MudBlazor.Size.Small" Class="mr-1" Style="vertical-align: text-bottom;" />
                                    Action required for 12 accounts
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" Class="mt-4">
                            <MudPaper Class="pa-6 rounded-xl" Style="background: white; border: 1px solid #E2E8F0; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);">
                                <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B2559; margin-bottom: 16px;">Revenue Trend (YTD)</MudText>
                                <ApexChart TItem="MonthlyIncome" Options="@_chartOptions" Height="350">
                                    <ApexPointSeries TItem="MonthlyIncome"
                                                     Items="_incomeData"
                                                     Name="Interest Income"
                                                     SeriesType="SeriesType.Area"
                                                     XValue="@(e => e.Month)"
                                                     YAggregate="@(e => e.Sum(x => x.Interest))" />
                                    <ApexPointSeries TItem="MonthlyIncome"
                                                     Items="_incomeData"
                                                     Name="Penalties"
                                                     SeriesType="SeriesType.Area"
                                                     XValue="@(e => e.Month)"
                                                     YAggregate="@(e => e.Sum(x => x.Penalties))" />
                                </ApexChart>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
                <MudTabPanel Text="Penalty / Charges" Icon="@Icons.Material.Filled.Gavel">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Penalty/Charges Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
                <MudTabPanel Text="Profitability" Icon="@Icons.Material.Filled.BarChart">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Profitability Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
            </MudTabs>
        </MudTabPanel>

        @* 4. RISK & COMPLIANCE *@
        <MudTabPanel Text="4. Risk & Compliance" Icon="@Icons.Material.Filled.Security">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="Credit Risk" Icon="@Icons.Material.Filled.ErrorOutline">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Credit Risk Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
                <MudTabPanel Text="Non-Performing Loans" Icon="@Icons.Material.Filled.MoneyOff">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Non-Performing Loans (NPL) Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
                <MudTabPanel Text="Regulatory Compliance" Icon="@Icons.Material.Filled.Policy">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Regulatory Compliance Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
            </MudTabs>
        </MudTabPanel>

        @* 5. CUSTOMER REPORTS *@
        <MudTabPanel Text="5. Customer Reports" Icon="@Icons.Material.Filled.People">
            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
                <MudTabPanel Text="Customer Portfolio" Icon="@Icons.Material.Filled.ContactPage">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Customer Portfolio Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
                <MudTabPanel Text="Application Status" Icon="@Icons.Material.Filled.PendingActions">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Loan Application Status Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
                <MudTabPanel Text="Customer Risk Profile" Icon="@Icons.Material.Filled.Badge">
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">Customer Risk Profile Report - Data mapping in progress.</MudAlert>
                </MudTabPanel>
            </MudTabs>
        </MudTabPanel>

    </MudTabs>
</MudContainer>

@code {
    public class MonthlyIncome
    {
        public string Month { get; set; } = string.Empty;
        public decimal Interest { get; set; }
        public decimal Penalties { get; set; }
    }

    private List<MonthlyIncome> _incomeData = new()
    {
        new MonthlyIncome { Month = "Jan", Interest = 4500, Penalties = 200 },
        new MonthlyIncome { Month = "Feb", Interest = 5200, Penalties = 150 },
        new MonthlyIncome { Month = "Mar", Interest = 4800, Penalties = 300 },
        new MonthlyIncome { Month = "Apr", Interest = 6100, Penalties = 100 },
        new MonthlyIncome { Month = "May", Interest = 5900, Penalties = 400 },
        new MonthlyIncome { Month = "Jun", Interest = 7200, Penalties = 250 },
        new MonthlyIncome { Month = "Jul", Interest = 8400, Penalties = 500 }
    };

    private ApexChartOptions<MonthlyIncome> _chartOptions = new()
    {
        Chart = new Chart
        {
            Toolbar = new Toolbar { Show = false },
            Background = "transparent",
            FontFamily = "Roboto, sans-serif"
        },
        Colors = new List<string> { "#1B2559", "#4318FF" },
        DataLabels = new DataLabels { Enabled = false },
        Stroke = new Stroke { Curve = Curve.Smooth, Width = 3 },
        Xaxis = new XAxis 
        { 
            Labels = new XAxisLabels { Style = new AxisLabelStyle { Colors = "#A3AED0" } },
            AxisBorder = new AxisBorder { Show = false },
            AxisTicks = new AxisTicks { Show = false }
        },
        Yaxis = new List<YAxis> 
        { 
            new YAxis { Labels = new YAxisLabels { Style = new AxisLabelStyle { Colors = "#A3AED0" } } } 
        },
        Grid = new Grid { BorderColor = "#E2E8F0", StrokeDashArray = 4 },
        Fill = new Fill { Type = FillType.Gradient, Gradient = new FillGradient { ShadeIntensity = 1, OpacityFrom = 0.4d, OpacityTo = 0.05d, Stops = new List<double> { 0, 100 } } }
    };

    private List<ActiveLoanSummaryDTO> _activeLoans = new();
    private List<LoanDisbursementReportDTO> _disbursements = new();
    private List<LoanMaturityReportDTO> _maturities = new();
    private List<UserActivityReportDTO> _activities = new();

    private string _activeLoanSearch = "";
    private string _disbursementSearch = "";
    private string _activityUserSearch = "";
    private string _activitySearch = "";
    private DateRange _disbursementRange = new DateRange(DateTime.Now.AddYears(-5).Date, DateTime.Now.Date);
    private string? _loanTypeFilter;
    private DateRange _maturityRange = new DateRange(DateTime.Now.AddYears(-5).Date, DateTime.Now.AddYears(5).Date);
    private DateRange _activityRange = new DateRange(DateTime.Now.AddYears(-5).Date, DateTime.Now.Date);

    protected override async Task OnInitializedAsync()
    {
        await LoadActiveLoans();
        await LoadDisbursementReport();
        await LoadMaturityReport();
        await LoadActivityReport();
    }

    private async Task LoadActiveLoans()
    {
        try { _activeLoans = await ReportService.GetActiveLoansSummaryAsync(); }
        catch (Exception ex) { Snackbar.Add($"Error loading active loans: {ex.Message}", Severity.Error); }
    }

    private async Task LoadDisbursementReport()
    {
        try 
        { 
            _disbursements = await ReportService.GetLoanDisbursementReportAsync(
                _disbursementRange.Start ?? DateTime.MinValue, 
                _disbursementRange.End ?? DateTime.MaxValue, 
                _loanTypeFilter); 
        }
        catch (Exception ex) { Snackbar.Add($"Error loading disbursements: {ex.Message}", Severity.Error); }
    }

    private async Task LoadMaturityReport()
    {
        try 
        { 
            _maturities = await ReportService.GetLoanMaturityReportAsync(
                _maturityRange.Start, 
                _maturityRange.End); 
        }
        catch (Exception ex) { Snackbar.Add($"Error loading maturity report: {ex.Message}", Severity.Error); }
    }

    private async Task LoadActivityReport()
    {
        try 
        { 
            _activities = await ReportService.GetUserActivityReportAsync(
                _activityRange.Start, 
                _activityRange.End); 
        }
        catch (Exception ex) { Snackbar.Add($"Error loading activity logs: {ex.Message}", Severity.Error); }
    }

    private Func<ActiveLoanSummaryDTO, bool> _activeLoanFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_activeLoanSearch)) return true;
        if (x.BorrowerName.Contains(_activeLoanSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.ApplicationCode.Contains(_activeLoanSearch, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    };

    private Func<LoanDisbursementReportDTO, bool> _disbursementFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_disbursementSearch)) return true;
        if (x.BorrowerName.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.ApplicationCode.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.LoanType.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.Branch.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase)) return true;
        if (x.Officer.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    };

    private Func<UserActivityReportDTO, bool> _activityFilter => x =>
    {
        var userMatches = string.IsNullOrWhiteSpace(_activityUserSearch) ||
            x.UserName.Contains(_activityUserSearch, StringComparison.OrdinalIgnoreCase);

        var activityMatches = string.IsNullOrWhiteSpace(_activitySearch) ||
            x.Action.Contains(_activitySearch, StringComparison.OrdinalIgnoreCase) ||
            x.EntityName.Contains(_activitySearch, StringComparison.OrdinalIgnoreCase) ||
            x.Description.Contains(_activitySearch, StringComparison.OrdinalIgnoreCase);

        return userMatches && activityMatches;
    };
}
