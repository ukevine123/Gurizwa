</MudContainer>

@code {
    [SupplyParameterFromQuery]
    public string? Active { get; set; }

    private string _activeReport = "";

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Active))
        {
            _activeReport = Active;
        }
    }

    private void SetActiveReport(string reportName)
    {
        _activeReport = reportName;
        StateHasChanged();
    }

    private async Task Export(string reportName, string format)
    {
        byte[] fileBytes = null;
        string fileName = $"{reportName}_{DateTime.Now:yyyyMMdd_HHmmss}";

        try 
        {
            switch (reportName)
            {
                case "ActiveLoans": fileBytes = ExportData(_activeLoans, format, reportName); break;
                case "Disbursements": fileBytes = ExportData(_disbursements, format, reportName); break;
                case "MaturityTracker": fileBytes = ExportData(_maturities, format, reportName); break;
                case "UserActivities": fileBytes = ExportData(_activities, format, reportName); break;
                case "RepaymentSchedules": fileBytes = ExportData(_repaymentSchedules, format, reportName); break;
                case "UpcomingDues": 
                    var dues = _repaymentSchedules.Where(s => s.DueDate.Date >= DateTime.Now.Date && s.DueDate.Date <= DateTime.Now.Date.AddDays(7)).OrderBy(s => s.DueDate).ToList();
                    fileBytes = ExportData(dues, format, reportName); 
                    break;
                case "OverdueLoans": fileBytes = ExportData(_overdues, format, reportName); break;
                case "CustomerPortfolios": fileBytes = ExportData(_customerPortfolios, format, reportName); break;
                case "ApplicationStatuses": fileBytes = ExportData(_applicationStatuses, format, reportName); break;
                case "IncomeStatement": 
                    if (_incomeStatement != null)
                        fileBytes = ExportData(new List<IncomeStatementReportDTO> { _incomeStatement }, format, reportName); 
                    break;
            }

            if (fileBytes != null)
            {
                string extension = format == "pdf" ? ".pdf" : format == "doc" ? ".doc" : ".xlsx";
                using var streamRef = new DotNetStreamReference(new MemoryStream(fileBytes));
                await JSRuntime.InvokeVoidAsync("triggerFileDownload", fileName + extension, streamRef);
            }
        } 
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to export: {ex.Message}", Severity.Error);
        }
    }

    private byte[] ExportData<T>(IEnumerable<T> data, string format, string title)
    {
        if (format == "pdf") return ExportService.ExportToPdf(data, title);
        if (format == "doc") return ExportService.ExportToWordHtml(data, title);
        return ExportService.ExportToExcel(data, title);
    }

    private List<ActiveLoanSummaryDTO> _activeLoans = new();
    private List<LoanDisbursementReportDTO> _disbursements = new();
    private List<LoanMaturityReportDTO> _maturities = new();
    private List<UserActivityReportDTO> _activities = new();
    private List<UserDetailDTO> _subUsers = new();

    private DateRange _incomeStatementRange = new DateRange(new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1), DateTime.Now);
    private IncomeStatementReportDTO? _incomeStatement;

    private async Task LoadIncomeStatement()
    {
        if (_incomeStatementRange.Start.HasValue && _incomeStatementRange.End.HasValue)
        {
            _incomeStatement = await ReportService.GetIncomeStatementAsync(_incomeStatementRange.Start.Value, _incomeStatementRange.End.Value);
        }
    }

    private List<RepaymentScheduleReportDTO> _repaymentSchedules = new();
    private List<OverdueReportDTO> _overdues = new();
    private List<CustomerPortfolioReportDTO> _customerPortfolios = new();
    private List<ApplicationStatusReportDTO> _applicationStatuses = new();

    private string _activeLoanSearch = "";
    private string _disbursementSearch = "";
    private string _activityUserSearch = "";
    private string _activitySearch = "";
    private string _repaymentSearch = "";
    private string _overdueSearch = "";
    private string _customerSearch = "";
    private string _applicationSearch = "";

    private DateRange _disbursementRange = new DateRange(DateTime.Now.AddYears(-5).Date, DateTime.Now.Date);
    private string? _loanTypeFilter;
    private DateRange _maturityRange = new DateRange(DateTime.Now.AddYears(-5).Date, DateTime.Now.AddYears(5).Date);
    private DateRange _activityRange = new DateRange(DateTime.Now.AddYears(-5).Date, DateTime.Now.Date);

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            if (UserContext.PersonId.HasValue)
            {
                _subUsers = await IdentityService.GetSubUsers(UserContext.PersonId.Value) ?? new List<UserDetailDTO>();
            }
            
            if (!_subUsers.Any() && UserContext.Id.HasValue)
            {
                _subUsers = await IdentityService.GetSubUsersAsync(UserContext.Id.Value) ?? new List<UserDetailDTO>();
            }
        } 
        catch { }

        await LoadActiveLoans();
        await LoadDisbursementReport();
        await LoadMaturityReport();
        await LoadActivityReport();

        await LoadNewReports();
    }

    private async Task LoadNewReports()
    {
        try { _repaymentSchedules = await ReportService.GetRepaymentScheduleReportAsync(); } catch { }
        try { _overdues = await ReportService.GetOverdueReportAsync(); } catch { }
        try { _customerPortfolios = await ReportService.GetCustomerPortfolioReportAsync(); } catch { }
        try { _applicationStatuses = await ReportService.GetApplicationStatusReportAsync(); } catch { }
    }

    private async Task LoadActiveLoans()
    {
        try { _activeLoans = await ReportService.GetActiveLoansSummaryAsync(); }
        catch (Exception ex) { Snackbar.Add($"Error loading active loans: {ex.Message}", Severity.Error); }
    }

    private async Task LoadDisbursementReport()
    {
        try 
        { 
            _disbursements = await ReportService.GetLoanDisbursementReportAsync(
                _disbursementRange.Start ?? DateTime.MinValue, 
                _disbursementRange.End ?? DateTime.MaxValue, 
                _loanTypeFilter); 
        }
        catch (Exception ex) { Snackbar.Add($"Error loading disbursements: {ex.Message}", Severity.Error); }
    }

    private async Task LoadMaturityReport()
    {
        try 
        { 
            _maturities = await ReportService.GetLoanMaturityReportAsync(
                _maturityRange.Start, 
                _maturityRange.End); 
        }
        catch (Exception ex) { Snackbar.Add($"Error loading maturity report: {ex.Message}", Severity.Error); }
    }

    private async Task LoadActivityReport()
    {
        try 
        { 
            _activities = await ReportService.GetUserActivityReportAsync(
                _activityRange.Start, 
                _activityRange.End); 
        }
        catch (Exception ex) { Snackbar.Add($"Error loading activity logs: {ex.Message}", Severity.Error); }
    }

    private Func<ActiveLoanSummaryDTO, bool> _activeLoanFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_activeLoanSearch)) return true;
        if (x.BorrowerName?.Contains(_activeLoanSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ApplicationCode?.Contains(_activeLoanSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };

    private Func<LoanDisbursementReportDTO, bool> _disbursementFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_disbursementSearch)) return true;
        if (x.BorrowerName?.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ApplicationCode?.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.LoanType?.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.Branch?.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.Officer?.Contains(_disbursementSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };

    private Func<UserActivityReportDTO, bool> _activityFilter => x =>
    {
        var userMatches = string.IsNullOrWhiteSpace(_activityUserSearch) ||
            (!string.IsNullOrEmpty(x.UserName) && x.UserName.Contains(_activityUserSearch, StringComparison.OrdinalIgnoreCase));

        var activityMatches = string.IsNullOrWhiteSpace(_activitySearch) ||
            (!string.IsNullOrEmpty(x.Action) && x.Action.Contains(_activitySearch, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(x.EntityName) && x.EntityName.Contains(_activitySearch, StringComparison.OrdinalIgnoreCase)) ||
            (!string.IsNullOrEmpty(x.Description) && x.Description.Contains(_activitySearch, StringComparison.OrdinalIgnoreCase));

        return userMatches && activityMatches;
    };

    private Func<RepaymentScheduleReportDTO, bool> _repaymentFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_repaymentSearch)) return true;
        if (x.BorrowerName?.Contains(_repaymentSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ApplicationCode?.Contains(_repaymentSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };

    private Func<OverdueReportDTO, bool> _overdueFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_overdueSearch)) return true;
        if (x.BorrowerName?.Contains(_overdueSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ApplicationCode?.Contains(_overdueSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };

    private Func<CustomerPortfolioReportDTO, bool> _customerFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_customerSearch)) return true;
        if (x.BorrowerName?.Contains(_customerSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };

    private Func<ApplicationStatusReportDTO, bool> _applicationFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_applicationSearch)) return true;
        if (x.BorrowerName?.Contains(_applicationSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.ApplicationCode?.Contains(_applicationSearch, StringComparison.OrdinalIgnoreCase) == true) return true;
        return false;
    };
}
