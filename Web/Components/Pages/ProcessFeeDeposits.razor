@page "/ProcessFeeDeposits"
@using Microsoft.EntityFrameworkCore
@using MudBlazor
@using Domain.Entities
@using Application.Services.ProcessFeeDeposits
@using Domain.ValueObjects
@inject IProcessFeeDepositService ProcessFeeDepositService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<PageTitle>Process Fee Deposits</PageTitle>
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudGrid Class="mb-4" Spacing="2">

        <MudItem xs="12"  Class="d-flex align-center justify-end gap-4">
            @if (_selectedItems.Any())
            {
                <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" OnClick="@(() => OpenDetailDialog(_selectedItems.First().Id))" />
                @* <MudIconButton Icon="@Icons.Material.Filled.Details" Size="Size.Small" /> *@
                <AuthorizeView Roles="Tenant">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"  OnClick="@(() => OpenEditDialog(_selectedItems.First().Id))" />
                </AuthorizeView>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
            }
     
        </MudItem>
    </MudGrid>

    @* 3. THE DATAGRID *@
    <MudDataGrid T="ProcessFeeDeposit" Items="@_processFeeDeposits" MultiSelection="true" @bind-SelectedItems="_selectedItems"
                 Hover="true" Elevation="0" Class="rounded-xl border-none">

                  <ToolBarContent>
            <MudText Typo="Typo.h5" Color="Color.Primary">p</MudText>
            <MudSpacer />

            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenDialog">Add Fee Deposit</MudButton>
        </ToolBarContent>

          <ToolBarContent>
            @* <MudText Typo="Typo.h5" Color="Color.Primary">Guarantor</MudText> *@
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenDialog())">Add Fee Deposit</MudButton>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="ProcessFeeDeposit" />
            
            <PropertyColumn Property="x => x.LoanApplication.ApplicationCode" Title="Loan Application " />
            @* <PropertyColumn Property="x => x.LoanApplication.Borrower.FirstName  " + x.LoanApplication.Borrower.LastName" Title="Loan Application" /> *@
            <PropertyColumn Property="x => x.Amount" Title="Amount" />
            <PropertyColumn Property="x => x.DepositDate" Title="Deposit Date" Format="yyyy-MM-dd" />
            <PropertyColumn Property="x => x.Account.AccountNumber" Title="Account number" />
            

        </Columns>
        
        <PagerContent>
            <MudDataGridPager T="ProcessFeeDeposit" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
     private string _searchString = "";

    private IEnumerable<ProcessFeeDeposit> FilteredProcessFeeDeposits => _processFeeDeposits
        .Where(x => string.IsNullOrWhiteSpace(_searchString) || 
                    x.LoanApplication.Borrower.FirstName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                    x.LoanApplication.Borrower.LastName.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                    x.LoanApplication.Borrower.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase));
     //s
       List<ProcessFeeDeposit> _processFeeDeposits = new();
    private HashSet<ProcessFeeDeposit> _selectedItems = new();

      protected override async Task OnInitializedAsync()
    {
         await LoadProcessFeeDeposits();
         
    }
    
    private async Task OpenDialog()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.Medium };

        var dialog = await DialogService.ShowAsync<CreateProcessFeeDepositdialog>("Add Fee Deposit", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
             await LoadProcessFeeDeposits();
        }
    }
     private async Task LoadProcessFeeDeposits()
    {
        _processFeeDeposits = (await ProcessFeeDepositService.GetAllProcessFeeDepositsAsync()).OrderByDescending(x => x.Id).ToList();
        StateHasChanged();
    }
        private Color GetStatusColor(LoanStatus status)
        {
        return status.ToString() switch
        {
            "Dormant" => Color. Warning,
            "Active" => Color.Success,
            "Closed" => Color.Error,
            _ => Color.Default
        };
       }

    private async Task OpenDetailDialog(int id)
    {
        var parameters = new DialogParameters<BorrowerDetailDialog> { { x => x.Id, id } };
        await DialogService.ShowAsync<BorrowerDetailDialog>("View Details", parameters);
    }

     private async Task OpenEditDialog(int id)
    {
        var parameters = new DialogParameters<EditBorrowerDialog> { { x => x.Id, id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = await DialogService.ShowAsync<EditBorrowerDialog>("Edit Guarantor", parameters, options);
        var result = await dialog.Result;
    }


}
