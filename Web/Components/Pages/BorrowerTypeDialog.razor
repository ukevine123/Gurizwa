@using Application.DTO
@using Application.Interfaces
@using Application.Services.BorrowerTypes
@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Authorization

@inject NavigationManager Navigation
@inject IBorrowerTypeService BorrowerTypeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog Style="overflow:hidden;" >
    <DialogContent>
        <MudPaper Elevation="0" Style="background: linear-gradient(135deg, #4318FF); padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Home" Style="color:white; font-size:1.6rem;" />
                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1" Style="color:white; font-weight:700; line-height:1.2;">Create Borrower Type</MudText>
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">Fill the form below to create a new Borrower Type</MudText>
                </MudStack>
            </MudStack>
        </MudPaper>

        <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreateBorrowerTypeForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <MudGrid Spacing="1" Class="align-items-center">
                <MudItem  xs="12">
                <MudTextField Label="Borrower Type"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Type"
                              For="@(() => Model.Type)" />
                </MudItem>
                
                <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" FullWidth="true" ButtonType="ButtonType.Submit" Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px;">
                    Add Borrower Type
                </MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
</MudDialog>

@code{
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    
    [SupplyParameterFromForm(Name = "CreateBorrowerTypeForm")]
    private CreateBorrowTypeDTO Model {get;set;} = new ();
    private string ErrorMessage{get;set;}

    private async Task onValidSubmit()
    {
        try
        {
            await BorrowerTypeService.CreateBorrowerType(Model);
            Snackbar.Add("Borrower Type created successfully!", Severity.Info);
            MudDialog.Close(DialogResult.Ok(Model));
        }
        catch(Exception ex)
        {
            ErrorMessage = ex.Message;
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
