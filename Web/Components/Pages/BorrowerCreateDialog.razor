@using  Application.DTO
@using System.ComponentModel.DataAnnotations
@using Application.Interfaces
@using Application.Services.BorrowerTypes
@using Application.Services.Borrowers
@using Domain.ValueObjects
@using Domain.Entities
@using MudBlazor
@using MudBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore.Metadata.Internal
@using Microsoft.AspNetCore.Authorization
@* @attribute [Authorize] *@
@inject NavigationManager Navigation
@inject IBorrowerService BorrowerService
@inject IBorrowerTypeService BorrowerTypeService
@inject ISnackbar Snackbar
@inject IDialogService DialogService


<MudDialog Style="overflow:hidden;" >

    <DialogContent>

        <!-- ══════════ HEADER BANNER ══════════ -->
        <MudPaper Elevation="0"
                  Style="background: linear-gradient(135deg, #5a55e6 0%, #f7f9f8 100%);
                         padding:14px 18px; margin-bottom:16px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">

                <MudIcon Icon="@Icons.Material.Filled.AccountBalance"
                         Style="color:white; font-size:1.6rem;" />

                <MudStack Spacing="0">
                    <MudText Typo="Typo.subtitle1"
                             Style="color:white; font-weight:700; line-height:1.2;">
                        Create Borrower
                    </MudText>

                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.80);">
                        Fill the form below to create a new Borrower
                    </MudText>
                </MudStack>

            </MudStack>
        </MudPaper>


        <!-- ══════════ FORM ══════════ -->
        <EditForm Model="Model" OnValidSubmit="onValidSubmit" FormName="CreateBorrowerForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            @* <MudStack Spacing="2"> *@

                <!-- Section -->
                @* <MudText Typo="Typo.caption"
                         Style="color:#9E9E9E; font-weight:600; letter-spacing:.08em;
                                text-transform:uppercase;">
                    Account Type
                </MudText> *@
                <MudGrid Spacing="1" Class="align-items-center">
                    <MudItem xs="12">
                        <MudSelect T="int"
                                   Label="Borrower Type"
                                   Placeholder="--Select Borrower Type--"
                                   @bind-Value="Model.BorrowerTypeId"
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Margin="Margin.Dense"
                                   AdornmentIcon="@Icons.Material.Filled.Category"
                                   AdornmentColor="Color.Primary">

                            <MudSelectItem Value="0">--Select Borrower Type--</MudSelectItem>

                            @if (acctype != null)
                            {
                                foreach (var type in acctype)
                                {
                                    <MudSelectItem T="int" Value="@type.Id">@type.Type</MudSelectItem>
                                }
                            }
                        </MudSelect>
                    </MudItem>
                <MudItem  xs="12">
                <MudTextField Label="FirstName"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.FirstName"
                              For="@(() => Model.FirstName)" />
                </MudItem>
                <MudItem  xs="12">
                <MudTextField Label="LastName"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.LastName"
                              For="@(() => Model.LastName)" />
                </MudItem>

                
                        @* <MudItem xs="12">
    <MudSelect T="Maritalstatus"
               Label="Maritalstatus"
               @bind-Value="Model.Maritalstatus"
               Variant="Variant.Outlined"
               Dense="true"
               Margin="Margin.Dense"
               AdornmentIcon="@Icons.Material.Filled.Transgender"
               AdornmentColor="Color.Primary">
        
        <MudSelectItem T="Maritalstatus" Disabled="true">-- Select Maritalstatus --</MudSelectItem>

        @foreach (Maritalstatus item in Enum.GetValues(typeof(Maritalstatus)))
        {
            <MudSelectItem T="Maritalstatus" Value="item">@item.ToString()</MudSelectItem>
        }
    </MudSelect>
</MudItem> *@

                  <MudItem xs="6">
    <MudSelect T="Maritalstatus"
               Label="Maritalstatus"
               @bind-Value="Model.Maritalstatus"
               Variant="Variant.Outlined"
               Dense="true"
               Margin="Margin.Dense"
               AdornmentIcon="@Icons.Material.Filled.Transgender"
               AdornmentColor="Color.Primary">
        
        @* If Model.sex is NOT nullable, this line is just a visual label *@
        <MudSelectItem T="Maritalstatus" Disabled="true">-- Select Maritalstatus --</MudSelectItem>

        @foreach (Maritalstatus item in Enum.GetValues(typeof(Maritalstatus)))
        {
            <MudSelectItem T="Maritalstatus" Value="item">@item.ToString()</MudSelectItem>
        }
    </MudSelect>
</MudItem>
                <MudItem xs="6">
    <MudSelect T="Sex"
               Label="Sex"
               @bind-Value="Model.sex"
               Variant="Variant.Outlined"
               Dense="true"
               Margin="Margin.Dense"
               AdornmentIcon="@Icons.Material.Filled.Transgender"
               AdornmentColor="Color.Primary">
        
        @* If Model.sex is NOT nullable, this line is just a visual label *@
        <MudSelectItem T="Sex" Disabled="true">-- Select Sex --</MudSelectItem>

        @foreach (Sex item in Enum.GetValues(typeof(Sex)))
        {
            <MudSelectItem T="Sex" Value="item">@item.ToString()</MudSelectItem>
        }
    </MudSelect>
</MudItem>
                <MudItem  xs="6"> 
                      <MudDatePicker Label="Date Of Birth"
                       @bind-Value="Model.DateOfBirth"
                        Variant="Variant.Outlined"
                        Margin="Margin.Dense"
                        Adornment="Adornment.Start" 
                        AdornmentColor="Color.Primary" />
                </MudItem>

                  <MudItem  xs="6">
                <MudTextField Label="IdentificationNumber"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.IdentificationNumber"
                              For="@(() => Model.IdentificationNumber)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="Email"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Email"
                              For="@(() => Model.Email)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="PhoneNumber"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.PhoneNumber"
                              For="@(() => Model.PhoneNumber)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="SpouceIdNumber"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.SpouceIdNumber"
                              For="@(() => Model.SpouceIdNumber)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="SpouceName"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.SpouceName"
                              For="@(() => Model.SpouceName)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="Province"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Province"
                              For="@(() => Model.Province)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="District"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.District"
                              For="@(() => Model.District)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="Sector"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Sector"
                              For="@(() => Model.Sector)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="Cell"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Cell"
                              For="@(() => Model.Cell)" />
                </MudItem>
                  <MudItem  xs="6">
                <MudTextField Label="Village"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              @bind-Value="Model.Village"
                              For="@(() => Model.Village)" />
                </MudItem>
                <MudItem xs="12">
                <MudButton Variant="Variant.Filled"
                        Color="Color.Primary"
                        Size="Size.Small"
                        FullWidth="true"
                        ButtonType="ButtonType.Submit"
                        Style="height: 40px; font-weight: bold; margin-top:5px; margin-bottom:5px;">
                    Add Borrower
                </MudButton>
                </MudItem>



            </MudGrid>

        </EditForm>
    </DialogContent>
</MudDialog>

@code{
    [CascadingParameter]
    
    private IMudDialogInstance MudDialog { get; set; }
    private bool _fullWidth;
    private bool _fitContent;
    [SupplyParameterFromForm(Name = "CreateBorrowerForm")]
    private CreateBorrowerDTO Model {get;set;} = new ();
    private string ErrorMessage{get;set;}

      public Sex sex { get; set; }
      public Maritalstatus maritalstatus { get; set; }


    private async Task onValidSubmit()
    {
        try
        {
            await BorrowerService.CreateBorrower(Model);
            Snackbar.Add("Borrower created successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(Model));
        }
        catch(Exception ex)
        {
            ErrorMessage = ex.Message;
        }
    }
   
private List<BorrowerType> acctype = new List<BorrowerType>();

protected override async Task OnInitializedAsync()
{
    try 
    {
        var types = await BorrowerTypeService.GetAllBorrowerTypeAsync();
        if (types != null)
        {
            acctype = types;
            StateHasChanged();
            
        }
    }
    catch (Exception ex)
    {
        Snackbar.Add("Error loading account types", Severity.Error);
    }
}
      

}