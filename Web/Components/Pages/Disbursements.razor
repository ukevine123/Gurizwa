@page "/Disbursements"
@using Application.Services.Disbursements
@using Domain.Entities
@using MudBlazor
@inject IDisbursementService DisbursementService
@inject IDialogService DialogService

<PageTitle>Disbursements</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    @* --- ACTION BAR --- *@
    <MudGrid Class="mb-4" Spacing="2">
        <MudItem xs="12" Class="d-flex align-center justify-end gap-4">
            @if (_selectedItems.Any())
            {
                <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Info" Size="Size.Small" OnClick="@(() => OpenAmortizationDetails(_selectedItems.First()))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
                <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
            }
            <MudButton StartIcon="@Icons.Material.Filled.FilterList" Variant="Variant.Text">Filter</MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Sort" Variant="Variant.Text">Sort by</MudButton>
        </MudItem>
    </MudGrid>

    @* --- DATA GRID --- *@
    <MudDataGrid T="Disbursement" 
                 Items="@_disbursements" 
                 Hover="true" 
                 Elevation="0" 
                 MultiSelection="true"
                 @bind-SelectedItems="_selectedItems"
                 Class="rounded-xl border-none shadow-sm">
        
        <ToolBarContent>
            <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight: bold;">Confirmed borrower</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => GoToCreateDisbursement())">Add Disbursement</MudButton>
        </ToolBarContent>

        <Columns>
            <SelectColumn T="Disbursement" />
            
            <TemplateColumn Title="Borrower">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.LoanApplication?.Borrower?.CompanyName))
                    {
                        @context.Item.LoanApplication?.Borrower?.CompanyName
                    }
                    else
                    {
                        <b>@context.Item.LoanApplication?.Borrower?.FirstName</b> @(" ") @context.Item.LoanApplication?.Borrower?.LastName
                    }
                </CellTemplate>
            </TemplateColumn>

            <PropertyColumn Property="x => x.PrincipalOffered" Title="Principal" Format="n" />
            
            @* DYNAMIC REMAINING BALANCE *@
            <TemplateColumn Title="Remaining Balance">
                <CellTemplate>
                    @{
                        var totalPaid = context.Item.Payments?.Where(p => p.IsActive).Sum(p => p.Amount) ?? 0;
                        var balance = context.Item.Amount - totalPaid;
                    }
                    <MudText Typo="Typo.body2" Color="@(balance <= 0.1m ? Color.Success : Color.Default)">
                        <b>@balance.ToString("n")</b>
                    </MudText>
                </CellTemplate>
            </TemplateColumn>
            
            <PropertyColumn Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd" />       
            <PropertyColumn Property="x => x.EndDate" Title="End" Format="yyyy-MM-dd" />
          
            @* STATUS LOGIC: PAID VS PENDING *@
            <TemplateColumn Title="Status">
                <CellTemplate>
                    @{
                        var totalPaid = context.Item.Payments?.Where(p => p.IsActive).Sum(p => p.Amount) ?? 0;
                        bool isPaid = totalPaid >= (context.Item.Amount - 0.1m);
                    }
                    <MudChip T="string" 
                             Color="@(isPaid ? Color.Success : Color.Warning)" 
                             Size="Size.Small" 
                             Variant="@(isPaid ? Variant.Filled : Variant.Text)"
                             Style="font-weight: 700; min-width: 90px;">
                        @(isPaid ? "PAID" : "PENDING")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

            @* ACTION COLUMN: PRINT *@
            <TemplateColumn Title="Action" HeaderStyle="text-align: center;" Style="text-align: center;">
                <CellTemplate>
                    <div class="d-flex justify-center align-center">
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Primary" 
                                   Size="Size.Small" 
                                   StartIcon="@Icons.Material.Filled.Print" 
                                   OnClick="@(() => PrintRepaymentSchedule(context.Item))"
                                   Style="font-weight:600;">
                            Print
                        </MudButton>
                    </div>
                </CellTemplate>
            </TemplateColumn>
        </Columns>

        <PagerContent>
            <MudDataGridPager T="Disbursement" />
        </PagerContent>
    </MudDataGrid>
</MudContainer>

@code {
    private List<Disbursement> _disbursements = new();
    private HashSet<Disbursement> _selectedItems = new(); 
    
    protected override async Task OnInitializedAsync()
    {
        await LoadDisbursements();
    }

    private async Task LoadDisbursements()
    {
        // IMPORTANT: We use GetAllDisbursementsAsync so finished loans remain in the history grid.
        _disbursements = await DisbursementService.GetAllDisbursementsAsync();
        StateHasChanged();
    }

    private async Task GoToCreateDisbursement()
    {
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateDisbursement>("Add Disbursement", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadDisbursements();
        }
    }

    private async Task OpenAmortizationDetails(Disbursement item)
    {
        // Fetch full object to include payment history
        var fullItem = await DisbursementService.GetDisbursementByIdAsync(item.Id);
        
        var parameters = new DialogParameters<LoanDetailsDialog> 
        { 
            { x => x.Disbursement, fullItem } 
        };

        var options = new DialogOptions 
        { 
            CloseButton = true, 
            MaxWidth = MaxWidth.Medium, 
            FullWidth = true 
        };

        await DialogService.ShowAsync<LoanDetailsDialog>("Amortization Schedule", parameters, options);
    }

    private async Task PrintRepaymentSchedule(Disbursement item)
    {
        var fullItem = await DisbursementService.GetDisbursementByIdAsync(item.Id);
        var parameters = new DialogParameters
        {
            ["Disbursement"] = fullItem
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true };
        await DialogService.ShowAsync<RepaymentSchedulePrintDialog>("Print Repayment Schedule", parameters, options);
    }
}
