
@using Domain.Entities

@using Domain.ValueObjects
@using Application.Services.Borrowers
@using System.Globalization

@inject NavigationManager NavigationManager

 <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="BackToBorrower" StartIcon="@Icons.Material.Filled.ArrowBack">
                    Back to List
                </MudButton>
<MudDialog>
    
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2"/> Borrower Details
        </MudText>
    </TitleContent>
    <DialogContent>
        @if (_borrowers == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Borrower ID</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.Id</MudText>
                </MudItem>
                
                @if (string.IsNullOrEmpty(_borrowers.CompanyName))
                {
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">First Name</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.FirstName</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Last Name</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.LastName</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Gender</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.sex</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Marital Status</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.Maritalstatus</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Date of Birth</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.DateOfBirth</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Identification Number</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.IdentificationNumber</MudText>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Company Name</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.CompanyName</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">TIN / Registration No</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.TIN</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Contact Person</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.ContactPersonName</MudText>
                    </MudItem>
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Contact Person Phone</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.ContactPersonPhone</MudText>
                    </MudItem>
                }

                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Email</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.Email</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Phone Number</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.PhoneNumber</MudText>
                </MudItem>

                @if (string.IsNullOrEmpty(_borrowers.CompanyName))
                {
                    <MudItem xs="4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Next of Kin</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.NextOfKin</MudText>
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Kin Phone Number</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.KinPhoneNumber</MudText>
                    </MudItem>
                    <MudItem xs="4">
                        <MudText Typo="Typo.subtitle2" Color="Color.Primary">Relationship</MudText>
                        <MudText Typo="Typo.body1">@_borrowers.NextOfKinRelationship</MudText>
                    </MudItem>

                    @if (_borrowers.Maritalstatus == Domain.ValueObjects.Maritalstatus.Married)
                    {
                        <MudItem xs="6">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Spouse ID Number</MudText>
                            <MudText Typo="Typo.body1">@_borrowers.SpouceIdNumber</MudText>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.subtitle2" Color="Color.Primary">Spouse Name</MudText>
                            <MudText Typo="Typo.body1">@_borrowers.SpouceName</MudText>
                        </MudItem>
                    }
                }

                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Province</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.Province</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">District</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.District</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Sector</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.Sector</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Cell</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.Cell</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary">Village</MudText>
                    <MudText Typo="Typo.body1">@_borrowers.Village</MudText>
                </MudItem>
              
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    [Parameter] public int Id { get; set; } 
    
    [Inject] IBorrowerService BorrowerService { get; set; }

    private Borrower _borrowers;

    protected override async Task OnInitializedAsync()
    {
        _borrowers = await BorrowerService.GetBorrowerById(Id);
    }
    private void Close() => MudDialog.Close();
     private void BackToBorrower()
    {
        NavigationManager.NavigateTo("/Borrower");
    }
}
