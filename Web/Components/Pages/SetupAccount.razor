@page "/account/setup"
@attribute [AllowAnonymous]
@layout AuthLayout
@using Application.DTO
@using Application.Services.Users
@using MudBlazor
@inject IIdentityService IdentityService
@inject NavigationManager NavigationManager

<PageTitle>Setup Account</PageTitle>

<style>
    :root {
        --sellora-blue: #070bdc;
        --sellora-bg: #ffffff;
        --sellora-text-main: #1a1a1a;
        --sellora-text-muted: #757575;
    }

    /* Force the page to fill the screen and remove scrolling */
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden; /* Removes scrollbars */
    }

    .page-container {
        display: flex;
        height: 100vh; /* Fixed height to viewport */
        width: 100vw;
        background-color: var(--sellora-bg);
        font-family: 'Inter', sans-serif;
        overflow: hidden;
    }

    /* Left Side - Login Form */
    .login-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 40px;
        justify-content: center; /* Centers vertically */
    }

    .login-form-container {
        width: 100%;
        max-width: 420px;
        margin: 0 auto;
    }

    .brand-logo {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 48px;
        font-weight: 900;
        font-family: 'Arial Black', 'Montserrat', sans-serif;
        text-transform: uppercase;
        font-size: 1.5rem;
        color: var(--sellora-text-main);
    }

    /* Right Side - Blue Panel */
    .blue-panel {
        background-color: var(--sellora-blue);
        border-radius: 40px 0 0 40px;
        color: white;
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 60px;
        flex: 1;
    }

    .custom-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--sellora-text-main);
        margin-bottom: 8px;
        display: block;
    }

    .login-btn {
        background-color: #4318FF !important;
        color: white !important;
        text-transform: none !important;
        font-weight: 600 !important;
        height: 48px;
        border-radius: 8px !important;
    }

    @@media (max-width: 960px) {
        .blue-panel { display: none; }
        html, body { overflow: auto; } /* Allow scroll on mobile if content is too long */
    }
</style>

<div class="page-container">
    <!-- Left Section -->
    <div class="login-section">
        <div class="login-form-container">
            <div class="brand-logo">
                <div style="width: 72px; height: 58px; overflow: hidden; display: flex; justify-content: center; align-items: flex-start; border-radius: 10px;">
                    <img src="/Images/guriza_logo.png" style="width: 72px; height: auto;" alt="Guriza Logo" />
                </div>
                <span>GURIZA</span>
            </div>

            <MudText Typo="Typo.h4" Style="font-weight: 800; margin-bottom: 8px;">Welcome</MudText>
            <MudText Typo="Typo.body2" Style="color: #757575; margin-bottom: 32px;">
                Set up your password to complete your account registration.
            </MudText>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@errorMessage</MudAlert>
            }

            @if (isSuccess)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Class="mb-4">
                    Your account has been set up successfully. Redirecting to login...
                </MudAlert>
            }
            else
            {
                <EditForm Model="@setupModel" OnValidSubmit="HandleSetup">
                    <DataAnnotationsValidator />
                    
                    <span class="custom-label">Email</span>
                    <MudTextField @bind-Value="setupModel.Email"
                                 ReadOnly="@(!string.IsNullOrEmpty(Email))"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Class="mb-4"/>

                    <span class="custom-label">Password</span>
                    <MudTextField @bind-Value="setupModel.Password"
                                 For="@(() => setupModel.Password)"
                                 Placeholder="Enter new password"
                                 InputType="@_passwordInput"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                
                                 Adornment="Adornment.End" AdornmentIcon="@_passwordInputIcon"
                                 OnAdornmentClick="TogglePasswordVisibility"
                                 Class="mb-4" />

                    <span class="custom-label">Confirm Password</span>
                    <MudTextField @bind-Value="setupModel.ConfirmPassword"
                                 For="@(() => setupModel.ConfirmPassword)"
                                 Placeholder="Confirm new password"
                                 InputType="@_passwordInput"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                
                                 Adornment="Adornment.End" AdornmentIcon="@_passwordInputIcon"
                                 OnAdornmentClick="TogglePasswordVisibility"
                                 Class="mb-6" />

                    <MudButton ButtonType="ButtonType.Submit" Disabled="@isLoading" Variant="Variant.Filled" FullWidth="true" Class="login-btn mb-6">
                        @if (isLoading)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <MudText Class="ms-2" Style="color: white;">Setting up...</MudText>
                        }
                        else
                        {
                            <text>Complete Setup</text>
                        }
                    </MudButton>
                </EditForm>
            }
        </div>
    </div>

    <!-- Right Section (Blue Panel) -->
    <div class="blue-panel">
        <div style="z-index: 2; width: 100%; max-width: 500px;">
            <MudText Typo="Typo.h3" Style="font-weight: 700; line-height: 1.2;" Class="mb-6">
                Manage your LOANS and Its Operations.
            </MudText>
            <MudText Typo="Typo.h6" Style="font-weight: 400; opacity: 0.9;" Class="mb-10">
                Set up your account to access GURIZA and manage your team.
            </MudText>

            <MudPaper Elevation="25" Class="pa-4 rounded-xl relative" Style="background-color: white; min-height: 350px; color: black;">
                <div class="d-flex justify-space-between mb-4">
                    <div style="height: 12px; width: 60px; background: #eee; border-radius: 6px;"></div>
                    <div style="height: 12px; width: 40px; background: #eee; border-radius: 6px;"></div>
                </div>
                
                <MudGrid Spacing="2">
                    <MudItem xs="4">
                        <MudPaper Class="pa-3 rounded-lg" Elevation="0" Style="background: #f8f9ff;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total LOAN</MudText>
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 800; color: #070bdc;">All LOANS</MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="8">
                        <MudPaper Class="pa-3 rounded-lg" Elevation="0" Style="background: #f8f9ff;">
                            <div class="d-flex justify-space-between">
                                 <MudText Typo="Typo.caption" Color="Color.Secondary">Performance</MudText>
                                 <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Color="Color.Success"/>
                            </div>
                            <div style="height: 20px; width: 100%; background: linear-gradient(90deg, #070bdc 30%, #eee 30%); border-radius: 10px; margin-top: 4px;"></div>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12">
                         <MudTable Items="_mockRows" Elevation="0" Dense="true" Class="rounded-lg mt-2">
                            <HeaderContent>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight:700">ID</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight:700">Product</MudText></MudTh>
                                <MudTh><MudText Typo="Typo.caption" Style="font-weight:700">Status</MudText></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd><MudText Typo="Typo.caption">#@context.Id</MudText></MudTd>
                                <MudTd><MudText Typo="Typo.caption">@context.Name</MudText></MudTd>
                                <MudTd>
                                    <MudChip T="string" Color="@context.Color" Size="Size.Small" Style="font-size: 10px; height: 18px;">@context.Status</MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudItem>
                </MudGrid>

                <MudPaper Elevation="10" Class="pa-4 rounded-xl absolute d-flex flex-column align-center" 
                          Style="bottom: -20px; right: -40px; width: 160px; background: white; border: 1px solid #eee;">
                     <MudText Typo="Typo.caption" Style="font-weight: 700;">Expense Category</MudText>
                     <MudProgressCircular Color="Color.Success" Size="Size.Large" Class="my-2" />
                     <MudText Typo="Typo.caption" Style="font-weight: 800; text-align:center;">Get all expenses</MudText>
                </MudPaper>
            </MudPaper>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    private SetupTenantUserDTO setupModel = new();
    private bool isLoading = false;
    private string? errorMessage;
    private bool isSuccess = false;
    
    private bool _isPasswordVisible = false;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    private List<MockOrder> _mockRows = new() {
        new(5298, "GIRA IWAWE", "Active", Color.Success),
        new(5299, "STUDENT LOAN", "Active", Color.Warning),
    };

    public record MockOrder(int Id, string Name, string Status, Color Color);

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Email))
        {
            setupModel.Email = Email;
        }
        else
        {
            errorMessage = "Invalid setup link. Missing email parameter.";
        }
    }

    private async Task HandleSetup()
    {
        if (string.IsNullOrEmpty(setupModel.Email))
        {
            errorMessage = "Email is required.";
            return;
        }

        try
        {
            isLoading = true;
            errorMessage = null;

            await IdentityService.SetupTenantUserAsync(setupModel);
            
            isSuccess = true;
            StateHasChanged();

            // Wait 2 seconds so the user can read the success message, then redirect
            await Task.Delay(2000);
            NavigationManager.NavigateTo($"/account/login?success=Account+setup+successful.+Please+log+in.", true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    public void TogglePasswordVisibility() {
        _isPasswordVisible = !_isPasswordVisible;
        _passwordInputIcon = _isPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
        _passwordInput = _isPasswordVisible ? InputType.Text : InputType.Password;
    }
}
