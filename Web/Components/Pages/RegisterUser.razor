@page "/RegisterUser"
@attribute [AllowAnonymous]
@layout AuthLayout
@using Application.DTO
@using Application.Services.Tenants
@using Domain.ValueObjects
@rendermode InteractiveServer
@using Application.Interfaces
@using Application.Services.Users
@using Microsoft.AspNetCore.Components.Authorization
@inject IIdentityService IdentityService
@inject ITenantService TenantService
@inject NavigationManager NavigationManager

<style>
    html, body { height: 100%; margin: 0; padding: 0; overflow: hidden; }
    .success-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; z-index: 9999; animation: fadeIn 0.3s ease; }
    @@keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    .success-card { background: white; border-radius: 20px; padding: 48px 40px; max-width: 420px; width: 90%; text-align: center; box-shadow: 0 24px 64px rgba(0,0,0,0.2); }
    .success-icon-ring { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #02086b, #3b5bdb); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; }
</style>

<PageTitle>Setup Account | GURIZA</PageTitle>

@if (_registrationSuccess)
{
    <div class="success-overlay">
        <div class="success-card">
            <div class="success-icon-ring">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color:white; font-size: 2.5rem;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 800; margin-bottom: 8px;">Account Setup Complete!</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Style="margin-bottom: 32px;">
                You can now log in using your email and password.
            </MudText>
            <MudButton Variant="Variant.Filled" FullWidth="true" StartIcon="@Icons.Material.Filled.Login" Style="background: #02086b; color: white; border-radius: 25px; text-transform: none; font-weight: 700;" OnClick='() => NavigationManager.NavigateTo("/account/login")'>
                Go to Login
            </MudButton>
        </div>
    </div>
}

<MudContainer MaxWidth="MaxWidth.False" Class="d-flex align-center justify-center pa-0" Style="height: 100vh; background-color: #f5f5f5;">
    <MudPaper Elevation="4" Class="d-flex" Style="width: 900px; height: 680px; border-radius: 24px; overflow: hidden;">
        <MudGrid Spacing="0">
            <MudItem md="5" Class="d-none d-md-flex flex-column align-center justify-center pa-8" Style="background-color: #1a1512; color: white;">
                <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700; line-height: 1.2;" Class="mb-6">
                    Setup <br /> Account
                </MudText>
            </MudItem>

            <MudItem xs="12" md="7" Class="pa-8 d-flex flex-column" Style="background-color: white; height: 100%;">
                <div class="d-flex align-center mb-6">
                    <MudText Typo="Typo.h6" Style="font-weight: 900; font-family: 'Arial Black', 'Montserrat', sans-serif;">GURIZA</MudText>
                    <MudSpacer />
                    <MudLink href="/account/login" Underline="Underline.None" Color="Color.Primary" Style="font-size: 0.85rem; font-weight: 600;">Sign In</MudLink>
                </div>

                <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight: 700;">Account Setup</MudText>
                
                @if (_tenantNotFound)
                {
                    <MudAlert Severity="Severity.Error">Invalid or missing tenant link.</MudAlert>
                }
                else
                {
                    <EditForm Model="@Model" OnValidSubmit="OnValidSubmit">
                        <DataAnnotationsValidator />

                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@ErrorMessage</MudAlert>
                        }

                        <MudTextField @bind-Value="Model.Email" Label="Email Address" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" Disabled="true" />

                        <MudTextField @bind-Value="Model.Password" Label="Set Password" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="@_passwordInput" Adornment="Adornment.End" AdornmentIcon="@_passwordInputIcon" OnAdornmentClick="TogglePasswordVisibility" />

                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" FullWidth="true" Disabled="@_isProcessing" Class="py-3 shadow-none mt-6" Style="background: #02086b; color: white; border-radius: 25px; font-weight: 700;">
                            @if (_isProcessing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            <span>Complete Setup</span>
                        </MudButton>
                    </EditForm>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "email")]
    public string TenantEmail { get; set; }

    private RegisterUserDTO Model { get; set; } = new();
    private string ErrorMessage { get; set; } = string.Empty;
    private bool _isProcessing = false;
    private bool _isPasswordVisible = false;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
    private bool _registrationSuccess = false;
    private bool _tenantNotFound = false;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(TenantEmail))
        {
            var tenant = await TenantService.GetTenantByEmailAsync(TenantEmail);
            if (tenant != null && tenant.IsApproved)
            {
                Model.Email = tenant.Email;
                Model.TenantId = tenant.Id;
                Model.FirstName = tenant.FirstName ?? "";
                Model.LastName = tenant.LastName ?? "";
                Model.CompanyName = tenant.CompanyName ?? "";
                Model.PhoneNumber = tenant.PhoneNumber ?? "";
                Model.TenantType = tenant.TenantType;
            }
            else
            {
                _tenantNotFound = true;
            }
        }
        else
        {
            _tenantNotFound = true;
        }
    }

    public void TogglePasswordVisibility()
    {
        _isPasswordVisible = !_isPasswordVisible;
        _passwordInputIcon = _isPasswordVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
        _passwordInput = _isPasswordVisible ? InputType.Text : InputType.Password;
    }

    private async Task OnValidSubmit()
    {
        if (_isProcessing) return;
        _isProcessing = true;
        try
        {
            await IdentityService.RegisterUser(Model);
            _registrationSuccess = true;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally { _isProcessing = false; }
    }
}
