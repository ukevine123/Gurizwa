   private async Task onValidSubmit()
{
    try
    {
        // 1. Create the Loan Product and get the created entity back
        var createdProduct = await LoanProductService.CreateLoanProductAsync(Model);
        Snackbar.Add("LoanProduct created successfully!", Severity.Info);

        // 2. Open the Requirements configuration dialog with the new product ID
        await OpenRequirementDialog(createdProduct.Id, createdProduct.ProductName);

        // 3. Close this create dialog
        MudDialog.Close(DialogResult.Ok(createdProduct));
    }
    catch (Exception ex)
    {
        ErrorMessage = ex.Message;
        Snackbar.Add($"Error: {ex.Message}", Severity.Error);
    }
}

private async Task OpenRequirementDialog(int loanProductId, string productName)
{
    var options = new DialogOptions 
    { 
        CloseButton = true, 
        MaxWidth = MaxWidth.Medium, 
        FullWidth = true,
        BackdropClick = false 
    };

    var parameters = new DialogParameters 
    { 
        { "LoanProductId", loanProductId },
        { "ProductName", productName }
    };

    await DialogService.ShowAsync<LoanProductRequirementDialog>("Configure Requirements", parameters, options);
}
    

