@page "/Settings"

@using Application.Interfaces
@using Application.Services.BorrowerTypes
@using Application.Services.GuarantorTypes
@using Application.Services.PaymentModalities
@using Domain.Entities
@using Application.Services.PaymentTypes
@using Application.Services.AccountTypes
@using Application.Services.LoanProductSettings
@inject IDialogService DialogService
@inject IPaymentTypeService PaymentTypeService
@inject IReasonService ReasonService
@inject IBorrowerTypeService BorrowerTypeService
@inject IPaymentModalityService PaymentModalityService
@inject IGuarantorTypeService GuarantorTypeService
@inject IAccountTypeService AccountTypeService
@inject ILoanProductSettingService LoanProductSettingService




@using Application.Services.Reasons  
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-6 p-3">
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
        
        @* --- TAB 1: ACCOUNT TYPES --- *@
        <MudTabPanel Text="Payment Types" Icon="@Icons.Material.Filled.Category">
            <MudDataGrid T="PaymentType"
                         Items="@PaymentTypes"
                         MultiSelection="true"
                         SortMode="SortMode.Multiple"
                         Filterable="true"
                         Hideable="true"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         Class="elevation-1">

                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary">Payment Types</MudText>
                    <MudSpacer />
                    <MudMenu Label="Add Payment Type" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@GoToCreatePaymentType">Single</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
                    </MudMenu>
                </ToolBarContent>

                <Columns>
                    <SelectColumn T="PaymentType" />
                    <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                    <PropertyColumn Property="x => x.PaymentTypeName" Title="Payment Type" Sortable="true" />
                     <PropertyColumn Property="x => x.CreatedAt" Title="Created At" Format="dd MMM yyyy" Sortable="true" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap" />

            <TemplateColumn Title="Status" HeaderStyle="white-space:nowrap" ItemStyle="white-space:nowrap">
                <CellTemplate>
                    <MudChip T="string"
                             Color="@(context.Item.IsActive ? Color.Success : Color.Error)"
                             Size="Size.Small"
                             Variant="Variant.Text">
                        @(context.Item.IsActive ? "Active" : "Inactive")
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>

                    @* <TemplateColumn Title="Actions">
                        <CellTemplate>
                            <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense="true" Size="Size.Small">
                                <MudMenuItem Icon="@Icons.Material.Filled.Info">Details</MudMenuItem>
                                <MudMenuItem Icon="@Icons.Material.Filled.Edit">Edit</MudMenuItem>
                            </MudMenu>
                        </CellTemplate>
                    </TemplateColumn> *@
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="PaymentType" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>
        
        @* --- TAB 2 --- *@
        <MudTabPanel Text="Reasons">
            
@* --- ACTION BAR: Clean spacing and alignment --- *@
<MudGrid Class="mb-4 px-4" Spacing="2">
    <MudItem xs="12" Class="d-flex align-center justify-end gap-4">
        @if (_selectedItems.Any())
        {
            <MudText Color="Color.Primary" Typo="Typo.subtitle2">@_selectedItems.Count Selected</MudText>
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" />
            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
        }
        <MudButton StartIcon="@Icons.Material.Filled.FilterList" Variant="Variant.Text">Filter</MudButton>
        <MudButton StartIcon="@Icons.Material.Filled.Sort" Variant="Variant.Text">Sort by</MudButton>
    </MudItem>
</MudGrid>

@* --- DATA GRID: Styled with rounded corners and no borders --- *@
<MudDataGrid T="Reason" 
             Items="@_reason" 
             Hover="true" 
             Bordered="false" 
             Elevation="0" 
             MultiSelection="true"
             @bind-SelectedItems="_selectedItems"
             Class="rounded-xl border-none shadow-sm mx-4">
    
    <ToolBarContent>
        <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-weight: bold;">Reasons List</MudText>
        <MudSpacer />
        <MudMenu Label="Add Reason" 
                 Variant="Variant.Filled" 
                 EndIcon="@Icons.Material.Filled.KeyboardArrowDown" 
                 Color="Color.Primary"
                 Class="rounded-lg">
            <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@(() => GoToCreateReason())">Single</MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
        </MudMenu>
    </ToolBarContent>

    <Columns>
        <SelectColumn T="Reason" />

        <PropertyColumn Property="x => x.Id" Title="ID" />
        <PropertyColumn Property="x => x.Name" Title="Reason" />
      
        <TemplateColumn Title="Status">
            <CellTemplate>
                <MudChip T="string" 
                         Color="@(context.Item.IsActive ? Color.Success : Color.Error)" 
                         Size="Size.Small" 
                         Variant="Variant.Text"
                         Style="font-weight: 600;">
                    @(context.Item.IsActive ? "Active" : "Inactive")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
    </Columns>

    <PagerContent>
        <MudDataGridPager T="Reason" />
    </PagerContent>
</MudDataGrid>

        </MudTabPanel>

        @* --- TAB 3 --- *@
        
             <MudTabPanel Text="Account Types" Icon="@Icons.Material.Filled.Category">
            <MudDataGrid T="AccountType"
                         Items="@AccountTypes"
                         MultiSelection="true"
                         SortMode="SortMode.Multiple"
                         Filterable="true"
                         Hideable="true"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         Class="elevation-1">

                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary">Account Types</MudText>
                    <MudSpacer />
                    <MudMenu Label="Add Account Type" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@GoToCreateAccountType">Single</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
                    </MudMenu>
                </ToolBarContent>

                <Columns>
                    <SelectColumn T="AccountType" />
                    <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                    <PropertyColumn Property="x => x.AccountTypeName" Title="Account Type" Sortable="true" />

                    
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="AccountType" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>
        

        @* --- TAB 4 --- *@
        <MudTabPanel Text="Borrower Types" Icon="@Icons.Material.Filled.Category">
            <MudDataGrid T=" BorrowerType"
                         Items="@BorrowerTypes"
                         MultiSelection="true"
                         SortMode="SortMode.Multiple"
                         Filterable="true"
                         Hideable="true"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         Class="elevation-1">

                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary">Borrower Types</MudText>
                    <MudSpacer />
                    <MudMenu Label="Add Borrower Type" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@GoToCreateBorrowerType">Single</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
                    </MudMenu>
                </ToolBarContent>

                <Columns>
                    <SelectColumn T="BorrowerType" />
                    <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                    <PropertyColumn Property="x => x.Type" Title="Borrower Type" Sortable="true" />

                    
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="BorrowerType" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>

            @* // --- TAB 5 --- // *@
        <MudTabPanel Text="Guarantor Types" Icon="@Icons.Material.Filled.Category">
            <MudDataGrid T=" GuarantorType"
                         Items="@GuarantorTypes"
                         MultiSelection="true"
                         SortMode="SortMode.Multiple"
                         Filterable="true"
                         Hideable="true"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         Class="elevation-1">

                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary">Guarantor Types</MudText>
                    <MudSpacer />
                    <MudMenu Label="Add Guarantor Type" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@GoToCreateGuarantorType">Single</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
                    </MudMenu>
                </ToolBarContent>

                <Columns>
                    <SelectColumn T="GuarantorType" />
                    <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                    <PropertyColumn Property="x => x.Name" Title="Guarantor Type" Sortable="true" />

                    
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="GuarantorType" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>


        @* // --- TAB 6 --- // *@
        <MudTabPanel Text="Payment Modality" Icon="@Icons.Material.Filled.Category">
            <MudDataGrid T=" PaymentModality"
                         Items="@PaymentModalities"
                         MultiSelection="true"
                         SortMode="SortMode.Multiple"
                         Filterable="true"
                         Hideable="true"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         Class="elevation-1">

                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary">Payment Modalities</MudText>
                    <MudSpacer />
                    <MudMenu Label="Add Payment Modality" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@GoToCreatePaymentModality">Single</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
                    </MudMenu>
                </ToolBarContent>

                <Columns>
                    <SelectColumn T="PaymentModality" />
                    <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                    <PropertyColumn Property="x => x.Mode" Title="Payment Modality" Sortable="true" />

                    
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="PaymentModality" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>

         @* // --- TAB 7 --- // *@
        <MudTabPanel Text="LoanProduct Setting" Icon="@Icons.Material.Filled.Category">
            <MudDataGrid T=" LoanProductSetting"
                         Items="@LoanProductSettings"
                         MultiSelection="true"
                         SortMode="SortMode.Multiple"
                         Filterable="true"
                         Hideable="true"
                         Dense="true"
                         Hover="true"
                         Striped="true"
                         Class="elevation-1">

                <ToolBarContent>
                    <MudText Typo="Typo.h5" Color="Color.Primary">LoanProduct Setting</MudText>
                    <MudSpacer />
                    <MudMenu Label="Add LoanProduct Setting" Variant="Variant.Filled" EndIcon="@Icons.Material.Filled.KeyboardArrowDown" Color="Color.Primary">
                        <MudMenuItem Icon="@Icons.Material.Filled.Add" OnClick="@GoToCreateLoanProductSetting">Single</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.ImportExport">Import</MudMenuItem>
                    </MudMenu>
                </ToolBarContent>

                <Columns>
                    <SelectColumn T="LoanProductSetting" />
                    <PropertyColumn Property="x => x.Id" Title="ID" Sortable="true" />
                    <PropertyColumn Property="x => x.LoanProduct.ProductName" Title="LoanProduct Setting" Sortable="true" />
                    <PropertyColumn Property="x => x.InterestRate" Title="Interest Rate" Sortable="true" />
                    <PropertyColumn Property="x => x.ProcessingFee" Title="Processing Fee" Sortable="true" />
                    <PropertyColumn Property="x => x.GracePeriodDays" Title="GracePeriodDays" Sortable="true" />

                    
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="LoanProductSetting" />
                </PagerContent>
            </MudDataGrid>
        </MudTabPanel>
    </MudTabs>
</MudContainer>
@code {
    private List<PaymentType> PaymentTypes = new();
    private readonly DialogOptions _closeButton2 = new() { CloseButton = true };

     private List<Reason> _reason = new();
    private HashSet<Reason> _selectedItems = new(); // Added to support selection UI
    private readonly DialogOptions _closeButton = new() { CloseButton = true };

     private List<AccountType> AccountTypes = new();
     private List<BorrowerType> BorrowerTypes = new();
     private List<GuarantorType> GuarantorTypes = new();
     private List<PaymentModality> PaymentModalities = new();
     private List<LoanProductSetting> LoanProductSettings = new();
    private readonly DialogOptions _closeButton3 = new() { CloseButton = true };


    private async Task LoadPaymentType()
    {
        PaymentTypes = await PaymentTypeService.GetAllPaymentTypesAsync();
    }

     private async Task LoadReason()
    {
        _reason = await ReasonService.GetAllReasonsAsync();
    }

    private async Task LoadAccountType()
    {
        // Added a check to ensure we get a fresh list
        var result = await AccountTypeService.GetAllAccountTypesAsync();
        AccountTypes = result?.ToList() ?? new List<AccountType>();
    }
    private async Task LoadBorrowerType()
    {
        // Added a check to ensure we get a fresh list
        var result = await BorrowerTypeService.GetAllBorrowerTypeAsync();
        BorrowerTypes = result?.ToList() ?? new List<BorrowerType>();
    }
    private async Task LoadGuarantorType()
    {
        // Added a check to ensure we get a fresh list
        var result = await GuarantorTypeService.GetAllGuarantorTypesAsync();
        GuarantorTypes = result?.ToList() ?? new List<GuarantorType>();
    }
    private async Task LoadPaymentModality()
    {
        // Added a check to ensure we get a fresh list
        var result = await PaymentModalityService.GetAllPaymentModalitysAsync();
        PaymentModalities = result?.ToList() ?? new List<PaymentModality>();
    }
     private async Task LoadLoanProductSetting()
    {
        // Added a check to ensure we get a fresh list
        var result = await LoanProductSettingService.GetAllLoanProductSettingsAsync();
        LoanProductSettings = result?.ToList() ?? new List<LoanProductSetting>();
    }


    protected override async Task OnInitializedAsync()
    {
        await LoadPaymentType();
        await LoadReason();
        await LoadAccountType();
        await LoadBorrowerType();
        await LoadGuarantorType();
        await LoadPaymentModality();
        await LoadLoanProductSetting();
    }
    private async Task GoToCreatePaymentType()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<CreatePaymentType>("Add Payment Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100); // Small delay to let DB catch up if needed
            await LoadPaymentType();
        }
    }

    private async Task GoToCreateReason()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<CreateReason>("Add Reason", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100);
            await LoadReason();
        }
    }

     private async Task GoToCreateAccountType()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<AccountTypeDialog>("Add Account Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100); // Small delay to let DB catch up if needed
            await LoadAccountType();
        }
    }
     private async Task GoToCreateBorrowerType()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<BorrowerTypeDialog>("Add Borrower Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100); // Small delay to let DB catch up if needed
            await LoadBorrowerType();
        }
    }
     private async Task GoToCreateGuarantorType()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<GuarantorTypeDialog>("Add Guarantor Type", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100); // Small delay to let DB catch up if needed
            await LoadGuarantorType();
        }
    }
     private async Task GoToCreatePaymentModality()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<PaymentModalityDialog>("Add Payment Modality", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100); // Small delay to let DB catch up if needed
            await LoadPaymentModality();
        }
    }

    private async Task GoToCreateLoanProductSetting()
    {
        DialogOptions options = new DialogOptions() { CloseButton = true, MaxWidth = MaxWidth.ExtraSmall };

        var dialog = await DialogService.ShowAsync<LoanProductSettingDialog>("Add LoanProduct Setting", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await Task.Delay(100); // Small delay to let DB catch up if needed
            await LoadLoanProductSetting();
        }
    }
}